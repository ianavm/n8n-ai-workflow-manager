# Environment variables and secrets
.env
.mcp.json
credentials.json
token.json

# Temporary files
.tmp/
*.tmp

# Workflow backups (use n8n version history instead)
*_backup_*.json

# PayFast workflows contain the passphrase and HMAC secret inline at build time
workflows/payfast-dept/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Python's `lib/` rule above accidentally swallows client-portal/src/lib/.
# Keep that Next.js source directory tracked explicitly.
!client-portal/src/lib/
!client-portal/src/lib/**
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Netlify
.netlify/

# Node
node_modules/

# Client portal environment
client-portal/.env.local
client-portal/.env*.local

# Secrets baseline
.secrets.baseline

# OS
.DS_Store
Thumbs.db

# GitHub reference repos (large, not for commit)
Github Access/

# Obsidian — personal state (do not commit)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/hotkeys.json
.obsidian/plugins/*/data.json
.obsidian/plugins/*/styles.css

