# ============================================
# AnyVision Media — Client Portal Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Supabase — Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URLs
NEXT_PUBLIC_APP_URL=https://portal.anyvisionmedia.com
MAIN_SITE_URL=https://www.anyvisionmedia.com

# Google OAuth -- Get from Google Cloud Console > Credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Stripe -- Get from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayFast -- Get from PayFast Merchant Dashboard > Settings > Integration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# n8n Webhooks -- Get from n8n workflow webhook URLs
N8N_WEBHOOK_MEETING_CREATED=https://your-n8n-instance.app.n8n.cloud/webhook/meeting-created
PROPERTY_ANALYZER_WEBHOOK_SECRET=your-webhook-secret
N8N_WEBHOOK_SECRET=your-shared-n8n-webhook-secret

# Upstash Redis -- Distributed rate limiter for /api/auth/* and login pages.
# Required in production (Vercel edge runtime doesn't share in-memory state
# across nodes). Free tier is sufficient.
# 1) Sign up at https://console.upstash.com
# 2) Create a Redis database (Global or Regional, pick a region close to
#    your Vercel deployment)
# 3) On the database page, scroll to "REST API" and copy both values below
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Stripe webhook (in addition to STRIPE_SECRET_KEY above)
# Get from Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret

# PayFast environment -- "false" for live, omit or "true" for sandbox
PAYFAST_SANDBOX=false

# Meta (Facebook/Instagram) App -- server-only, do NOT prefix with NEXT_PUBLIC_
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
