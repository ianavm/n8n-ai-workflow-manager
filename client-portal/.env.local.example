# ============================================
# AnyVision Media — Client Portal Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Supabase — Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URLs
NEXT_PUBLIC_APP_URL=https://portal.anyvisionmedia.com
MAIN_SITE_URL=https://www.anyvisionmedia.com

# Google OAuth -- Get from Google Cloud Console > Credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Stripe -- Get from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayFast -- Get from PayFast Merchant Dashboard > Settings > Integration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# n8n Webhooks -- Get from n8n workflow webhook URLs
N8N_WEBHOOK_MEETING_CREATED=https://ianimmelman89.app.n8n.cloud/webhook/meeting-created
PROPERTY_ANALYZER_WEBHOOK_SECRET=your-webhook-secret
