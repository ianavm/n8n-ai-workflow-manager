# n8n Agentic Workflows Manager - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================================
# n8n Instance
# ============================================================
# N8N_BASE_URL=https://your-n8n-instance.com
# N8N_API_KEY=your_n8n_api_key_here

# ============================================================
# AI Model API Keys
# ============================================================
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================
# Google OAuth (for Slides/Gmail reporting)
# ============================================================
# GOOGLE_CREDENTIALS_PATH=credentials.json
# GOOGLE_TOKEN_PATH=token.json

# ============================================================
# Airtable
# ============================================================
# AIRTABLE_API_TOKEN=your_airtable_pat_here

# Accounting department table IDs
# ACCOUNTING_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_CUSTOMERS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_SUPPLIERS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_PRODUCTS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_INVOICES=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_PAYMENTS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_SUPPLIER_BILLS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_TASKS=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_AUDIT_LOG=tblXXXXXXXXXXXXXX
# ACCOUNTING_TABLE_SYSTEM_CONFIG=tblXXXXXXXXXXXXXX
# ACCOUNTING_XERO_CRED_ID=your_n8n_xero_cred_id

# ============================================================
# Webhook Security
# ============================================================
# WEBHOOK_AUTH_TOKEN=generate_a_random_64_char_token_here
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# PAYFAST_PASSPHRASE=your_payfast_passphrase

# ============================================================
# WhatsApp Business API (INACTIVE - pending Meta verification)
# ============================================================
# WHATSAPP_APP_ID=your_app_id
# WHATSAPP_APP_SECRET=your_app_secret
# WHATSAPP_PHONE_NUMBER_ID=your_phone_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_id
# WHATSAPP_TEMPLATE_NAME=hello_world  # Pre-approved template for 24h window fallback

# ============================================================
# Google Places API (Lead Scraper)
# ============================================================
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ============================================================
# n8n Credential IDs (internal references, not secrets)
# ============================================================
# N8N_CRED_GMAIL=your_n8n_gmail_cred_id
# N8N_CRED_AIRTABLE=your_n8n_airtable_cred_id
# N8N_CRED_OPENROUTER=your_n8n_openrouter_cred_id
# N8N_CRED_WHATSAPP=your_n8n_whatsapp_send_cred_id
# N8N_CRED_WHATSAPP_TRIGGER=your_n8n_whatsapp_trigger_cred_id
# N8N_CRED_WHATSAPP_AIRTABLE=your_n8n_whatsapp_airtable_cred_id

# ============================================================
# MCP Server Credentials (Claude Code integrations)
# ============================================================
# GITHUB_PAT=ghp_your_github_personal_access_token
# SUPABASE_ACCESS_TOKEN=sbp_your_supabase_access_token
# SUPABASE_PROJECT_REF=your_supabase_project_ref_id

# Xero MCP Server (direct Xero API access from Claude)
# Create at: https://developer.xero.com/app/manage → Custom Connections
# XERO_CLIENT_ID=your_xero_app_client_id
# XERO_CLIENT_SECRET=your_xero_app_client_secret

# Google Workspace MCP Server (Gmail, Sheets, Slides, Calendar, Drive, Docs, Contacts)
# Create at: https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client (Desktop App)
# Enable APIs: Gmail, Drive, Sheets, Slides, Calendar, Docs, People
# GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================================
# Property Analyzer
# ============================================================
# N8N_PROPERTY_ANALYZER_WEBHOOK_URL=https://ianimmelman89.app.n8n.cloud/webhook/property-analyzer/analyze
# PROPERTY_ANALYZER_WEBHOOK_SECRET=generate_a_random_64_char_token_here
# NEXT_PUBLIC_APP_URL=https://portal.anyvisionmedia.com

# ============================================================
# Multi-Client Config (per-client Airtable tokens)
# ============================================================
# AIRTABLE_TOKEN_CLIENTNAME=pat_client_specific_token
