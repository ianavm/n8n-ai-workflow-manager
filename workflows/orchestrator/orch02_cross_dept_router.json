        "responseBody": "={\"status\": \"received\", \"event_id\": \"{{ $json.fields['Event ID'] || $json.eventId }}\", \"routed_to\": \"{{ $('Route Event').first().json.targetAgent }}\"}",
        "options": {}
      },
