    {
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 500, \"temperature\": 0.7, \"messages\": [{\"role\": \"user\", \"content\": \"You are a professional real estate video script writer for AnyVision Media, a digital media agency in South Africa.\\n\\nWrite a compelling, natural-sounding video script for a property walkthrough presentation. The avatar presenter will stand in front of property photos and narrate.\\n\\nPROPERTY DETAILS:\\n- Name: {{ $json['Property Name'] }}\\n- Type: {{ $json['Property Type'] }}\\n- Address: {{ $json['Property Address'] }}\\n- Price: R{{ $json['Listing Price ZAR'] }}\\n- Key Features: {{ $json['Key Features'] }}\\n\\nREQUIREMENTS:\\n1. Script should be 30-60 seconds when spoken (roughly 75-150 words)\\n2. Open with an attention-grabbing hook (first 3 seconds matter for social media)\\n3. Highlight the top 3-4 features naturally\\n4. Include the price and location\\n5. End with a clear call-to-action (DM, call, link in bio)\\n6. Tone: {{ $json['Script Tone'] || 'professional, warm, aspirational' }}\\n7. Use South African English (e.g., \\\"lounge\\\" not \\\"living room\\\", \\\"garden\\\" not \\\"yard\\\")\\n8. Do NOT use emojis in the script\\n9. Do NOT include stage directions or camera cues - just the spoken words\\n\\nOUTPUT FORMAT:\\nReturn ONLY the script text, nothing else. No headers, no labels, just the words the presenter will say.\"}]}",
        "options": {}
      },
      "id": "0096ea38-04bf-44fc-8648-800d6c5f503a",
      "name": "Generate Script",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1460,
        300
      ],
      "typeVersion": 4.2,
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 300, \"temperature\": 0.7, \"messages\": [{\"role\": \"user\", \"content\": \"You are a social media expert for AnyVision Media, a real estate-focused digital media agency in South Africa.\\n\\nWrite a short, engaging social media caption for a property video post.\\n\\nPROPERTY: {{ $('Loop Over Jobs').item.json['Property Name'] }} in {{ $('Loop Over Jobs').item.json['Property Address'] }}\\nPRICE: R{{ $('Loop Over Jobs').item.json['Listing Price ZAR'] }}\\nTYPE: {{ $('Loop Over Jobs').item.json['Property Type'] }}\\nFEATURES: {{ $('Loop Over Jobs').item.json['Key Features'] }}\\n\\nREQUIREMENTS:\\n1. Max 150 characters for the caption text (before hashtags)\\n2. Attention-grabbing, create urgency or curiosity\\n3. Include the price\\n4. South African English\\n5. Add 5-8 relevant hashtags on a new line\\n\\nOUTPUT FORMAT:\\nLine 1: Caption text\\nLine 2: Hashtags (space-separated, starting with #)\"}]}",
        "options": {}
      },
      "id": "b7bc6b54-53a0-4f2a-ab07-4aeb23202e30",
      "name": "Generate Caption",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1740,
        300
      ],
      "typeVersion": 4.2,
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\n// Build HeyGen API v2 video generation payload\nconst job = $input.first().json;\nconst script = $('Generate Script').first().json.message.content || $('Generate Script').first().json.choices[0].message.content;\nconst caption = $('Generate Caption').first().json.message.content || $('Generate Caption').first().json.choices[0].message.content;\n\n// Parse caption into text + hashtags\nconst captionLines = caption.trim().split('\\n').filter(l => l.trim());\nconst captionText = captionLines[0] || '';\nconst hashtags = captionLines.find(l => l.includes('#')) || '';\n\n// Determine dimensions from aspect ratio\nconst aspectRatio = job['Aspect Ratio'] || '9:16';\nconst dimensions = {\n  '9:16': { width: 1080, height: 1920 },\n  '16:9': { width: 1920, height: 1080 },\n  '1:1':  { width: 1080, height: 1080 },\n};\nconst dim = dimensions[aspectRatio] || dimensions['9:16'];\n\n// Get avatar/voice config\nconst avatarId = job['Avatar ID'] || 'REPLACE_WITH_YOUR_AVATAR_ID';\nconst voiceId = job['HeyGen Voice ID'] || 'REPLACE_WITH_YOUR_VOICE_ID';\n\n// Build the HeyGen v2 payload\nconst payload = {\n  video_inputs: [\n    {\n      character: {\n        type: \"avatar\",\n        avatar_id: avatarId,\n        avatar_style: \"normal\",\n      },\n      voice: {\n        type: \"text\",\n        input_text: script.trim(),\n        voice_id: voiceId,\n        speed: 1.0,\n      },\n      background: {\n        type: \"color\",\n        value: \"#FFFFFF\",\n      },\n    },\n  ],\n  dimension: dim,\n  aspect_ratio: null,\n  test: false,\n};\n\n// If property photos exist, use first as background\nconst photos = (job['Property Photos'] || '').split('\\n').filter(u => u.trim().startsWith('http'));\nif (photos.length > 0) {\n  payload.video_inputs[0].background = {\n    type: \"image\",\n    url: photos[0].trim(),\n  };\n}\n\nreturn {\n  json: {\n    heygenPayload: payload,\n    script: script.trim(),\n    caption: captionText.trim(),\n    hashtags: hashtags.trim(),\n    jobId: job['Job ID'] || job.id,\n    recordId: job.id,\n    propertyName: job['Property Name'] || '',\n    aspectRatio: aspectRatio,\n  }\n};\n"
      },
