    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "e6607d66-9f96-410f-9eb8-37c0c5794f74",
              "leftValue": "={{ $json.length }}",
