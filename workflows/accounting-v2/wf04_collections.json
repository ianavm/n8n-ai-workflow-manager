    {
      "parameters": {
        "jsCode": "// Fetch the customer record for the current invoice\nconst invoice = $input.first().json;\nconst customerId = invoice.customer_id;\n\nif (!customerId) {\n  return [{ json: { ...invoice, customer: null, customerEmail: null, customerName: 'Unknown' } }];\n}\n\nconst url = 'REPLACE/rest/v1/acct_customers'\n  + '?select=*'\n  + '&id=eq.' + customerId;\n\nconst resp = await fetch(url, {\n  method: 'GET',\n  headers: {\n    'apikey': 'REPLACE',\n    'Authorization': 'Bearer REPLACE',\n    'Accept': 'application/vnd.pgrst.object+json',\n  },\n});\n\nlet customer = null;\nlet customerEmail = null;\nlet customerName = 'Valued Customer';\n\nif (resp.ok) {\n  customer = await resp.json();\n  customerEmail = customer.email || customer.billing_email || null;\n  customerName = customer.name || customer.company_name || 'Valued Customer';\n}\n\nreturn [{ json: {\n  ...invoice,\n  customer,\n  customerEmail,\n  customerName,\n} }];\n"
      },
      "id": "c4d0d4d9-0508-4623-b5d7-0381f11f3c60",
      "name": "Fetch Customer",
      "type": "n8n-nodes-base.code",
      "position": [
        1440,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Determine reminder tier based on days overdue vs cadence\nconst item = $input.first().json;\nconst now = new Date();\nconst dueDate = new Date(item.due_date);\nconst daysOverdue = Math.floor((now - dueDate) / (1000 * 60 * 60 * 24));\n\n// Default cadence: [-3, 0, 3, 7, 14]\nconst cadence = item.reminderCadenceDays\n  || $('Find Overdue Invoices').first().json.reminderCadenceDays\n  || [-3, 0, 3, 7, 14];\n\nconst escalationAfterDays = item.escalationAfterDays\n  || $('Find Overdue Invoices').first().json.escalationAfterDays\n  || 30;\n\n// Determine tier:\n//   tier 1 = friendly  (0-3 days overdue)\n//   tier 2 = firm      (4-14 days overdue)\n//   tier 3 = escalation (14+ days overdue)\nlet tier = 1;\nif (daysOverdue >= 14) {\n  tier = 3;\n} else if (daysOverdue >= 4) {\n  tier = 2;\n}\n\nconst currentReminderCount = parseInt(item.reminder_count || '0', 10);\n\n// Only send if this tier hasn't been sent yet\nconst shouldSend = tier > currentReminderCount;\n\nreturn [{\n  json: {\n    ...item,\n    daysOverdue,\n    tier,\n    tierLabel: tier === 1 ? 'friendly' : tier === 2 ? 'firm' : 'escalation',\n    shouldSend,\n    currentReminderCount,\n    escalationAfterDays,\n  }\n}];\n"
      },
      "id": "8acd4eef-0ab8-4e86-9ba8-c1a045c95ef5",
      "name": "Determine Reminder Tier",
      "type": "n8n-nodes-base.code",
      "position": [
        1680,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "ec34f379-fc23-4c61-a29d-06bce2e859f5",
              "leftValue": "{{ $json.shouldSend }}",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "e7dc3073-8dc6-48d3-a2e0-20779291ca8b",
      "name": "Should Send Reminder?",
      "type": "n8n-nodes-base.if",
      "position": [
        1920,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.tier }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "friendly"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.tier }}",
                    "rightValue": "2",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "firm"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.tier }}",
                    "rightValue": "3",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "escalation"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "3bbaf07e-9535-4385-87ab-cbf72384bf9e",
