    {
      "parameters": {
        "jsCode": "// Fetch overdue invoices from Supabase\nconst config = $input.first().json;\n\nconst today = new Date().toISOString().split('T')[0];\n\n// Query: status IN (sent, payment_pending, overdue) AND due_date <= today AND balance_due > 0\nconst url = 'REPLACE/rest/v1/acct_invoices'\n  + '?select=*'\n  + '&status=in.(sent,payment_pending,overdue)'\n  + '&due_date=lte.' + today\n  + '&balance_due=gt.0'\n  + '&order=due_date.asc';\n\nconst resp = await fetch(url, {\n  method: 'GET',\n  headers: {\n    'apikey': 'REPLACE',\n    'Authorization': 'Bearer REPLACE',\n    'Accept': 'application/json',\n  },\n});\n\nif (!resp.ok) {\n  throw new Error('Supabase query failed: ' + resp.status + ' ' + (await resp.text()));\n}\n\nconst invoices = await resp.json();\n\nif (invoices.length === 0) {\n  return [{ json: { overdueCount: 0, invoices: [], config } }];\n}\n\n// Pass config along for later use\nreturn [{ json: {\n  overdueCount: invoices.length,\n  invoices,\n  config,\n  reminderCadenceDays: config.reminder_cadence_days || [-3, 0, 3, 7, 14],\n  escalationAfterDays: config.escalation_after_days || 30,\n} }];\n"
      },
      "id": "4e619688-dc32-4036-b9b9-1b8eb5f2423a",
      "name": "Find Overdue Invoices",
      "type": "n8n-nodes-base.code",
      "position": [
        720,
        400
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "ad79c7a8-af60-4b31-82eb-a67cee444829",
              "leftValue": "{{ $json.overdueCount }}",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "rightValue": "0"
            }
          ],
          "combinator": "and"
        }
      },
      "id": "cf3148fc-3657-414b-967f-04e9b8e57fd9",
      "name": "Has Overdue?",
