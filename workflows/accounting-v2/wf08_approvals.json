        "jsCode": "const item = $('Mark Task Completed').first().json;\nconst action = item.approval_action || 'processed';\nconst color = action === 'approve' ? '#38a169' : '#e53e3e';\nconst label = action === 'approve' ? 'Approved' : 'Rejected';\n\nreturn [{\n  json: {\n    success: true,\n    html: '<html><body style=\"font-family:sans-serif;text-align:center;padding:60px\">'\n      + '<h1 style=\"color:' + color + '\">' + label + '</h1>'\n      + '<p>The ' + (item.task_type || 'task') + ' has been <strong>' + action + 'd</strong>.</p>'\n      + '<p style=\"color:#888\">You can close this window.</p>'\n      + '</body></html>',\n  }\n}];\n"
