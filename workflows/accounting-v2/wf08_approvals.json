                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "invoice_approval",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "invoice"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "bill_approval",
                    "operator": {
