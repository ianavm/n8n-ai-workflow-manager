        "jsCode": "const qs = $input.first().json.query || $input.first().json;\nif (!qs.token) {\n  throw new Error('Missing approval token');\n}\nreturn [{\n  json: {\n    token: qs.token,\n    action: 'approve',\n  }\n}];\n"
