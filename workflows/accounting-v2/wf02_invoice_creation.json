    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet totalProcessed = 0;\nlet totalCents = 0;\nlet approvedCount = 0;\nlet pendingApprovalCount = 0;\nconst summaryLines = [];\n\nfor (const item of items) {\n  const inv = item.json;\n  if (inv && inv.invoice_number) {\n    totalProcessed++;\n    totalCents += inv.total_cents || 0;\n    if (inv._isHighValue) {\n      pendingApprovalCount++;\n    } else {\n      approvedCount++;\n    }\n    const rands = ((inv.total_cents || 0) / 100).toFixed(2);\n    summaryLines.push(`${inv.invoice_number} - ${inv.customer_name || 'Unknown'} - R ${rands}`);\n  }\n}\n\nreturn [{\n  json: {\n    success: true,\n    total_processed: totalProcessed,\n    total_invoiced_cents: totalCents,\n    total_invoiced_display: `R ${(totalCents / 100).toFixed(2)}`,\n    approved: approvedCount,\n    pending_approval: pendingApprovalCount,\n    invoices: summaryLines,\n    completed_at: new Date().toISOString(),\n  }\n}];\n"
      },
