          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({  Line: $json.processed_line_items.map(li => ({    Amount: li.line_subtotal_cents / 100,    Description: li.description,    DetailType: 'SalesItemLineDetail',    SalesItemLineDetail: { Qty: li.quantity, UnitPrice: li.unit_price_cents / 100 }  })),  CustomerRef: { value: $json._customer?.external_id || '' },  DocNumber: $json.invoice_number,  CurrencyRef: { value: 'ZAR' }}) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "cb41316f-4c20-4c7e-ae99-99cd044c3509",
      "name": "Sync QuickBooks",
