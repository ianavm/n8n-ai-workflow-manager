      "position": [
        200,
        800
      ],
      "typeVersion": 2,
      "webhookId": "a91e56ae-f52f-4e49-b573-56caf1933e68"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "REPLACE/rest/v1/acct_config?select=*&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
