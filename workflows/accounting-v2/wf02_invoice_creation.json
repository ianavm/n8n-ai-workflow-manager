              "responseFormat": "json"
            }
          }
        }
      },
      "id": "42d15bbc-fd2e-489c-80aa-922be8e51f46",
      "name": "Load Client Config",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        460,
        400
      ],
      "typeVersion": 4.2,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "GET",
        "url": "REPLACE/rest/v1/acct_invoices?select=*&status=eq.draft&order=created_at.asc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "REPLACE"
            },
            {
              "name": "Authorization",
              "value": "Bearer REPLACE"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "bd003924-2c97-4419-b00b-024d78966d82",
      "name": "Read Draft Invoices",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        700,
        400
      ],
      "typeVersion": 4.2,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Combine scheduled draft invoices with any webhook payload\nconst config = $('Load Client Config').first().json;\nconst draftItems = $input.all().filter(i => i.json && i.json.id);\n\nlet webhookData = null;\ntry { webhookData = $('Invoice Webhook').first(); } catch(e) { /* not triggered */ }\n\nconst items = [];\n\n// Add draft invoices from Supabase\nfor (const item of draftItems) {\n  items.push({ ...item.json, _config: config });\n}\n\n// Add webhook invoice request if present\nif (webhookData && webhookData.json && webhookData.json.body) {\n  const body = webhookData.json.body;\n  items.push({\n    id: body.id || `wh-${Date.now()}`,\n    client_id: body.client_id || config.client_id,\n    customer_id: body.customer_id,\n    line_items: body.line_items || [],\n    notes: body.notes || '',\n    due_date: body.due_date || null,\n    status: 'draft',\n    source: 'webhook',\n    _config: config,\n  });\n}\n\nif (items.length === 0) {\n  return [{ json: { _empty: true, _config: config, totalItems: 0 } }];\n}\nreturn items.map(item => ({ json: item }));\n"
      },
      "id": "aa106c33-a969-475e-aaa8-b4a0715ed072",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.code",
      "position": [
        940,
        600
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "074df18f-3710-410c-9b58-8288a7b0a0ca",
              "leftValue": "{{ $json._empty }}",
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "53066286-57f5-4990-8cc5-df2ab378ecc4",
      "name": "Has Items?",
      "type": "n8n-nodes-base.if",
      "position": [
        1160,
        600
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "5ec761a1-e05c-4998-b31e-136e23d25307",
      "name": "Loop Over Invoices",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [
        1400,
        500
      ],
      "typeVersion": 3
    },
    {
      "parameters": {
        "jsCode": "// Build Supabase query for the customer\nconst invoice = $input.first().json;\nconst customerId = invoice.customer_id;\n\nif (!customerId) {\n  return [{ json: { ...invoice, _customer: null, _customerFound: false } }];\n}\n\n// Pass through — the next HTTP node does the actual lookup\nreturn [{ json: { ...invoice, _lookupCustomerId: customerId } }];\n"
      },
      "id": "f9ed1272-358f-4fb9-9e12-a6808120fcde",
      "name": "Lookup Customer",
      "type": "n8n-nodes-base.code",
      "position": [
        1600,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "GET",
        "url": "REPLACE/rest/v1/acct_customers?select=*&id=eq.{{ $json._lookupCustomerId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "REPLACE"
            },
            {
              "name": "Authorization",
              "value": "Bearer REPLACE"
            },
            {
              "name": "Accept",
              "value": "application/vnd.pgrst.object+json"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "da30097f-f935-4d5b-b6fc-cf792e7674e8",
      "name": "Fetch Customer",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1820,
        500
      ],
      "typeVersion": 4.2,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const customer = $input.first().json;\nconst invoice = $('Lookup Customer').first().json;\n\nreturn [{\n  json: {\n    ...invoice,\n    _customer: customer || {},\n    _customerFound: !!(customer && customer.id),\n    customer_name: customer.name || customer.company_name || '',\n    customer_email: customer.email || '',\n  }\n}];\n"
      },
      "id": "953108ac-428a-4fa0-a671-9ade193c371f",
      "name": "Merge Customer Into Invoice",
      "type": "n8n-nodes-base.code",
      "position": [
        2060,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Compute line_items totals, subtotal, VAT, total — all in cents\nconst invoice = $input.first().json;\nconst config = invoice._config || {};\nconst vatRate = parseFloat(config.vat_rate) || 0.15;\n\nlet lineItemsRaw = invoice.line_items || '[]';\nlet lineItems;\ntry {\n  lineItems = typeof lineItemsRaw === 'string' ? JSON.parse(lineItemsRaw) : lineItemsRaw;\n} catch(e) {\n  lineItems = [];\n}\n\nlet subtotal_cents = 0;\nlet vat_cents = 0;\nconst processed = [];\n\nfor (const item of lineItems) {\n  const qty = parseInt(item.quantity) || 1;\n  // unit_price_cents: price in cents (integer)\n  const unitPriceCents = parseInt(item.unit_price_cents) || 0;\n  const isVatable = item.vat_exempt !== true;\n  \n  const lineSubtotal = unitPriceCents * qty;\n  const lineVat = isVatable ? Math.round(lineSubtotal * vatRate) : 0;\n  const lineTotal = lineSubtotal + lineVat;\n  \n  subtotal_cents += lineSubtotal;\n  vat_cents += lineVat;\n  \n  processed.push({\n    description: item.description || '',\n    item_code: item.item_code || '',\n    quantity: qty,\n    unit_price_cents: unitPriceCents,\n    vat_exempt: !isVatable,\n    line_subtotal_cents: lineSubtotal,\n    line_vat_cents: lineVat,\n    line_total_cents: lineTotal,\n  });\n}\n\nconst total_cents = subtotal_cents + vat_cents;\n\nreturn [{\n  json: {\n    ...invoice,\n    processed_line_items: processed,\n    subtotal_cents,\n    vat_cents,\n    total_cents,\n    vat_rate: vatRate,\n    currency: 'ZAR',\n  }\n}];\n"
      },
      "id": "99f46242-6340-44b0-b8ed-19d3dbbfd52d",
      "name": "Calculate Tax",
      "type": "n8n-nodes-base.code",
      "position": [
        2300,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const invoice = $input.first().json;\nconst clientId = invoice.client_id || invoice._config?.client_id || '';\nreturn [{ json: { p_client_id: clientId, _invoice: invoice } }];\n"
      },
      "id": "89adae9f-7379-46a3-bf85-bad4606fe477",
      "name": "Prepare RPC Params",
      "type": "n8n-nodes-base.code",
      "position": [
        2520,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "REPLACE/rest/v1/rpc/acct_generate_invoice_number",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "REPLACE"
            },
            {
              "name": "Authorization",
              "value": "Bearer REPLACE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "dced0ca3-b57d-4bef-9d03-d2bab2a6047c",
      "name": "Generate Invoice Number",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2740,
        500
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "const rpcResult = $input.first().json;\nconst invoice = $('Prepare RPC Params').first().json._invoice;\nconst invoiceNumber = rpcResult.invoice_number || rpcResult || `INV-${Date.now()}`;\n\nreturn [{\n  json: {\n    ...invoice,\n    invoice_number: typeof invoiceNumber === 'string' ? invoiceNumber : String(invoiceNumber),\n  }\n}];\n"
      },
      "id": "8adab2be-3ce1-410d-800b-96d1ddfa1a8f",
      "name": "Attach Invoice Number",
      "type": "n8n-nodes-base.code",
      "position": [
        2960,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const invoice = $input.first().json;\nconst config = invoice._config || {};\n// Default threshold: R50,000 = 5000000 cents\nconst threshold = parseInt(config.high_value_threshold) || 5000000;\nconst isHighValue = invoice.total_cents > threshold;\n\nreturn [{ json: { ...invoice, _isHighValue: isHighValue, _threshold: threshold } }];\n"
      },
      "id": "7f31db76-3ce2-469e-ac69-b5274f262584",
      "name": "Check High Value",
      "type": "n8n-nodes-base.code",
      "position": [
        3180,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cdfe7248-d024-44f9-a776-7a2dae0968f5",
              "leftValue": "{{ $json._isHighValue }}",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "8de33d90-2d7e-4bc5-972d-e3e7acf45ba7",
      "name": "Is High Value?",
      "type": "n8n-nodes-base.if",
      "position": [
        3400,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const inv = $input.first().json;\nconst totalRands = (inv.total_cents / 100).toFixed(2);\nreturn [{\n  json: {\n    action: 'task_created',\n    data: {\n      client_id: inv.client_id,\n      invoice_id: inv.id,\n      invoice_number: inv.invoice_number,\n      customer_name: inv.customer_name,\n      total_cents: inv.total_cents,\n      total_display: `R ${totalRands}`,\n      task_type: 'high_value_approval',\n      priority: 'high',\n      description: `High-value invoice ${inv.invoice_number} for ${inv.customer_name} - R ${totalRands} requires approval`,\n    }\n  }\n}];\n"
      },
      "id": "e1e0ac88-5529-46e8-9615-a8d9f4d31c83",
      "name": "Prepare Approval Task",
      "type": "n8n-nodes-base.code",
      "position": [
        3640,
        300
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://portal.anyvisionmedia.com/api/webhooks/n8n-accounting",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-webhook-secret",
              "value": "REPLACE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({action: \"task_created\", data: $json}) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 10000
        }
      },
      "id": "65a28a0b-1e52-4b99-995a-4c6ac34ed6a8",
      "name": "Portal: Task Created",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        3880,
        300
      ],
      "typeVersion": 4.2,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const inv = $('Prepare Approval Task').first().json.data;\nreturn [{\n  json: {\n    id: inv.invoice_id,\n    updatePayload: {\n      status: 'pending_approval',\n      invoice_number: inv.invoice_number,\n      subtotal_cents: $('Check High Value').first().json.subtotal_cents,\n      vat_cents: $('Check High Value').first().json.vat_cents,\n      total_cents: inv.total_cents,\n      updated_at: new Date().toISOString(),\n    }\n  }\n}];\n"
      },
      "id": "74553080-c405-4ed0-97c2-fc405d52069f",
      "name": "Set Pending Approval",
      "type": "n8n-nodes-base.code",
      "position": [
        4120,
        300
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=REPLACE/rest/v1/acct_invoices?id=eq.{{ $json.id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "REPLACE"
            },
            {
              "name": "Authorization",
              "value": "Bearer REPLACE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.updatePayload || $json) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "f4cd5590-f119-419f-b8b0-5adb0b10ddd4",
      "name": "Update Invoice Pending",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        4360,
        300
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "const inv = $input.first().json;\nconst config = inv._config || {};\nconst software = (config.accounting_software || 'none').toLowerCase();\nreturn [{ json: { ...inv, _accounting_software: software } }];\n"
      },
      "id": "16a89944-663a-46b0-8e25-b5367cd59e54",
      "name": "Prepare Adapter",
      "type": "n8n-nodes-base.code",
      "position": [
        3640,
        700
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._accounting_software }}",
                    "rightValue": "quickbooks",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "quickbooks"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._accounting_software }}",
                    "rightValue": "xero",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "xero"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._accounting_software }}",
                    "rightValue": "sage",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "sage"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "bbdbea2f-f3b0-455a-b838-0ebe1acc842d",
      "name": "Accounting Software",
      "type": "n8n-nodes-base.switch",
      "position": [
        3880,
