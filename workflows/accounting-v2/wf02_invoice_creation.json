      "onError": "continueRegularOutput"
    },
    {
      "parameters": {},
      "id": "53ee3fa3-e783-43b0-a2f8-b0954e3e39d8",
      "name": "Skip Sync",
      "type": "n8n-nodes-base.noOp",
      "position": [
        4140,
        1100
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n// Extract external ID from whichever adapter responded\nconst externalId = item.Id || item.InvoiceID || item.id || null;\nconst prevInvoice = (() => {\n  try { return $('Prepare Adapter').first().json; } catch(e) { return {}; }\n})();\n\nreturn [{\n  json: {\n    ...prevInvoice,\n    external_id: externalId,\n    sync_status: externalId ? 'synced' : 'local_only',\n  }\n}];\n"
      },
