            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({  Type: 'ACCREC',  Contact: { ContactID: $json._customer?.external_id || '' },  InvoiceNumber: $json.invoice_number,  CurrencyCode: 'ZAR',  LineItems: $json.processed_line_items.map(li => ({    Description: li.description,    Quantity: li.quantity,    UnitAmount: li.unit_price_cents / 100,    TaxType: li.vat_exempt ? 'EXEMPTOUTPUT' : 'OUTPUT2'  }))}) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "4d6db23c-4d13-444a-a9a8-0798d38cdcdf",
      "name": "Sync Xero",
