      "id": "eecf8deb-d6d4-403a-bc95-3a0f1f64dbf1",
      "name": "Fetch Approved Bills",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        720,
        300
      ],
      "typeVersion": 4.2,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "fc44e797-1ef6-4ab0-9f87-ed7f08e24e30",
              "leftValue": "={{ $json.length }}",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "rightValue": "0"
            }
          ],
          "combinator": "and"
        }
      },
      "id": "cf90dc34-805a-4a7b-bdeb-9a207dbca5a8",
      "name": "Has Bills?",
      "type": "n8n-nodes-base.if",
      "position": [
        960,
        300
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    success: true,\n    message: 'No approved unpaid bills found',\n    bills_processed: 0,\n  }\n}];\n"
      },
      "id": "fa81bb77-4aef-4eb1-b809-cba42fe66978",
      "name": "No Bills Response",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
        500
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const bills = $input.all().map(i => i.json);\nconst config = $('Load Config').first().json;\nconst groups = {};\n\nfor (const bill of bills) {\n  const sid = bill.supplier_id;\n  if (!groups[sid]) {\n    groups[sid] = {\n      supplier_id: sid,\n      supplier_name: bill.acct_suppliers?.legal_name || 'Unknown',\n      supplier_email: bill.acct_suppliers?.email || null,\n      bills: [],\n      total: 0,\n      client_id: config.client_id,\n      accounting_software: config.accounting_software,\n      payment_method: config.payment_method,\n      owner_email: config.owner_email,\n      run_date: config.run_date,\n    };\n  }\n  groups[sid].bills.push({\n    id: bill.id,\n    bill_number: bill.bill_number,\n    amount: Number(bill.amount_due || bill.total_amount || 0),\n    due_date: bill.due_date,\n    description: bill.description || bill.bill_number,\n  });\n  groups[sid].total += Number(bill.amount_due || bill.total_amount || 0);\n}\n\nreturn Object.values(groups).map(g => ({\n  json: { ...g, total: Math.round(g.total * 100) / 100 }\n}));\n"
      },
      "id": "71421219-cfbf-4ad4-b206-f414f82620f0",
      "name": "Group by Supplier",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
        200
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const g = $input.first().json;\nconst rows = g.bills.map(b =>\n  `<tr><td>${b.bill_number}</td><td>${b.description}</td>`\n  + `<td>${b.due_date || '-'}</td><td style=\"text-align:right\">R ${b.amount.toFixed(2)}</td></tr>`\n).join('\\n');\n\nconst html = `\n<h2>Remittance Advice</h2>\n<p>Dear ${g.supplier_name},</p>\n<p>Please find below the details of payment processed on ${g.run_date}:</p>\n<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse\">\n<tr style=\"background:#f0f0f0\">\n  <th>Bill #</th><th>Description</th><th>Due Date</th><th>Amount</th>\n</tr>\n${rows}\n<tr style=\"font-weight:bold\">\n  <td colspan=\"3\">Total</td><td style=\"text-align:right\">R ${g.total.toFixed(2)}</td>\n</tr>\n</table>\n<p>Payment method: ${g.payment_method.toUpperCase()}</p>\n<p>Kind regards,<br/>AnyVision Media Accounting</p>\n`;\n\nreturn [{ json: { ...g, remittance_html: html } }];\n"
      },
      "id": "022d6054-1d37-49df-95b1-fa36b3693d28",
      "name": "Generate Remittance",
      "type": "n8n-nodes-base.code",
      "position": [
        1460,
        200
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.accounting_software || 'none' }}",
                    "rightValue": "quickbooks",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "quickbooks"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.accounting_software || 'none' }}",
                    "rightValue": "xero",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "xero"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
