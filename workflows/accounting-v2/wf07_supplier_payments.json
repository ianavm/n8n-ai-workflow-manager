    {
      "parameters": {
        "jsCode": "const g = $input.first().json;\nconst today = new Date().toISOString();\n\n// Emit one item per bill so downstream Supabase update processes each\nreturn g.bills.map(b => ({\n  json: {\n    id: b.id,\n    updatePayload: {\n      payment_status: 'paid',\n      payment_date: today,\n      updated_at: today,\n    },\n    client_id: g.client_id,\n    supplier_id: g.supplier_id,\n    supplier_name: g.supplier_name,\n    supplier_email: g.supplier_email,\n    remittance_html: g.remittance_html,\n    total: g.total,\n    owner_email: g.owner_email,\n    bill_count: g.bills.length,\n  }\n}));\n"
      },
