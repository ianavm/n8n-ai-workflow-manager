        "jsCode": "const items = $('Group by Supplier').all();\nconst totalPaid = items.reduce((s, i) => s + (i.json.total || 0), 0);\nreturn [{\n  json: {\n    success: true,\n    message: 'Supplier payments processed',\n    suppliers_paid: items.length,\n    total_paid: Math.round(totalPaid * 100) / 100,\n  }\n}];\n"
