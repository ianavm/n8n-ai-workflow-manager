        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst errors = [];\n\nif (!body.legal_name || !body.legal_name.trim()) {\n  errors.push('legal_name is required');\n}\nif (!body.client_id) {\n  errors.push('client_id is required');\n}\n\nif (errors.length > 0) {\n  throw new Error('Validation failed: ' + errors.join(', '));\n}\n\nreturn [{\n  json: {\n    legal_name: body.legal_name.trim(),\n    email: (body.email || '').trim().toLowerCase(),\n    phone: body.phone || null,\n    billing_address: body.billing_address || null,\n    vat_number: body.vat_number || null,\n    payment_terms: body.payment_terms || 'net_30',\n    credit_limit: body.credit_limit || 0,\n    client_id: body.client_id,\n    entity_type: 'customer',\n  }\n}];\n"
