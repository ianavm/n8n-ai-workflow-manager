        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 1500,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"You are AnyVision Media's brand auditor. Analyze all content for brand consistency. Brand guidelines: tone=professional+innovative, terminology='digital growth partner' (not 'agency'), primary color=#FF6D5A, values=innovation+results+transparency. Return JSON: {overall_score: 0-100, content_audited: number, consistent_count: number, inconsistent_items: [{title, issues}], trends: string, recommendations: []}\"},\n    {\"role\": \"user\", \"content\": \"Audit {{ $json.content_count }} pieces of content from the past week:\\n\\n{{ $json.content_list }}\"}\n  ]}",
        "options": {}
