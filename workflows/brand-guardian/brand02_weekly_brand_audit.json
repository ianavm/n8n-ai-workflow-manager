      "position": [
        880,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst raw = (resp.choices && resp.choices[0]) ? resp.choices[0].message.content : '{}';\nlet audit = {};\ntry { audit = JSON.parse(raw.replace(/```json\\n?/g,'').replace(/```\\n?/g,'').trim()); } catch(e) { audit = {overall_score: 0, content_audited: 0, consistent_count: 0, inconsistent_items: [], trends: 'Parse failed', recommendations: ['Manual review needed']}; }\nconst meta = $('Aggregate Content').first().json;\nreturn { json: {\n  overall_score: audit.overall_score || 0,\n  content_audited: audit.content_audited || meta.content_count,\n  consistent_count: audit.consistent_count || 0,\n  inconsistent_items: JSON.stringify(audit.inconsistent_items || []),\n  trends: audit.trends || '',\n  recommendations: (audit.recommendations || []).join('; '),\n  audit_date: meta.audit_date,\n}};"
      },
