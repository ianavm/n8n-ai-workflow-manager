    {
      "id": "db04f8ae-1b3d-4d24-9776-bdc6810bc1ad",
      "name": "AI Pattern Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1180,
        700
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 2000, \"temperature\": 0.3, \"messages\": [{\"role\": \"system\", \"content\": \"You are a sales intelligence analyst for AnyVision Media.\\n\\nAnalyze lead outcome records to identify patterns in successful vs lost leads.\\n\\nAnalyze:\\n1. Which ICP score ranges correlate with wins vs losses?\\n2. Which industries have highest conversion rates?\\n3. Which pain point categories lead to deals most often?\\n4. Which package tiers are most popular?\\n5. What outreach messages got the best response rates?\\n6. Are there any red flags to add to the ICP?\\n7. Are there scoring weight adjustments needed?\\n\\nOutput (JSON only, no markdown fences):\\n{\\\"win_patterns\\\":[\\\"pattern\\\"],\\\"loss_patterns\\\":[\\\"pattern\\\"],\\\"icp_refinements\\\":[{\\\"field\\\":\\\"industry\\\",\\\"suggestion\\\":\\\"Add hospitality\\\",\\\"evidence\\\":\\\"3/5 wins\\\"}],\\\"scoring_adjustments\\\":[{\\\"weight\\\":\\\"pain_indicators\\\",\\\"current\\\":20,\\\"suggested\\\":25,\\\"reasoning\\\":\\\"...\\\"}],\\\"top_performing_industries\\\":[\\\"industry\\\"],\\\"recommended_actions\\\":[\\\"action\\\"],\\\"summary\\\":\\\"executive summary\\\"}\"}, {\"role\": \"user\", \"content\": \"={{ JSON.stringify($input.all().map(i => ({outcome: i.json.outcome || i.json['Outcome'], industry: i.json.industry || '', icp_score: i.json.icp_score_at_contact || i.json['ICP Score At Contact'] || 0, package: i.json.package_sold || i.json['Package Sold'] || '', revenue: i.json.revenue_zar || i.json['Revenue ZAR'] || 0})))}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "475e3ee7-5755-41f7-bc00-1cb39b7aabd7",
      "name": "Parse Learning",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        700
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nlet parsed = {};\ntry {\n  const content = raw.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {win_patterns: [], loss_patterns: [], summary: 'Parse error: ' + e.message};\n}\nreturn {\n  json: {\n    feedback_id: `LEARN-${Date.now().toString(36)}`.toUpperCase(),\n    lead_id: 'SYSTEM',\n    outcome: 'Nurture',\n    learning_insights: JSON.stringify(parsed, null, 2),\n    feedback_notes: parsed.summary || '',\n    recorded_at: new Date().toISOString(),\n    email_subject: 'LinkedIn Lead Intelligence - Monthly Learning Report',\n    email_body: `<div style=\"font-family:Arial;max-width:600px\"><div style=\"background:#FF6D5A;padding:15px\"><h2 style=\"color:white;margin:0\">Monthly Learning Report</h2></div><div style=\"padding:20px\"><h3>Win Patterns</h3><ul>${(parsed.win_patterns||[]).map(p=>'<li>'+p+'</li>').join('')}</ul><h3>Loss Patterns</h3><ul>${(parsed.loss_patterns||[]).map(p=>'<li>'+p+'</li>').join('')}</ul><h3>Recommendations</h3><ul>${(parsed.recommended_actions||[]).map(p=>'<li>'+p+'</li>').join('')}</ul><p><b>Summary:</b> ${parsed.summary||''}</p></div></div>`,\n  }\n};"
      }
    },
