    {
      "id": "255481e6-f2b4-4c9f-bbc1-4bb8abb90092",
      "name": "AI Enrichment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1900,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 1500, \"temperature\": 0.2, \"messages\": [{\"role\": \"system\", \"content\": \"You are a business intelligence analyst for AnyVision Media, an AI automation agency in South Africa.\\n\\nGiven raw HTML content from a company website, extract structured business intelligence.\\n\\nExtract These Fields:\\n1. company_description: 2-3 sentence summary of what the company does\\n2. key_services: array of main services/products offered\\n3. business_model: one of \\\"B2B\\\", \\\"B2C\\\", \\\"B2B2C\\\", \\\"Marketplace\\\", \\\"SaaS\\\", \\\"Agency\\\", \\\"Retail\\\", \\\"Manufacturing\\\", \\\"Services\\\", \\\"Unknown\\\"\\n4. employee_estimate: one of \\\"1-10\\\", \\\"11-50\\\", \\\"51-200\\\", \\\"201-500\\\", \\\"500+\\\"\\n5. tech_stack_hints: array of technologies detected (CMS, analytics, chat widgets, etc.)\\n6. has_blog: boolean\\n7. social_presence: object with boolean for each platform {linkedin, facebook, instagram, twitter, youtube}\\n8. digital_presence_score: 0-100 based on website quality, social links, blog, contact forms\\n9. website_quality_score: 0-100\\n\\nScoring Rubric for digital_presence_score:\\n- Has modern website: +20\\n- Has blog/content: +15\\n- Has 3+ social media links: +15\\n- Has contact form: +10\\n- Has chat widget: +10\\n- Has SSL (https): +10\\n- Has clear service pages: +10\\n- Has testimonials/case studies: +10\\n\\nOutput Format (JSON only, no markdown fences):\\n{\\\"company_description\\\":\\\"...\\\",\\\"key_services\\\":[...],\\\"business_model\\\":\\\"...\\\",\\\"employee_estimate\\\":\\\"...\\\",\\\"tech_stack_hints\\\":[...],\\\"has_blog\\\":true,\\\"social_presence\\\":{\\\"linkedin\\\":true},\\\"digital_presence_score\\\":75,\\\"website_quality_score\\\":60}\"}, {\"role\": \"user\", \"content\": \"={{ JSON.stringify({company_name: $json.company_name, html_snippet: ($json.data || '').substring(0, 3000)})}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "e56ae6dc-eb72-4575-99ce-62c7b170711f",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2140,
        400
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nlet parsed = {};\ntry {\n  const content = raw.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {\n    company_description: '',\n    key_services: [],\n    business_model: 'Unknown',\n    employee_estimate: '',\n    tech_stack_hints: [],\n    has_blog: false,\n    social_presence: {},\n    digital_presence_score: 0,\n    website_quality_score: 0,\n    parse_error: e.message,\n  };\n}\nconst lead = $('Load Lead + Enrichment Data').first().json;\nreturn {\n  json: {\n    ...lead,\n    ...parsed,\n    enrichment_id: `EN-${Date.now().toString(36)}`.toUpperCase(),\n    enriched_at: new Date().toISOString(),\n  }\n};"
      }
    },
