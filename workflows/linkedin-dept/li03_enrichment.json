      "id": "b70dcb6b-4dca-48ea-9173-fcef95c8518e",
      "name": "Load Lead + Enrichment Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        400
      ],
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst company = lead.company_name || '';\nconst query = encodeURIComponent(company + ' official website');\nreturn {\n  json: {\n    ...lead,\n    search_url: `https://www.google.com/search?q=${query}&num=3`,\n  }\n};"
      }
    },
    {
      "id": "bd3597a9-9b2b-46fb-b4e2-715eba34a546",
      "name": "Scrape Website",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1420,
        400
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.company_website || $json.search_url }}",
        "options": {
          "timeout": 30000
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "4585254f-c235-4654-9f99-78176decb8bd",
