    {
      "id": "49b67c05-4fec-4f48-89cb-870e74a97856",
      "name": "Build Scoring Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        400
      ],
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst enrichment = $('Load Enrichment Data').first().json;\nconst config = $('Trigger').first().json;\nconst context = {\n  lead: {\n    full_name: lead.full_name || lead['Full Name'] || '',\n    title: lead.title || lead['Title'] || '',\n    company_name: lead.company_name || lead['Company Name'] || '',\n    industry: lead.industry || lead['Industry'] || '',\n    location: lead.location || lead['Location'] || '',\n    linkedin_url: lead.linkedin_url || lead['LinkedIn URL'] || '',\n    employee_count: lead.employee_count || lead['Employee Count'] || '',\n  },\n  enrichment: {\n    company_description: enrichment.company_description || enrichment['Company Description'] || '',\n    key_services: enrichment.key_services || enrichment['Key Services'] || '',\n    business_model: enrichment.business_model || enrichment['Business Model'] || '',\n    digital_presence_score: enrichment.digital_presence_score || enrichment['Digital Presence Score'] || 0,\n    website_quality_score: enrichment.website_quality_score || enrichment['Website Quality Score'] || 0,\n  },\n  icp_config: {\n    titles: config.icp_titles || [],\n    industries: config.icp_industries || [],\n    company_size: config.icp_company_size || '10-500',\n  },\n};\nreturn {json: {scoring_context: JSON.stringify(context, null, 2), lead_id: lead.lead_id || lead['Lead ID'] || ''}};"
      }
    },
    {
      "id": "aac02b60-9ef7-4df1-81c9-a69eca06d811",
      "name": "AI ICP Score",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1660,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 1500, \"temperature\": 0.2, \"messages\": [{\"role\": \"system\", \"content\": \"You are an ICP (Ideal Customer Profile) scoring specialist for AnyVision Media, an AI workflow automation agency in South Africa.\\n\\nAnyVision Media ICP:\\n- Decision-makers (CEO, COO, CTO, MD, Operations Director, Marketing Director) at SMBs\\n- Company size: 10-500 employees\\n- Industries: Professional services, real estate, e-commerce, healthcare admin, logistics, finance, hospitality, education\\n- Located in South Africa (Johannesburg/Gauteng preferred) or SADC region\\n- Shows signs of manual processes, scaling challenges, or tech adoption interest\\n- NOT: competitors (agencies, dev shops), job seekers, students, enterprise (5000+ employees)\\n\\nScoring Weights:\\n- Decision Maker Role (20%): CEO/MD/COO=20, Director/VP=16, Manager=12, Other=5\\n- Company Size Fit (15%): Sweet spot 20-200 employees=15, 10-20 or 200-500=10, outside=3\\n- Industry Fit (15%): Core industries=15, Adjacent=10, Poor fit=3\\n- Pain Indicators (20%): Strong signals=20, Moderate=12, Weak=5\\n- Automation Potential (20%): High=20, Medium=12, Low=5\\n- Engagement Likelihood (10%): Active LinkedIn presence=10, Moderate=6, Low=2\\n\\nRed Flags (auto-disqualify or reduce score):\\n- Competitor (digital agency, automation company): DISQUALIFY\\n- Job seeker / \\\"Open to Work\\\": DISQUALIFY\\n- Student / intern: DISQUALIFY\\n- Enterprise (>5000 employees): reduce by 50%\\n- No company website: reduce by 20%\\n- Non-South African without SADC presence: reduce by 30%\\n\\nOutput Format (JSON only, no markdown fences):\\n{\\\"total_score\\\":78,\\\"decision_maker_score\\\":16,\\\"company_size_score\\\":15,\\\"industry_score\\\":12,\\\"pain_indicator_score\\\":15,\\\"automation_potential_score\\\":12,\\\"engagement_likelihood_score\\\":8,\\\"confidence\\\":0.82,\\\"priority_band\\\":\\\"High\\\",\\\"red_flags\\\":[],\\\"reasoning\\\":\\\"explanation\\\",\\\"disqualified\\\":false,\\\"disqualify_reason\\\":null}\"}, {\"role\": \"user\", \"content\": \"={{ $json.scoring_context}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "dba068df-1431-4b6d-81bc-76e835e2bcf7",
      "name": "Parse Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1900,
        400
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nlet parsed = {};\ntry {\n  const content = raw.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {total_score: 0, confidence: 0, priority_band: 'Low', red_flags: [], reasoning: 'Parse error: ' + e.message, disqualified: false};\n}\nconst context = $('Build Scoring Context').first().json;\nreturn {\n  json: {\n    score_id: `SC-${Date.now().toString(36)}`.toUpperCase(),\n    lead_id: context.lead_id,\n    score_type: 'ICP',\n    ...parsed,\n    scored_at: new Date().toISOString(),\n  }\n};"
      }
    },
