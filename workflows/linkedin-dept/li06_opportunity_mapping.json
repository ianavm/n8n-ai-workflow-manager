    {
      "id": "edfb7a57-0b5a-4664-91b9-c3a3ded2c5fd",
      "name": "AI Opportunity Mapping",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1420,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 2000, \"temperature\": 0.3, \"messages\": [{\"role\": \"system\", \"content\": \"You are a solutions architect for AnyVision Media, an AI workflow automation agency in South Africa.\\n\\nAnyVision Media Service Packages:\\n- Lite (R1,999/mo): 1 automated workflow, basic chatbot, email automation, monthly reporting\\n- Growth (R4,999/mo): 3 workflows, AI chatbot, CRM integration, social media automation\\n- Pro (R14,999/mo): Unlimited workflows, custom AI agents, full system integration\\n- Enterprise (R29,999/mo): Dedicated AI architect, custom development, white-label\\n\\nAnyVision Media Capabilities:\\n- n8n workflow automation (any business process)\\n- AI chatbots (WhatsApp, website, Telegram)\\n- CRM setup and automation (Airtable, HubSpot)\\n- Document processing (invoices, contracts, compliance)\\n- Email management and classification\\n- Social media automation\\n- Reporting dashboards\\n- Lead generation automation\\n- Accounting automation\\n\\nOutput (JSON only, no markdown fences):\\n{\\\"opportunities\\\":[{\\\"solution_name\\\":\\\"AI Email Triage\\\",\\\"pain_points_addressed\\\":[\\\"Communication_Gaps\\\"],\\\"roi_hypothesis\\\":\\\"Reduce email response time by 60%\\\",\\\"suggested_package\\\":\\\"Growth_R4999\\\",\\\"implementation_complexity\\\":\\\"Moderate\\\",\\\"confidence\\\":0.8}],\\\"recommended_package\\\":\\\"Growth_R4999\\\",\\\"estimated_monthly_value_to_client_zar\\\":12000,\\\"pitch_angle\\\":\\\"hook for this client\\\"}\"}, {\"role\": \"user\", \"content\": \"={{ JSON.stringify({lead: {full_name: $('Loop Over Leads').first().json.full_name || $('Loop Over Leads').first().json['Full Name'], company: $('Loop Over Leads').first().json.company_name || $('Loop Over Leads').first().json['Company Name'], industry: $('Loop Over Leads').first().json.industry || $('Loop Over Leads').first().json['Industry']}, pain_points: $input.all().map(i => ({pain: i.json.pain_point || i.json['Pain Point'], category: i.json.category || i.json['Category'], severity: i.json.severity || i.json['Severity']}))})}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "c4d5a1af-0855-4da9-b433-3d5137fac20a",
      "name": "Parse Opportunities",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        400
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nlet parsed = {opportunities: [], recommended_package: '', pitch_angle: ''};\ntry {\n  const content = raw.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {opportunities: [], recommended_package: 'Growth_R4999', pitch_angle: 'Parse error', estimated_monthly_value_to_client_zar: 0};\n}\nconst lead = $('Loop Over Leads').first().json;\nconst leadId = lead.lead_id || lead['Lead ID'] || '';\nconst results = parsed.opportunities.map((opp, i) => ({\n  json: {\n    opportunity_id: `OPP-${Date.now().toString(36)}-${i}`.toUpperCase(),\n    lead_id: leadId,\n    solution_name: opp.solution_name || '',\n    pain_points_addressed: JSON.stringify(opp.pain_points_addressed || []),\n    roi_hypothesis: opp.roi_hypothesis || '',\n    suggested_package: opp.suggested_package || parsed.recommended_package || '',\n    implementation_complexity: opp.implementation_complexity || 'Moderate',\n    rank: i + 1,\n    confidence: opp.confidence || 0.5,\n    created_at: new Date().toISOString(),\n  }\n}));\nif (results.length === 0) {\n  results.push({json: {lead_id: leadId, solution_name: 'General consultation', created_at: new Date().toISOString()}});\n}\nreturn results;"
      }
    },
