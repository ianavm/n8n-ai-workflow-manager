    {
      "id": "312ebfcc-dc48-4845-a5d7-ebd80aabfd8c",
      "name": "AI Pain Detection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1420,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 2000, \"temperature\": 0.3, \"messages\": [{\"role\": \"system\", \"content\": \"You are a business operations analyst specializing in identifying automation opportunities for South African SMBs.\\n\\nGiven a lead's profile and their company's enrichment data, identify 3-7 likely operational pain points that AnyVision Media's AI automation services could address.\\n\\nPain Point Categories:\\n1. Manual_Processes: Repetitive data entry, manual reporting, paper-based workflows\\n2. Data_Silos: Disconnected systems, manual data transfer between platforms\\n3. Customer_Experience: Slow response times, inconsistent communication, no self-service\\n4. Reporting_Visibility: No real-time dashboards, manual report generation\\n5. Communication_Gaps: Internal miscommunication, missed follow-ups, no CRM\\n6. Scaling_Bottleneck: Processes that don't scale, hiring to solve process problems\\n7. Cost_Inefficiency: Overstaffing for admin tasks, duplicate tool subscriptions\\n\\nOutput (JSON only, no markdown fences):\\n{\\\"pain_points\\\":[{\\\"pain_point\\\":\\\"description\\\",\\\"category\\\":\\\"Manual_Processes\\\",\\\"severity\\\":8,\\\"confidence\\\":0.75,\\\"evidence\\\":\\\"data suggesting this\\\",\\\"automation_category\\\":\\\"workflow_automation\\\"}],\\\"summary\\\":\\\"overall pain assessment\\\"}\"}, {\"role\": \"user\", \"content\": \"={{ JSON.stringify({lead: {full_name: $json.full_name || $json['Full Name'], title: $json.title || $json['Title'], company: $json.company_name || $json['Company Name'], industry: $json.industry || $json['Industry']}, enrichment: {description: $('Load Lead Enrichment').first().json.company_description || '', services: $('Load Lead Enrichment').first().json.key_services || '', model: $('Load Lead Enrichment').first().json.business_model || ''}})}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "ac1c48af-f66c-43b8-85e5-74071c4a709c",
      "name": "Parse Pain Points",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        400
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nlet parsed = {pain_points: [], summary: ''};\ntry {\n  const content = raw.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {pain_points: [], summary: 'Parse error: ' + e.message};\n}\nconst lead = $('Loop Over Leads').first().json;\nconst leadId = lead.lead_id || lead['Lead ID'] || '';\nconst results = parsed.pain_points.map((pp, i) => ({\n  json: {\n    pain_point_id: `PP-${Date.now().toString(36)}-${i}`.toUpperCase(),\n    lead_id: leadId,\n    pain_point: pp.pain_point || '',\n    category: pp.category || 'Manual_Processes',\n    severity: pp.severity || 5,\n    confidence: pp.confidence || 0.5,\n    evidence: pp.evidence || '',\n    automation_category: pp.automation_category || '',\n    detected_at: new Date().toISOString(),\n  }\n}));\nif (results.length === 0) {\n  results.push({json: {lead_id: leadId, pain_point: 'No pain points detected', severity: 0, detected_at: new Date().toISOString()}});\n}\nreturn results;"
      }
    },
