    {
      "parameters": {
        "jsCode": "// Filter for items where admin has filled in an action but status is still open\nconst items = $input.all();\nconst actionable = items.filter(item => {\n  const row = item.json;\n  return row.admin_action\n    && row.admin_action.trim() !== ''\n    && row.status === 'open'\n    && row.admin_email\n    && row.admin_email.trim() !== '';\n});\n\nif (actionable.length === 0) {\n  return [{ json: { _noItems: true, count: 0 } }];\n}\n\nreturn actionable;\n"
      },
      "id": "f2c40e1d-a545-453f-89d6-59226b611423",
      "name": "Filter Actionable",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "leftValue": "={{ $json._noItems }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ]
        }
      },
      "id": "f91edbf9-4e24-4121-a5a6-d2147cb7cc62",
