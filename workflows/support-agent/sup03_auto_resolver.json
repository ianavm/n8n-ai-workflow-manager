      ],
      "typeVersion": 2.2
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Re: {{ $json.subject }} [{{ $json.ticket_id }}]",
        "emailType": "html",
        "message": "={{ $json.resolution.response_html }}",
        "options": {}
      },
      "id": "c1c71188-2231-4a21-8f44-512f853c199a",
