{
  "name": "Support Agent - Auto-Resolver (SUP-03)",
  "nodes": [
    {
      "parameters": {},
      "id": "1849e947-8f5c-4fcb-98e3-a59a55da0525",
      "name": "Execute Workflow Trigger",
