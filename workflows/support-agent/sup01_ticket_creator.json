{
  "name": "Support Agent - Ticket Creator (SUP-01)",
  "nodes": [
    {
      "parameters": {
        "path": "support-ticket",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "0749f21a-4316-4d2b-99f1-0c4357eefd21",
      "name": "Ticket Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        200,
        400
      ],
      "typeVersion": 2,
      "webhookId": "e7df453d-1231-4604-b0f5-e4e9dde145d8"
    },
    {
      "parameters": {
        "jsCode": "// Extract ticket data from webhook body\nconst body = $json.body || $json;\nconst ticket = {\n  email: (body.email || body.client_email || '').toLowerCase().trim(),\n  subject: body.subject || body.title || 'No subject',\n  body: body.body || body.message || body.description || '',\n  client_id: body.client_id || body.clientId || '',\n  source: body.source || 'webhook',\n};\n\nif (!ticket.email) {\n  throw new Error('Client email is required for ticket creation');\n}\n\nreturn { json: { ticket } };"
      },
      "id": "1eb51584-88df-4b47-9bde-e37aff853806",
      "name": "Extract Ticket Data",
      "type": "n8n-nodes-base.code",
      "position": [
        440,
        400
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 800,\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a support ticket classifier for AnyVision Media, a digital media and AI automation agency in South Africa.\\n\\n## Your Task\\nClassify the incoming support ticket: determine priority, department, and suggest a resolution.\\n\\n## Priority Levels\\n- P1: Service down, security breach, data loss - immediate response needed\\n- P2: Major feature broken, billing error, client unable to work - response within 4h\\n- P3: Minor bug, feature request, general question - response within 8h\\n- P4: Nice-to-have, cosmetic issue, documentation - response within 24h\\n\\n## Departments\\n- Accounting: Invoicing, billing, payments, Xero, subscriptions\\n- Marketing: Content, social media, campaigns, analytics\\n- Technical: Workflows, n8n, API errors, integrations, portal issues\\n- General: Other inquiries, feedback, partnerships\\n\\n## Output Format (JSON only, no markdown, no backticks):\\n{\\n  \\\"priority\\\": \\\"P1|P2|P3|P4\\\",\\n  \\\"department\\\": \\\"Accounting|Marketing|Technical|General\\\",\\n  \\\"category\\\": \\\"short category label\\\",\\n  \\\"ai_summary\\\": \\\"1-2 sentence summary of the issue\\\",\\n  \\\"suggested_resolution\\\": \\\"Suggested steps to resolve this issue\\\",\\n  \\\"confidence\\\": 0.85,\\n  \\\"reasoning\\\": \\\"Brief explanation of classification reasoning\\\"\\n}\\n\\n## Rules\\n- Be conservative with P1 - only true emergencies\\n- If unsure between two priorities, choose the higher one\\n- Include confidence score (0.0 to 1.0) reflecting how certain you are\\n- South African business context (ZAR, SAST timezone)\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify('SUBJECT: ' + $json.ticket.subject + '\\n\\nBODY: ' + $json.ticket.body + '\\n\\nCLIENT: ' + $json.ticket.email) }}\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "5af4e7eb-c390-4613-88e3-b3b6d53e2299",
      "name": "AI Classify Ticket",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        680,
        400
      ],
      "typeVersion": 4.2,
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "// Parse AI classification response\nconst input = $input.first().json;\nconst ticketData = $('Extract Ticket Data').first().json.ticket;\n\nlet classification;\ntry {\n  const content = input.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  const jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\n  classification = JSON.parse(jsonMatch ? jsonMatch[0] : cleaned);\n} catch(e) {\n  classification = {\n    priority: 'P3',\n    department: 'General',\n    category: 'unclassified',\n    ai_summary: ticketData.subject,\n    suggested_resolution: 'Manual review required',\n    confidence: 0.0,\n    reasoning: 'Failed to parse AI response'\n  };\n}\n\n// Calculate SLA due time based on priority\nconst slaHours = { P1: 4, P2: 24, P3: 72, P4: 168 };\nconst slaDue = new Date(Date.now() + (slaHours[classification.priority] || 72) * 60 * 60 * 1000);\n\nreturn {\n  json: {\n    ticket: ticketData,\n    classification: classification,\n    sla_due_at: slaDue.toISOString(),\n    can_auto_resolve: classification.confidence > 0.85 && (classification.priority === 'P3' || classification.priority === 'P4'),\n  }\n};"
      },
      "id": "5cd58cc0-276b-4ae5-82cb-92d8624cea27",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "position": [
        920,
        400
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
