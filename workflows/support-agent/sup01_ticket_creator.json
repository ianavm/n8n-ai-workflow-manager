            "Client Email": "={{ $json.ticket.email }}",
            "Client ID": "={{ $json.ticket.client_id }}",
            "Subject": "={{ $json.ticket.subject }}",
            "Body": "={{ $json.ticket.body }}",
            "Department": "={{ $json.classification.department }}",
            "Priority": "={{ $json.classification.priority }}",
            "Status": "Open",
            "Category": "={{ $json.classification.category }}",
            "AI Summary": "={{ $json.classification.ai_summary }}",
            "AI Suggested Resolution": "={{ $json.classification.suggested_resolution }}",
            "SLA Due At": "={{ $json.sla_due_at }}",
