      "parameters": {
        "jsCode": "// Prepare data for SUP-03 Auto-Resolver sub-workflow\nconst ticketData = $('Parse Classification').first().json;\nconst airtableRecord = $('Create Ticket').first().json;\nreturn {\n  json: {\n    ticket_id: airtableRecord.fields ? airtableRecord.fields['Ticket ID'] : 'unknown',\n    record_id: airtableRecord.id || '',\n    email: ticketData.ticket.email,\n    subject: ticketData.ticket.subject,\n    body: ticketData.ticket.body,\n    category: ticketData.classification.category,\n    department: ticketData.classification.department,\n    suggested_resolution: ticketData.classification.suggested_resolution,\n  }\n};"
