        "emailType": "html",
        "message": "=<h2 style=\"color:#FF6D5A;\">SLA Breach Alert</h2>\n<p>{{ $('Check SLA Status').first().json.breached_count }} support tickets have breached their SLA:</p>\n<table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse:collapse;\">\n<tr style=\"background:#FF6D5A;color:white;\"><th>Ticket</th><th>Subject</th><th>Priority</th><th>Hours Over</th></tr>\n{{ $('Check SLA Status').first().json.breached.map(t => '<tr><td>' + t.ticket_id + '</td><td>' + t.subject + '</td><td>' + t.priority + '</td><td>' + Math.abs(t.hours_remaining) + 'h</td></tr>').join('') }}\n</table>",
