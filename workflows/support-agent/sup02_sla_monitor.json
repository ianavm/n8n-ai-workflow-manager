      "parameters": {
        "jsCode": "// Mock SLA config (replace with Airtable read when Support base is set up)\nreturn [\n  { json: { Priority: 'P1', 'Response Time Hours': 1, 'Resolution Time Hours': 4 } },\n  { json: { Priority: 'P2', 'Response Time Hours': 4, 'Resolution Time Hours': 24 } },\n  { json: { Priority: 'P3', 'Response Time Hours': 8, 'Resolution Time Hours': 72 } },\n  { json: { Priority: 'P4', 'Response Time Hours': 24, 'Resolution Time Hours': 168 } },\n];"
      },
      "id": "2e2562cc-bf7b-42af-803f-ef11a63521dd",
      "name": "Read SLA Config",
      "type": "n8n-nodes-base.code",
      "position": [440, 600],
      "typeVersion": 2,
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Calculate SLA status for open tickets\nconst ticketItems = (() => { try { return $(\"Read Open Tickets\").all(); } catch(e) { return []; } })();\nconst slaItems = (() => { try { return $(\"Read SLA Config\").all(); } catch(e) { return []; } })();\n\nconst slaLookup = {};\nfor (const item of slaItems) {\n  const fields = item.json.fields || item.json;\n  const priority = fields['Priority'] || fields.priority || 'P3';\n  slaLookup[priority] = {\n    response_hours: fields['Response Time Hours'] || 4,\n    resolution_hours: fields['Resolution Time Hours'] || 72,\n  };\n}\n\nconst now = new Date();\nconst breached = [];\nconst warning = [];\n\nfor (const item of ticketItems) {\n  const fields = item.json.fields || item.json;\n  const priority = fields['Priority'] || fields.priority || 'P3';\n  const createdAt = new Date(fields['Created At'] || fields.createdTime || now);\n  const hoursElapsed = (now - createdAt) / (1000 * 60 * 60);\n  const sla = slaLookup[priority] || { response_hours: 8, resolution_hours: 72 };\n\n  if (hoursElapsed > sla.resolution_hours) {\n    breached.push({\n      ...fields,\n      sla_status: 'BREACHED',\n      hours_elapsed: Math.round(hoursElapsed * 10) / 10,\n      sla_limit: sla.resolution_hours,\n      overage_hours: Math.round((hoursElapsed - sla.resolution_hours) * 10) / 10,\n    });\n  } else if (hoursElapsed > sla.resolution_hours * 0.8) {\n    warning.push({\n      ...fields,\n      sla_status: 'WARNING',\n      hours_elapsed: Math.round(hoursElapsed * 10) / 10,\n      sla_limit: sla.resolution_hours,\n      hours_remaining: Math.round((sla.resolution_hours - hoursElapsed) * 10) / 10,\n    });\n  }\n}\n\nreturn {\n  json: {\n    total_open: ticketItems.length,\n    breached_count: breached.length,\n    warning_count: warning.length,\n    breached,\n    warning,\n    checked_at: now.toISOString(),\n  }\n};"
      },
      "id": "3036f0cc-2ed9-490a-88c3-1962b8238dc2",
      "name": "Check SLA Status",
      "type": "n8n-nodes-base.code",
      "position": [680, 400],
