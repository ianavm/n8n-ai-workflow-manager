      "id": "1f45d166-0220-4262-8fdf-a6293c830298",
      "name": "Check Decision Log",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        660,
        420
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable PAT"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const suppressions = $('Check Suppression Table').all();\nconst decisions = $('Check Decision Log').all();\nconst scope = $('Set Scan Scope').first().json;\n\nconst suppressionCount = suppressions.length;\nconst suppressionStatuses = {};\nfor (const s of suppressions) {\n  const status = s.json.status || s.json.Status || 'Unknown';\n  suppressionStatuses[status] = (suppressionStatuses[status] || 0) + 1;\n}\n\nconst decisionCount = decisions.length;\nconst unreviewed = decisions.filter(d => !(d.json.reviewed || d.json.status === 'Reviewed')).length;\n\nreturn { json: {\n  scan_id: scope.scan_id,\n  scan_date: scope.scan_date,\n  departments: scope.departments,\n  suppression_count: suppressionCount,\n  suppression_breakdown: JSON.stringify(suppressionStatuses),\n  decision_count: decisionCount,\n  unreviewed_decisions: unreviewed,\n  email_compliance: suppressionCount > 0 ? 'Active' : 'Warning - Empty suppression list',\n  audit_trail: decisionCount > 0 ? 'Active' : 'Warning - No decisions logged',\n}};"
      },
      "id": "cd6a6268-0a57-4af8-a534-0d75a7493be3",
      "name": "Compile Compliance Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 1200,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"You are a compliance auditor for a South African digital marketing company. Assess compliance based on: email suppression (POPIA), audit trail completeness, data handling. Return JSON: {overall_score: 0-100, findings: [{area, status: 'Compliant'|'Non-Compliant'|'Warning', detail, severity: 'Critical'|'High'|'Medium'|'Low'}], recommendations: [], risk_level: 'Low'|'Medium'|'High'|'Critical'}\"},\n    {\"role\": \"user\", \"content\": \"Monthly Compliance Scan {{ $json.scan_id }}\\nDepartments: {{ $json.departments }}\\n\\nEmail Suppression: {{ $json.suppression_count }} entries ({{ $json.suppression_breakdown }})\\nEmail Compliance: {{ $json.email_compliance }}\\nDecision Log: {{ $json.decision_count }} entries, {{ $json.unreviewed_decisions }} unreviewed\\nAudit Trail: {{ $json.audit_trail }}\"}\n  ]}",
        "options": {}
      },
      "id": "bf27ab1f-36e4-49fc-8748-4ab210eeb7a4",
      "name": "AI Compliance Assessment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst raw = (resp.choices && resp.choices[0]) ? resp.choices[0].message.content : '{}';\nlet assessment = {};\ntry { assessment = JSON.parse(raw.replace(/```json\\n?/g,'').replace(/```\\n?/g,'').trim()); } catch(e) { assessment = {overall_score: 0, findings: [], recommendations: ['Parse failed - manual review needed'], risk_level: 'High'}; }\nconst meta = $('Compile Compliance Data').first().json;\nconst nonCompliant = (assessment.findings || []).filter(f => f.status === 'Non-Compliant');\nreturn { json: {\n  scan_id: meta.scan_id,\n  overall_score: assessment.overall_score || 0,\n  findings: JSON.stringify(assessment.findings || []),\n  findings_count: (assessment.findings || []).length,\n  non_compliant_count: nonCompliant.length,\n  recommendations: (assessment.recommendations || []).join('; '),\n  risk_level: assessment.risk_level || 'Unknown',\n  scan_date: meta.scan_date,\n  has_violations: nonCompliant.length > 0,\n}};"
      },
      "id": "e388ed7f-ce1d-43d8-ad4a-690defcb11b5",
      "name": "Parse Assessment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
