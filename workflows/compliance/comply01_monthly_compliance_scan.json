            "recommendations": "={{ $json.recommendations }}",
            "risk_level": "={{ $json.risk_level }}",
            "non_compliant_count": "={{ $json.non_compliant_count }}",
            "status": "={{ $json.has_violations ? 'Action Required' : 'Compliant' }}",
            "scanned_at": "={{ $json.scan_date }}"
