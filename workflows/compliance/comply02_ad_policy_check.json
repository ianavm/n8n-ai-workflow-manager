    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 1500,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"You are an advertising policy compliance checker. Check ads against Google Ads, Meta (Facebook/Instagram), and TikTok advertising policies. Common violations: misleading claims, prohibited content, missing disclaimers, trademark issues, targeting restrictions. Return JSON: {compliant_count: number, violation_count: number, findings: [{ad_title, platform, violation_type, policy_reference, severity: 'Critical'|'High'|'Medium'|'Low', recommendation}], overall_risk: 'Low'|'Medium'|'High'|'Critical'}\"},\n    {\"role\": \"user\", \"content\": \"Check {{ $json.ad_count }} recent ad campaigns for policy compliance:\\n\\n{{ $json.ad_data }}\"}\n  ]}",
        "options": {}
      },
      "id": "1b120005-f9a2-4556-8812-05aa00a32010",
      "name": "AI Policy Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst raw = (resp.choices && resp.choices[0]) ? resp.choices[0].message.content : '{}';\nlet check = {};\ntry { check = JSON.parse(raw.replace(/```json\\n?/g,'').replace(/```\\n?/g,'').trim()); } catch(e) { check = {compliant_count: 0, violation_count: 0, findings: [], overall_risk: 'Unknown'}; }\nconst meta = $('Aggregate Ad Data').first().json;\nreturn { json: {\n  ad_count: meta.ad_count,\n  compliant_count: check.compliant_count || 0,\n  violation_count: check.violation_count || 0,\n  findings: JSON.stringify(check.findings || []),\n  overall_risk: check.overall_risk || 'Unknown',\n  check_date: meta.check_date,\n  has_violations: (check.violation_count || 0) > 0,\n}};"
      },
      "id": "02ada046-fff5-4063-8895-85b31d1ef713",
      "name": "Parse Policy Results",
