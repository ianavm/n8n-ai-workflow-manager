{
  "name": "Intelligence - Prompt Performance Tracker (INTEL-03)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 21 * * *"
            }
          ]
        }
      },
      "id": "964c001f-c232-4727-96ec-c9dd7d9f49cf",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b6ac76e0-73d9-4075-b026-eb181b62fc7e",
              "name": "since",
              "value": "={{ $now.minus({hours: 24}).toISO() }}",
              "type": "string"
            },
            {
              "id": "8261074e-1579-4830-8ef1-c8a68580a0ed",
              "name": "reportDate",
              "value": "={{ $now.format('yyyy-MM-dd') }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "632fedad-7a7f-4021-bbc0-966a3e7f35c5",
      "name": "Set Time Window",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://ianimmelman89.app.n8n.cloud/api/v1/executions",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "limit",
              "value": "200"
            },
            {
              "name": "status",
              "value": ""
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "options": {}
      },
      "id": "26832040-1962-46ca-9d7f-f75c5a3e84a9",
      "name": "Fetch Executions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        640,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "xymp9Nho08mRW2Wz",
          "name": "n8n API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Analyze execution data for prompt performance\nconst executions = ($json.data || []).filter(e => {\n  const startedAt = new Date(e.startedAt || 0);\n  const since = new Date($('Set Time Window').first().json.since);\n  return startedAt >= since;\n});\n\n// Track per-workflow performance\nconst workflowStats = {};\n\nfor (const exec of executions) {\n  const wfId = exec.workflowId || 'unknown';\n  const wfName = exec.workflowName || wfId;\n\n  if (!workflowStats[wfId]) {\n    workflowStats[wfId] = {\n      name: wfName,\n      total: 0,\n      success: 0,\n      failed: 0,\n      totalDuration: 0,\n    };\n  }\n\n  const s = workflowStats[wfId];\n  s.total++;\n  if (exec.status === 'success') {\n    s.success++;\n  } else if (exec.status === 'error' || exec.status === 'crashed') {\n    s.failed++;\n  }\n\n  // Duration\n  if (exec.startedAt && exec.stoppedAt) {\n    const dur = new Date(exec.stoppedAt) - new Date(exec.startedAt);\n    s.totalDuration += dur;\n  }\n}\n\n// Compute stats and find underperformers\nconst results = [];\nconst underperformers = [];\n\nfor (const [wfId, s] of Object.entries(workflowStats)) {\n  const successRate = s.total > 0 ? Math.round((s.success / s.total) * 100 * 10) / 10 : 0;\n  const avgDuration = s.total > 0 ? Math.round(s.totalDuration / s.total / 1000) : 0;\n\n  const entry = {\n    workflowId: wfId,\n    workflowName: s.name,\n    totalExecutions: s.total,\n    successCount: s.success,\n    failedCount: s.failed,\n    successRate,\n    avgDurationSec: avgDuration,\n    reportDate: $('Set Time Window').first().json.reportDate,\n  };\n\n  results.push(entry);\n\n  if (successRate < 60 && s.total >= 3) {\n    underperformers.push(entry);\n  }\n}\n\nreturn [{\n  json: {\n    totalExecutions: executions.length,\n    totalWorkflows: results.length,\n    results,\n    underperformers,\n    hasUnderperformers: underperformers.length > 0,\n    reportDate: $('Set Time Window').first().json.reportDate,\n  }\n}];"
      },
      "id": "e3a8a667-772b-4927-a5a7-1296b8c93a89",
      "name": "Analyze Performance",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Split results into individual items for Airtable write\nconst results = $json.results || [];\nreturn results.map(r => ({ json: r }));"
      },
      "id": "752bf043-5595-42a2-a9ea-a6e753c110ef",
      "name": "Split Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        200
      ]
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "__rl": true,
          "value": "REPLACE_WITH_BASE_ID",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "REPLACE_WITH_TABLE_ID",
          "mode": "id"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Report Date": "={{ $json.reportDate }}",
            "Workflow ID": "={{ $json.workflowId }}",
            "Workflow Name": "={{ $json.workflowName }}",
            "Total Executions": "={{ $json.totalExecutions }}",
            "Success Count": "={{ $json.successCount }}",
            "Failed Count": "={{ $json.failedCount }}",
            "Success Rate": "={{ $json.successRate }}",
            "Avg Duration Sec": "={{ $json.avgDurationSec }}"
          },
          "matchingColumns": []
        },
        "options": {}
      },
      "id": "87dcb535-fe41-4eaa-b341-5f3bdb5a5794",
      "name": "Write Performance Data",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        1300,
        200
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "leftValue": "={{ $('Analyze Performance').first().json.hasUnderperformers }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        }
      },
      "id": "eb9f8ba0-b179-4be8-9565-e25159aa39e8",
      "name": "Has Underperformers?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1080,
        420
      ]
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "__rl": true,
          "value": "REPLACE_WITH_BASE_ID",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "REPLACE_WITH_TABLE_ID",
          "mode": "id"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Title": "=Prompt/Workflow Performance Below 60% - {{ $('Analyze Performance').first().json.reportDate }}",
            "Category": "workflow_failure",
            "Severity": "P3",
            "Description": "={{ $('Analyze Performance').first().json.underperformers.length }} workflow(s) with success rate below 60%. Review prompt configurations and error logs.",
            "Recommended Action": "Review underperforming workflow prompts. Check execution error logs. Consider A/B testing alternative prompts.",
            "Status": "open",
            "Agent ID": "agent_orchestrator"
          },
          "matchingColumns": []
        },
        "options": {}
      },
      "id": "3ec48f22-956f-4f14-ad34-f14e4182db4c",
      "name": "Create Escalation",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        1300,
