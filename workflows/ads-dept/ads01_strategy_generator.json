    {
      "id": "cfbe98d4-86da-41a8-b5c3-c0be24096ef7",
      "name": "Aggregate Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        875,
        300
      ],
      "parameters": {
        "jsCode": "\n// Collect all merged items into structured context\nconst items = $input.all();\nconst research = [];\nconst campaigns = [];\nconst budgets = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (d['Campaign Name'] && (d.Status === 'Active' || d.Status === 'Launched' || d.Status === 'Planned')) {\n    campaigns.push(d);\n  } else if (d['Allocation Name'] || d['Daily Budget ZAR'] !== undefined) {\n    budgets.push(d);\n  } else {\n    research.push(d);\n  }\n}\n\nreturn [{json: {\n  research_insights: research,\n  current_campaigns: campaigns,\n  budget_allocation: budgets,\n  timestamp: new Date().toISOString(),\n}}];\n"
      }
    },
    {
      "id": "3f8ddb5b-63ce-42a1-ba47-48884554de21",
      "name": "AI Strategy Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        300
      ],
      "credentials": {
        "openRouterApi": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openRouterApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4\", \"max_tokens\": 2000, \"temperature\": 0.7, \"messages\": [{\"role\": \"system\", \"content\": \"You are the AVM Campaign Strategist for AnyVision Media, a South African SaaS/AI automation company.\\n\\nBUSINESS CONTEXT:\\n- Company: AnyVision Media (www.anyvisionmedia.com)\\n- Services: AI consulting, workflow automation, web development, social media management\\n- Target: SMBs in South Africa looking to automate and scale\\n- Brand color: #FF6D5A\\n- Currency: ZAR (South African Rand)\\n- Key CTA: \\\"Book a Free AI Strategy Call\\\"\\n\\nORGANIC CONTENT PERFORMANCE (last 7 days):\\n{{JSON.stringify($json)}}\\n\\nCURRENT PAID CAMPAIGNS:\\n{{JSON.stringify($json)}}\\n\\nBUDGET ALLOCATION:\\n{{JSON.stringify($json)}}\\n\\nBUDGET CONSTRAINTS (MANDATORY):\\n- Daily budget per campaign: max R500 (HARD LIMIT \\u2014 never suggest higher)\\n- Weekly total across ALL campaigns: max R2600\\n- Monthly total: max R11000\\n- AVM ONLY runs Google Ads and Meta Ads. Do NOT suggest TikTok, LinkedIn, or other platforms.\\n\\nGenerate 2-3 campaign recommendations as a JSON array. Each item must have:\\n- campaign_name: descriptive name\\n- platform: one of \\\"google_ads\\\", \\\"meta_ads\\\"\\n- objective: one of \\\"Traffic\\\", \\\"Conversions\\\", \\\"Lead_Gen\\\", \\\"Awareness\\\"\\n- target_audience: description of who to target\\n- suggested_daily_budget_zar: number (MUST NOT exceed R500)\\n- ad_format: one of \\\"RSA\\\", \\\"Image\\\", \\\"Video\\\", \\\"Carousel\\\"\\n- key_messages: array of 2-3 messaging angles\\n- duration_days: 7, 14, or 30\\n- priority: \\\"High\\\", \\\"Medium\\\", or \\\"Low\\\"\\n- reasoning: why this campaign should run\\n\\nFocus on SaaS lead generation and client acquisition. Prioritize campaigns with highest expected ROAS.\\n\\nOutput ONLY valid JSON array, no markdown or extra text.\"}, {\"role\": \"user\", \"content\": \"={{JSON.stringify($json)}}\"}]}",
        "options": {
          "timeout": 60000
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 60000,
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "id": "81d245ba-b6cf-472a-8443-5d022c5453f7",
      "name": "Parse Strategy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        300
      ],
      "parameters": {
        "jsCode": "\n// Parse AI strategy response into individual campaign records\nconst aiResp = $('AI Strategy Generator').first().json;\nconst content = aiResp.choices?.[0]?.message?.content || '[]';\n\nlet campaigns;\ntry {\n  // Strip markdown code fences if present\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  campaigns = JSON.parse(cleaned);\n} catch (e) {\n  return [{json: {error: 'Failed to parse AI response', raw: content}}];\n}\n\nif (!Array.isArray(campaigns)) campaigns = [campaigns];\n\nconst now = new Date().toISOString().split('T')[0];\nconst results = [];\n\nfor (const c of campaigns) {\n  results.push({\n    json: {\n      'Campaign Name': c.campaign_name || 'Untitled Campaign',\n      'Platform': c.platform || 'google_ads',\n      'Objective': c.objective || 'Conversions',\n      'Status': 'Planned',\n      'Target Audience': c.target_audience || '',\n      'Daily Budget ZAR': c.suggested_daily_budget_zar || 100,\n      'Lifetime Budget ZAR': (c.suggested_daily_budget_zar || 100) * (c.duration_days || 14),\n      'Key Messages': JSON.stringify(c.key_messages || []),\n      'Priority': c.priority || 'Medium',\n      'Created At': now,\n      'Created By': 'ADS-01',\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{json: {skip: true, reason: 'No campaigns generated'}}];\n"
      }
    },
    {
      "id": "a80bd760-d29d-4bc9-bfac-c7e2e409d55a",
