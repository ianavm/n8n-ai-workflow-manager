      "id": "142fdab5-b2cf-46ce-9a90-e2fdf3532bda",
      "name": "YouTube Search",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        720,
        200
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.googleapis.com/youtube/v3/videos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "part",
              "value": "statistics,snippet,contentDetails"
            },
            {
              "name": "id",
              "value": "={{ $json.items ? $json.items.map(i => i.id.videoId).join(',') : '' }}"
            },
            {
              "name": "key",
              "value": "={{ $('Search Config').first().json.youtubeApiKey }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "8410b682-e829-45ca-8b75-2879ed7e6619",
      "name": "YouTube Stats",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        960,
        200
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "const items = $input.first().json.items || [];\nconst today = new Date().toISOString();\n\nconst results = items\n  .filter(item => {\n    // Filter for Shorts (under 60s)\n    const duration = (item.contentDetails && item.contentDetails.duration) || '';\n    const match = duration.match(/PT(?:(\\d+)M)?(?:(\\d+)S)?/);\n    if (!match) return false;\n    const totalSec = (parseInt(match[1] || '0') * 60) + parseInt(match[2] || '0');\n    return totalSec <= 60;\n  })\n  .map(item => {\n    const stats = item.statistics || {};\n    const views = parseInt(stats.viewCount || '0');\n    const likes = parseInt(stats.likeCount || '0');\n    const comments = parseInt(stats.commentCount || '0');\n    const engRate = views > 0 ? ((likes + comments * 2) / views * 100) : 0;\n\n    return {\n      platform: 'YouTube',\n      sourceUrl: 'https://youtube.com/shorts/' + item.id,\n      sourceCreator: (item.snippet && item.snippet.channelTitle) || 'Unknown',\n      title: (item.snippet && item.snippet.title) || '',\n      viewCount: views,\n      likeCount: likes,\n      commentCount: comments,\n      engagementRate: Math.round(engRate * 100) / 100,\n      discoveredAt: today,\n    };\n  })\n  .sort((a, b) => b.viewCount - a.viewCount)\n  .slice(0, 5);\n\nconst output = results.map(r => ({ json: r }));\nreturn output.length > 0 ? output : [{ json: { _empty: true, platform: 'YouTube', sourceUrl: '' } }];"
      },
      "id": "344d016d-ee04-43bd-965e-e2cfabff688b",
      "name": "Parse YouTube",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
        200
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~instagram-hashtag-scraper/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "={{ $('Search Config').first().json.apifyToken }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"hashtags\": JSON.parse($(\"Search Config\").first().json.instagramHashtags), \"resultsLimit\": 25, \"resultsType\": \"posts\" }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "c7805a85-cac1-4506-8767-70420753a359",
      "name": "Instagram Apify",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        720,
        400
      ],
      "typeVersion": 4.2,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = Array.isArray($input.first().json) ? $input.first().json : ($input.all() || []).map(i => i.json);\nconst today = new Date().toISOString();\n\nconst results = items\n  .filter(item => item.type === 'Video' || item.videoUrl)\n  .map(item => {\n    const views = item.videoViewCount || item.viewCount || 0;\n    const likes = item.likesCount || 0;\n    const comments = item.commentsCount || 0;\n    const engRate = views > 0 ? ((likes + comments * 2) / views * 100) : 0;\n\n    return {\n      platform: 'Instagram',\n      sourceUrl: item.url || item.shortCode ? ('https://instagram.com/reel/' + item.shortCode) : '',\n      sourceCreator: item.ownerUsername || 'Unknown',\n      title: (item.caption || '').slice(0, 200),\n      viewCount: views,\n      likeCount: likes,\n      commentCount: comments,\n      engagementRate: Math.round(engRate * 100) / 100,\n      transcript: item.caption || '',\n      discoveredAt: today,\n    };\n  })\n  .filter(r => r.sourceUrl)\n  .sort((a, b) => b.engagementRate - a.engagementRate)\n  .slice(0, 5);\n\nreturn results.length > 0 ? results.map(r => ({ json: r })) : [{ json: { platform: 'Instagram', _empty: true } }];"
      },
      "id": "e460e141-4774-455b-9235-bda8c9896f37",
      "name": "Parse Instagram",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
