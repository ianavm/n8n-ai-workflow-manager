        "resource": "media",
        "operation": "upload",
        "useBinaryData": false,
        "mediaUrl": "={{ $json.videoUrl }}"
      },
      "id": "994154a3-8385-4cc8-b473-41b338b567f2",
      "name": "Upload to Blotato",
      "type": "@blotato/n8n-nodes-blotato.blotato",
