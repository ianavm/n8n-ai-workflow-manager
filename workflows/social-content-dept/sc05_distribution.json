      "type": "n8n-nodes-base.merge",
      "position": [
        1780,
        400
      ],
      "typeVersion": 3
    },
    {
      "parameters": {
        "jsCode": "const results = $input.all();\nconst source = $('Format for Blotato').first().json;\nconst platforms = results.map(r => {\n  const platform = r.json?.platform || 'Unknown';\n  const success = !r.json?.error;\n  return platform + ': ' + (success ? 'OK' : 'FAILED');\n}).join(', ');\n\nreturn [{\n  json: {\n    recordId: source.recordId,\n    scriptId: source.scriptId,\n    publishResults: platforms,\n  }\n}];"
      },
      "id": "3d004f4e-0d97-48bf-aea6-03ab2c7af92c",
      "name": "Process Results",
      "type": "n8n-nodes-base.code",
      "position": [
        2020,
        400
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "https://api.airtable.com/v0/apptjjBx34z9340tK/tblXGCQ4LTymrU7a1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REDACTED_AIRTABLE_PAT"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  performUpsert: { fieldsToMergeOn: ['Script ID'] },\n  records: [{\n    fields: {\n      'Script ID': $json.scriptId,\n      'Status': 'Published',\n      'Published At': $now.toISO()\n    }\n  }]\n}) }}",
        "options": {
          "timeout": 15000
