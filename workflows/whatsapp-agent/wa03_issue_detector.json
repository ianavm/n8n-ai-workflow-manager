    {
      "parameters": {
        "sendTo": "ian@anyvisionmedia.com",
        "subject": "=[URGENT] WhatsApp Support Ticket - Score {{ $('Scan Urgency').first().json.urgencyScore }}",
        "emailType": "html",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 700px; margin: 0 auto;\">\n<div style=\"background: #dc3545; padding: 20px; text-align: center;\">\n<h1 style=\"color: white; margin: 0;\">Urgent Support Ticket</h1>\n<p style=\"color: white; margin: 5px 0;\">WhatsApp Issue Detected</p>\n</div>\n<div style=\"padding: 20px;\">\n<h2 style=\"color: #333;\">Issue Details</h2>\n<ul>\n<li><strong>Urgency score:</strong> {{ $('Scan Urgency').first().json.urgencyScore }}</li>\n<li><strong>Keywords matched:</strong> {{ $('Scan Urgency').first().json.matchedKeywords.join(', ') }}</li>\n<li><strong>From:</strong> {{ $('Scan Urgency').first().json.from || $('Scan Urgency').first().json.phone || 'Unknown' }}</li>\n</ul>\n<h2 style=\"color: #333;\">Message</h2>\n<div style=\"background: #f9f9f9; padding: 15px; border-radius: 8px;\">{{ $('Scan Urgency').first().json.body || $('Scan Urgency').first().json.message || $('Scan Urgency').first().json.text || 'No message body' }}</div>\n</div>\n<div style=\"background: #f0f0f0; padding: 15px; text-align: center; font-size: 12px; color: #666;\">\nGenerated by AVM WhatsApp Agent | {{ $now.format('yyyy-MM-dd HH:mm') }}\n</div>\n</div>",
        "options": {}
