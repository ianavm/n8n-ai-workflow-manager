{
  "name": "WA-03 Issue Detector",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-issue-detector",
        "options": {}
      },
      "id": "0da76b9c-ea4d-4054-ba91-384daca3e5d4",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        220,
        300
      ],
      "webhookId": "a7670127-b74c-4445-aaae-7ad5a69d3471"
    },
    {
      "parameters": {
        "jsCode": "// Scan incoming message for complaint/urgency keywords and compute urgency score\nconst input = $input.first().json;\nconst text = ((input.body || input.message || input.text || '') + '').toLowerCase();\n\nconst urgencyKeywords = [\n  { word: 'urgent', weight: 0.9 },\n  { word: 'broken', weight: 0.7 },\n  { word: 'refund', weight: 0.8 },\n  { word: 'cancel', weight: 0.8 },\n  { word: 'frustrated', weight: 0.7 },\n  { word: 'help', weight: 0.4 },\n  { word: 'angry', weight: 0.8 },\n  { word: 'deadline', weight: 0.7 },\n  { word: 'asap', weight: 0.9 },\n  { word: 'escalate', weight: 1.0 },\n];\n\nlet totalWeight = 0;\nlet matchedKeywords = [];\nfor (const kw of urgencyKeywords) {\n  if (text.includes(kw.word)) {\n    totalWeight += kw.weight;\n    matchedKeywords.push(kw.word);\n  }\n}\n\n// Normalize to 0-1 range (cap at 1.0)\nconst urgencyScore = Math.min(totalWeight / 2.0, 1.0);\n\nreturn {\n  json: {\n    ...input,\n    urgencyScore: Math.round(urgencyScore * 100) / 100,\n    matchedKeywords,\n    keywordCount: matchedKeywords.length,\n    isUrgent: urgencyScore > 0.7,\n    scannedAt: new Date().toISOString(),\n  }\n};"
      },
      "id": "39dc4e9e-c216-4183-9643-db7cc9426f40",
      "name": "Scan Urgency",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.urgencyScore }}",
              "rightValue": 0.7,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "9275a258-38d1-4848-85da-a0667b15c8cb",
      "name": "If Urgent",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "__rl": true,
          "value": "appzcZpiIZ6QPtJXT",
          "mode": "id"
        },
