            "Sentiment Score": "={{ $json.urgencyScore * -1 }}",
            "AI Analysis": "=URGENT TICKET: Keywords={{ $json.matchedKeywords.join(', ') }} | Score={{ $json.urgencyScore }} | From={{ $json.from || $json.phone || 'unknown' }}",
            "Has Critical Issues": "=true",
            "Analyzed At": "={{ $now.toISO() }}"
          }
        },
        "options": {}
      },
