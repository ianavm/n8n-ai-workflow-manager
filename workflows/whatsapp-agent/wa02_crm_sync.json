    {
      "parameters": {
        "jsCode": "// Log sync statistics\nconst items = $('Update Contact Status').all();\nlet matched = 0;\nlet orphan = 0;\nlet errors = 0;\n\nfor (const item of items) {\n  const status = item.json.syncStatus || 'unknown';\n  if (status === 'matched') matched++;\n  else if (status === 'orphan') orphan++;\n  else errors++;\n}\n\nreturn {\n  json: {\n    syncedAt: new Date().toISOString(),\n    totalContacts: items.length,\n    matched,\n    orphan,\n    errors,\n    summary: `Synced ${items.length} contacts: ${matched} matched, ${orphan} orphan, ${errors} errors`,\n  }\n};"
      },
      "id": "7cb7622b-f3e6-4f61-939f-d6ebf3d7ae49",
