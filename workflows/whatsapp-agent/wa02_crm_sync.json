      "id": "17f33391-db57-4ca9-bc50-2cad1bbf2e10",
      "name": "Fetch Supabase Clients",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        520
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Match WhatsApp contacts against Supabase clients via HTTP response\nconst contacts = $('Read WhatsApp Contacts').all();\nconst supabaseData = $('Fetch Supabase Clients').first().json;\n\nconst clients = Array.isArray(supabaseData) ? supabaseData : (supabaseData.data || []);\nconst clientMap = {};\nfor (const c of clients) {\n  if (c.phone) clientMap[c.phone.replace(/\\D/g, '')] = c;\n  if (c.email) clientMap[c.email.toLowerCase()] = c;\n}\n\nconst results = [];\nfor (const item of contacts) {\n  const d = item.json;\n  const phone = (d.Phone || d.phone || '').replace(/\\D/g, '');\n  const email = (d.Email || d.email || '').toLowerCase();\n  const match = clientMap[phone] || clientMap[email] || null;\n\n  results.push({\n    json: {\n      contactId: d.id || d['Record ID'] || d.airtable_id,\n      phone: d.Phone || d.phone,\n      name: d.Name || d.name,\n      email: d.Email || d.email,\n      supabaseMatch: !!match,\n      supabaseClientId: match ? match.id : null,\n      supabaseStatus: match ? (match.status || 'active') : null,\n    }\n  });\n}\n\nif (results.length === 0) {\n  results.push({ json: { message: 'No contacts to sync', matchCount: 0 } });\n}\n\nreturn results;"
      },
      "id": "c6c005cd-80f6-4533-b24f-e318b403913a",
      "name": "Match Supabase Clients",
