      "id": "e769e5d0-9d73-4ebf-86f6-95baf7fe3424",
      "name": "Search SEO Leads",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        720,
        520
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable PAT"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Match contacts against SEO Leads Airtable search results\nconst contacts = $('Match Supabase Clients').all();\nconst seoLeads = $('Search SEO Leads').all();\n\nconst leadMap = {};\nfor (const item of seoLeads) {\n  const d = item.json;\n  const phone = (d.Phone || d.phone || '').replace(/\\D/g, '');\n  const email = (d.Email || d.email || '').toLowerCase();\n  if (phone) leadMap[phone] = d;\n  if (email) leadMap[email] = d;\n}\n\nlet matchCount = 0;\nlet supabaseMatchCount = 0;\nlet seoMatchCount = 0;\n\nconst results = [];\nfor (const item of contacts) {\n  const d = item.json;\n  const phone = (d.phone || '').replace(/\\D/g, '');\n  const email = (d.email || '').toLowerCase();\n  const seoMatch = leadMap[phone] || leadMap[email] || null;\n\n  if (d.supabaseMatch) supabaseMatchCount++;\n  if (seoMatch) seoMatchCount++;\n  if (d.supabaseMatch || seoMatch) matchCount++;\n\n  results.push({\n    json: {\n      ...d,\n      seoLeadMatch: !!seoMatch,\n      seoLeadStatus: seoMatch ? (seoMatch.Status || seoMatch.status) : null,\n      syncStatus: d.supabaseMatch || seoMatch ? 'matched' : 'orphan',\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "7bf73791-4eee-4cd9-a61f-2be31dc6fdf0",
      "name": "Match SEO Leads",
      "type": "n8n-nodes-base.code",
