    {
      "parameters": {
        "method": "GET",
        "url": "=https://example.supabase.co/rest/v1/clients?select=id,phone,email,name,status&limit=1000",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
