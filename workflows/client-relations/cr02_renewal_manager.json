      "id": "3879f839-9859-42b6-84cc-318c173219c4",
      "name": "Fetch Subscriptions",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        680,
        400
      ],
      "typeVersion": 4.2,
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000
