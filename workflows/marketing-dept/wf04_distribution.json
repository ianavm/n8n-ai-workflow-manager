    {
      "parameters": {
        "jsCode": "const now = new Date().toLocaleString('en-ZA', { timeZone: 'Africa/Johannesburg' });\nlet totalPublished = 0;\nlet totalFailed = 0;\n\ntry {\n  const items = $('Process Results').all();\n  if (items.length > 0) {\n    // All items now have the same final totals, so read from first item\n    totalPublished = items[0].json._successCount || 0;\n    totalFailed = items[0].json._failCount || 0;\n  }\n} catch(e) {\n  // No process results — queue was empty\n}\n\nreturn {\n  json: {\n    subject: `Marketing Distribution: ${totalPublished} posts published`,\n    body: [\n      '<h2>Daily Distribution Report</h2>',\n      `<p><strong>Date:</strong> ${now}</p>`,\n      '<hr>',\n      `<p><strong>Successful Posts:</strong> ${totalPublished}</p>`,\n      `<p><strong>Failed Posts:</strong> ${totalFailed}</p>`,\n      '<hr>',\n      '<p>Check your Airtable Distribution Log for per-platform details.</p>',\n    ].join('\\n')\n  }\n};"
      },
