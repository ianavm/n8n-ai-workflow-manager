      "parameters": {
        "jsCode": "const content = $input.first().json;\nconst queueItem = $('Loop Over Queue').item.json;\n\n// Build the post text from content fields\nconst postText = content.Body || content.Title || 'Check out our latest update!';\n\nreturn {\n  json: {\n    postText: postText,\n    contentId: content.id || '',\n    queueId: queueItem.id || '',\n    calendarId: content['Calendar Entry ID'] || '',\n    title: content.Title || '',\n    platform: content.Platform || 'all',\n    contentID_field: queueItem['Content ID'] || ''\n  }\n};"
      },
