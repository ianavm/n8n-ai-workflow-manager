    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst paymentAmount = data.amount;\nconst balanceDue = data.matchedBalanceDue;\n\nlet status, newBalance, newAmountPaid, invoiceStatus;\n\nif (Math.abs(paymentAmount - balanceDue) < 0.50) {\n  status = 'exact';\n  newBalance = 0;\n  newAmountPaid = data.matchedInvoiceTotal;\n  invoiceStatus = 'Paid';\n} else if (paymentAmount < balanceDue) {\n  status = 'partial';\n  newBalance = Math.round((balanceDue - paymentAmount) * 100) / 100;\n  newAmountPaid = Math.round((data.matchedInvoiceTotal - newBalance) * 100) / 100;\n  invoiceStatus = 'Partial';\n} else {\n  status = 'overpayment';\n  newBalance = 0;\n  newAmountPaid = data.matchedInvoiceTotal;\n  invoiceStatus = 'Paid';\n}\n\nreturn {\n  json: {\n    ...data,\n    paymentType: status,\n    newBalanceDue: newBalance,\n    newAmountPaid: newAmountPaid,\n    overpaymentAmount: status === 'overpayment' ? Math.round((paymentAmount - balanceDue) * 100) / 100 : 0,\n    invoiceStatus: invoiceStatus,\n  }\n};"
      },
      "id": "ee361f7b-9661-4a4a-b104-2501dd1558d3",
      "name": "Handle Partial/Over",
      "type": "n8n-nodes-base.code",
