      "id": "9ccdc99b-433f-413a-a51c-d18edefc514d",
      "name": "Lookup Products",
      "type": "n8n-nodes-base.airtable",
      "position": [
        2520,
        500
      ],
      "typeVersion": 2.1,
      "alwaysOutputData": true,
