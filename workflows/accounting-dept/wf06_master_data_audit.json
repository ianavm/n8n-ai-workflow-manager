      "parameters": {
        "jsCode": "return {\n  json: {\n    body: {\n      action: 'create',\n      'Customer ID': 'CUST-TEST-' + Date.now(),\n      'Legal Name': 'Test Company (Pty) Ltd',\n      'Trading Name': 'Test Co',\n      'Email': 'test@example.com',\n      'Phone': '+27 11 555 0100',\n      'Billing Address': '123 Test Street, Sandton, 2196',\n      'VAT Number': '4000000000',\n      'Default Payment Terms': '30 days',\n      'Credit Limit': 50000,\n      'Risk Flag': 'Low',\n      'Preferred Channel': 'Email',\n      'Active': true,\n      'Created At': new Date().toISOString().split('T')[0],\n      'Updated At': new Date().toISOString().split('T')[0]\n    }\n  }\n};"
      },
      "id": "6d10a33a-8a91-41a4-8027-2bf1f1cf679b",
      "name": "Sample Customer Data",
      "type": "n8n-nodes-base.code",
      "position": [
        440,
        1300
      ],
      "typeVersion": 2
