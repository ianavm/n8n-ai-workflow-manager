    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst config = {};\n\nfor (const item of items) {\n  const key = item.json.Key || item.json['Key'];\n  const value = item.json.Value || item.json['Value'];\n  if (key && value) {\n    try {\n      config[key] = JSON.parse(value);\n    } catch(e) {\n      config[key] = value;\n    }\n  }\n}\n\nreturn {\n  json: {\n    configCount: Object.keys(config).length,\n    config: config,\n    vatRate: config.vat_standard_rate ? config.vat_standard_rate.rate : 0.15,\n    currency: config.default_currency ? config.default_currency.code : 'ZAR',\n    approvalThreshold: config.approval_threshold ? config.approval_threshold.auto_approve_below : 10000,\n    highValueThreshold: config.high_value_invoice_threshold ? config.high_value_invoice_threshold.threshold : 50000,\n    invoicePrefix: config.invoice_prefix ? config.invoice_prefix.prefix : 'AVM',\n    nextInvoiceNumber: config.invoice_prefix ? config.invoice_prefix.next_number : 1001,\n    cachedAt: new Date().toISOString()\n  }\n};"
      },
