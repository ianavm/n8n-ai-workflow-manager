    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Document type -> Google Drive folder ID mapping\n// These are populated at deploy time from config/env\nconst FOLDER_MAP = {\n  \"FICA\": \"REPLACE\",\n  \"Offer_to_Purchase\": \"REPLACE\",\n  \"Mandate\": \"REPLACE\",\n  \"Title_Deed\": \"REPLACE\",\n  \"Municipal\": \"REPLACE\",\n  \"Bond_Finance\": \"REPLACE\",\n  \"Compliance_Cert\": \"REPLACE\",\n  \"Sectional_Scheme\": \"REPLACE\",\n  \"Entity_Docs\": \"REPLACE\",\n  \"Other\": \"REPLACE\"\n};\n\nconst DEFAULT_FOLDER = FOLDER_MAP['Other'] || 'REPLACE_AFTER_SETUP';\n\nreturn items.map(item => {\n  const docType = item.json.document_type || 'Other';\n  const folderId = FOLDER_MAP[docType] || DEFAULT_FOLDER;\n\n  return {\n    json: {\n      ...item.json,\n      target_folder_id: folderId,\n      target_folder_name: docType\n    }\n  };\n});"
      },
