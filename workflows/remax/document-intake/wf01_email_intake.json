          "value": "Document_Log",
          "mode": "name"
        },
        "options": {}
      },
      "id": "ad3ac659-1cca-427e-bc8a-b763fd90bbe5",
      "name": "Read Document Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1140,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "OkpDXxwI8WcUJp4P",
          "name": "Google Sheets AVM Tutorial"
        }
      },
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Check if the file hash already exists in Document_Log\nconst currentItem = $('Generate Hash + ID').first().json;\nconst fileHash = currentItem.fileHash;\nconst existingDocs = $input.all().map(i => i.json);\n\nconst duplicate = existingDocs.find(doc =>\n  doc.file_hash_sha256 === fileHash && doc.file_hash_sha256 !== 'no_binary'\n);\n\nreturn [{\n  json: {\n    ...currentItem,\n    isDuplicate: !!duplicate,\n    duplicateOfDocId: duplicate ? duplicate.doc_id : null,\n  },\n  binary: $('Generate Hash + ID').first().binary,\n}];\n"
      },
      "id": "dc341af1-9f8f-46f9-8189-746190b308dd",
      "name": "Check Duplicate",
      "type": "n8n-nodes-base.code",
