{
  "name": "Document Intake - Email Intake & Raw Storage (WF-DI-01)",
  "nodes": [
    {
      "parameters": {
        "content": "## WF-DI-01: Email Intake + Raw Storage\nMonitors Outlook for emails with attachments.\nDownloads, deduplicates, uploads to Google Drive,\nand triggers WF-DI-02 for processing.",
        "width": 500,
        "height": 140,
        "color": 4
      },
      "id": "3330235b-6734-4353-8013-8ba3c40db096",
      "name": "Note - Overview",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        180,
        80
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "hasAttachments": true
        },
        "options": {
          "downloadAttachments": true
        }
      },
      "id": "32ac6fb8-ab0e-4ff3-9654-9334162bae09",
      "name": "Outlook Trigger",
      "type": "n8n-nodes-base.microsoftOutlookTrigger",
      "typeVersion": 1,
      "position": [
        220,
        300
      ],
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK",
          "name": "Microsoft Outlook OAuth2"
        }
      }
    },
    {
      "parameters": {},
      "id": "3b44d5f8-7283-49b2-805e-544a74e2fe98",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        220,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract email metadata and split into one item per attachment\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const email = item.json;\n  const senderEmail = email.sender?.emailAddress?.address\n    || email.from?.emailAddress?.address || 'unknown';\n  const senderName = email.sender?.emailAddress?.name\n    || email.from?.emailAddress?.name || '';\n  const subject = email.subject || '(no subject)';\n  const receivedAt = email.receivedDateTime || email.createdDateTime || new Date().toISOString();\n  const messageId = email.id || '';\n\n  // Get all binary keys (attachments downloaded by trigger)\n  const binaryKeys = item.binary ? Object.keys(item.binary) : [];\n\n  if (binaryKeys.length === 0) {\n    // No binary attachments - skip\n    continue;\n  }\n\n  for (const binaryKey of binaryKeys) {\n    const binaryData = item.binary[binaryKey];\n    const fileName = binaryData.fileName || `attachment_${Date.now()}`;\n    const mimeType = binaryData.mimeType || 'application/octet-stream';\n    const fileSize = binaryData.fileSize || 0;\n\n    results.push({\n      json: {\n        senderEmail,\n        senderName,\n        subject,\n        receivedAt,\n        messageId,\n        fileName,\n        mimeType,\n        fileSize,\n        binaryKey,\n        intakeTimestamp: new Date().toISOString(),\n      },\n      binary: {\n        data: binaryData,\n      },\n    });\n  }\n}\n\nif (results.length === 0) {\n  results.push({ json: { _noAttachments: true } });\n}\n\nreturn results;\n"
      },
      "id": "6c481733-838e-4e92-bb09-75dea5b9f216",
      "name": "Split Attachments",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "leftValue": "={{ $json._noAttachments }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ]
        }
      },
      "id": "985cf105-c7b8-4e77-a483-25e53ece2bf9",
      "name": "Has Attachments?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const binaryData = item.binary?.data;\n  let fileHash = 'no_binary';\n\n  if (binaryData && binaryData.data) {\n    // binaryData.data is base64 encoded\n    const buffer = Buffer.from(binaryData.data, 'base64');\n    fileHash = crypto.createHash('sha256').update(buffer).digest('hex');\n  }\n\n  const random4 = Math.random().toString(36).slice(2, 6);\n  const docId = `DOC-${Date.now()}-${random4}`;\n\n  results.push({\n    json: {\n      ...item.json,\n      docId,\n      fileHash,\n    },\n    binary: item.binary,\n  });\n}\n\nreturn results;\n"
      },
      "id": "33aeacb6-b386-40eb-b7cd-d8a63efa5818",
      "name": "Generate Hash + ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        300
      ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "REPLACE_WITH_SHEETS_ID",
          "mode": "id"
        },
