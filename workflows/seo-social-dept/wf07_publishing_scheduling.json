      "parameters": {
        "jsCode": "const content = $input.first().json;\nconst queueItem = $('Loop Over Queue').item.json;\nconst postText = content.Body || content.Title || 'Check out our latest update!';\nreturn {\n  json: {\n    postText: postText,\n    contentId: content.id || queueItem['Content ID'],\n    queueId: queueItem.id,\n    calendarId: content['Calendar Entry ID'] || '',\n    title: content.Title || '',\n    platform: content.Platform || 'all'\n  }\n};"
      },
