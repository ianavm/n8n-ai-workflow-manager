      "parameters": {
        "jsCode": "const now = new Date().toLocaleString('en-ZA', { timeZone: 'Africa/Johannesburg' });\nlet totalPublished = 0, totalFailed = 0;\ntry { const items = $('Process Results').all(); for (const item of items) { totalPublished += item.json._successCount || 0; totalFailed += item.json._failCount || 0; } } catch(e) {}\nreturn { json: {\n  subject: `SEO Social Distribution: ${totalPublished} posts published`,\n  body: ['<h2 style=\"color:#FF6D5A\">Daily Publishing Report</h2>', `<p><strong>Date:</strong> ${now}</p>`, '<hr>', `<p><strong>Successful:</strong> ${totalPublished}</p>`, `<p><strong>Failed:</strong> ${totalFailed}</p>`, '<p>Check Distribution Log for details.</p>'].join('\\n')\n}};"
      },
