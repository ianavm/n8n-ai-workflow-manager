      ]
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "appTCh0EeXQp0XqzW",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "tblLo3smPaM19XXkv",
          "mode": "id"
        },
        "filterByFormula": "=AND(OR({Company} = '', {Phone} = ''), NOT({Sync Status} = 'Merged - Duplicate'))",
        "options": {
          "limit": 50
        }
      },
      "id": "bbe8912b-d246-4b42-9fb8-f2bc5a967902",
      "name": "Read Needing Enrichment",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        440,
        300
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable PAT"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "leftValue": "={{ $json.id ? 1 : 0 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        }
      },
      "id": "58a6a344-78b1-459e-9b7e-7eb5e844b496",
      "name": "Records Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract email domain for Tavily search\nconst records = $input.all().map(i => i.json);\nconst enrichable = [];\n\nfor (const rec of records) {\n  const email = (rec.Email || '').toLowerCase().trim();\n  if (!email.includes('@')) continue;\n  const domain = email.split('@')[1];\n  // Skip common free email providers\n  const freeProviders = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'icloud.com', 'aol.com'];\n  if (freeProviders.includes(domain)) {\n    enrichable.push({\n      id: rec.id,\n      email,\n      name: rec.Name || '',\n      domain: null,\n      searchQuery: (rec.Name || '') + ' company',\n    });\n  } else {\n    enrichable.push({\n      id: rec.id,\n      email,\n      name: rec.Name || '',\n      domain,\n      searchQuery: domain + ' company',\n    });\n  }\n}\n\nreturn enrichable.map(r => ({ json: r }));"
      },
      "id": "e0b94994-db6e-45d8-814f-f96214bd44a4",
      "name": "Extract Email Domain",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        200
      ]
    },
    {
      "parameters": {
        "url": "https://api.tavily.com/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": \"{{ $json.searchQuery }}\",\n  \"search_depth\": \"basic\",\n  \"max_results\": 3,\n  \"include_answer\": true\n}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "bd748080-6b54-4056-bed7-5fbbd629c5d0",
      "name": "Enrich via Tavily",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        200
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Extract company profile from search results. Return JSON: {company: string, industry: string, size: string, location: string}. Use empty string for unknown fields. Be concise.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Person: \" + $('Extract Email Domain').item.json.name + \"\\nEmail domain: \" + ($('Extract Email Domain').item.json.domain || 'unknown') + \"\\nSearch results: \" + JSON.stringify($json.answer || $json.results || 'No results')\n    }\n  ]\n}}",
        "options": {}
      },
      "id": "e1ac652d-a5c9-4ddf-912b-ee72a102f202",
      "name": "AI Extract Profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parse AI response and prepare update\nconst aiResponse = $json.choices ? $json.choices[0].message.content : '{}';\nlet profile;\ntry {\n  const jsonMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  profile = jsonMatch ? JSON.parse(jsonMatch[0]) : {};\n} catch (e) {\n  profile = {};\n}\n\nconst recordId = $('Extract Email Domain').item.json.id;\nconst email = $('Extract Email Domain').item.json.email;\n\nreturn [{ json: {\n  recordId,\n  email,\n  company: profile.company || '',\n  industry: profile.industry || '',\n  location: profile.location || '',\n  enriched: !!(profile.company || profile.industry),\n} }];"
      },
      "id": "fc26123a-85b9-45e1-8bed-3913a18d0d7f",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        200
      ]
    },
