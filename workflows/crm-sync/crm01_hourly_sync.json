    {
      "parameters": {
        "url": "https://api.xero.com/api.xro/2.0/Contacts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xero-tenant-id",
              "value": "1f5c5e97-8976-4e03-b33c-ba638a7aeb72"
