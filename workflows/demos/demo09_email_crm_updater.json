    {
      "id": "dceb9d7f-6114-4821-8a2e-7383a54eaaa9",
      "name": "Build Extract Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const msg = $input.first().json;\nconst prompt = `You are a CRM data extractor. Read the email below and extract\nthe sender's structured details. Return STRICT JSON ONLY (no prose, no markdown\nfences), with these keys:\n\n  {\n    \"name\": \"...\",\n    \"company\": \"...\",\n    \"email\": \"...\",\n    \"phone\": \"...|null\",\n    \"ask\": \"one-sentence summary of what they want\",\n    \"budgetZAR\": \"string or null, preserve their wording e.g. 'R20-40k/mo'\",\n    \"availability\": \"string or null, e.g. 'Tue/Thu after 2pm'\",\n    \"leadScore\": 1-10,\n    \"shouldAcknowledge\": true|false,\n    \"acknowledgementBody\": \"<p>...</p>\" (HTML, 3 short sentences, sign off as Ian)\n  }\n\nRules:\n- If you cannot confidently identify a field, use null (never invent data).\n- shouldAcknowledge = false only if the email is clearly spam or an auto-\n  responder bounce.\n- leadScore rubric: 10 = ready-to-buy with budget + timeline; 5 = curious;\n  1 = unrelated/noise.\n\nEmail:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...msg, prompt } }];\n"
      }
    },
    {
      "id": "a0e29acd-303e-466e-9d24-8cc2300f8173",
      "name": "AI Extract CRM Fields",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 900, temperature: 0.2, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "6ef4469a-a509-4f5c-aff0-08dc4f96d411",
      "name": "Parse Extracted Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const msg = $('Build Extract Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\n\nfunction deriveEmail(from) {\n  const m = String(from).match(/<([^>]+)>/);\n  return m ? m[1] : (String(from).includes('@') ? String(from).trim() : '');\n}\n\nconst emailAddr = parsed.email || deriveEmail(msg.from) || '';\nconst safeName = parsed.name || String(msg.from).split('<')[0].replace(/\"/g, '').trim() || 'Unknown';\n\nreturn [{\n  json: {\n    ...msg,\n    clientId: `CLT-${Date.now()}-${Math.floor(Math.random() * 1000)}`,\n    name: safeName,\n    company: parsed.company || '',\n    email: emailAddr,\n    phone: parsed.phone || '',\n    ask: parsed.ask || msg.subject || '',\n    budgetZAR: parsed.budgetZAR || '',\n    availability: parsed.availability || '',\n    leadScore: Number(parsed.leadScore) || 3,\n    shouldAcknowledge: parsed.shouldAcknowledge !== false && !!emailAddr,\n    acknowledgementBody: parsed.acknowledgementBody || `<p>Thanks for reaching out — I will come back to you within one business day.</p><p>Ian</p>`,\n  }\n}];"
      }
    },
