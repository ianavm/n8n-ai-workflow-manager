    {
      "id": "0d863d9e-0ffb-4329-a0b8-f0c5a43ebcee",
      "name": "Normalise Gmail Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst raw = $json;\nconst headers = raw.payload?.headers || [];\nconst h = (n) => headers.find(x => x.name?.toLowerCase() === n.toLowerCase())?.value || '';\nreturn [{\n  json: {\n    threadId: raw.threadId || raw.id,\n    messageId: raw.id,\n    from: h('From') || raw.from || 'unknown',\n    subject: h('Subject') || raw.subject || '(no subject)',\n    body: raw.snippet || raw.textPlain || raw.body || '',\n    date: h('Date') || new Date().toISOString(),\n    runId: cfg.runId,\n  }\n}];"
      }
    },
    {
      "id": "62eeb936-64b8-4505-881b-9d410c1bc14c",
      "name": "Merge Email Sources",
      "type": "n8n-nodes-base.merge",
