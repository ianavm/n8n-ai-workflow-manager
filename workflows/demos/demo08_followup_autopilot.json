      "onError": "continueRegularOutput"
    },
    {
      "id": "2c45b405-ef82-41e2-97a8-81cf358da4fd",
      "name": "Filter Due Rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst today = new Date().toISOString().slice(0, 10);\nconst due = rows.filter(r => (r.Status || '').toLowerCase() === 'due'\n  && (r.Scheduled_For || '') <= today);\n\n// If there are no due rows AND we are in demo mode, inject fixture seeds\n// so the workflow always has something to show on camera.\nconst cfg = $('Demo Config').first().json;\nif (due.length === 0 && String(cfg.demoMode) === '1') {\n  const seeds = [{'Follow_Up_ID': 'FU-DEMO-001', 'Related_Record': 'Q-2026-0123', 'Contact': 'naledi@bluehorizon.co.za', 'Scheduled_For': '2026-04-19', 'Type': 'check-in', 'Status': 'due', 'Last_Action': 'intro-call-2026-04-12', 'Notes': 'Asked about automation for client onboarding. Decided nothing yet.'}, {'Follow_Up_ID': 'FU-DEMO-002', 'Related_Record': 'LEAD-88', 'Contact': 'pieter@karoocraft.co.za', 'Scheduled_For': '2026-04-20', 'Type': 'quote-followup', 'Status': 'due', 'Last_Action': 'quote-sent-2026-04-17', 'Notes': 'Sent freight quote R82k. No response in 3 days.'}];\n  return JSON.parse(JSON.stringify(seeds)).map(s => ({ json: { ...s, _seeded: true } }));\n}\nreturn due.map(r => ({ json: r }));\n"
      }
    },
    {
      "id": "9a9a156a-15ab-4e07-b919-7bae62726188",
      "name": "Build Per-Row Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const r = $json;\nconst prompt = `You are Ian Immelman, founder of AnyVision Media, writing a\npersonalised re-engagement email based on the follow-up record below.\n\nRules:\n- 3 short sentences. No filler, no emoji, no \"just checking in\".\n- Reference the specific last_action / notes so it reads human.\n- End with a concrete next step (a specific time slot, a link, or a\n  \"reply yes and I'll send the proposal\").\n- STRICT JSON OUTPUT ONLY, no markdown:\n    { \"subject\": \"...\", \"bodyHtml\": \"<p>...</p>\" }\n\nRecord:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...r, prompt } }];\n"
      }
    },
    {
      "id": "229ae520-f826-4ed0-b79b-34c2a8778191",
      "name": "AI Personalise Follow-Up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1300,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 500, temperature: 0.5, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "6c42d1cf-4364-45b0-93c0-a88b3716e6a6",
      "name": "Parse Follow-Up",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const src = $('Build Per-Row Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\nreturn [{\n  json: {\n    ...src,\n    subject: parsed.subject || `Quick follow-up on ${src.Related_Record || 'our last chat'}`,\n    bodyHtml: parsed.bodyHtml || `<p>Hi, just circling back on the ${src.Type || 'follow-up'} from ${src.Last_Action || 'earlier'}. Let me know if helpful.</p><p>Ian</p>`,\n  }\n}];"
      }
    },
    {
      "id": "f3c3d7aa-a8df-4eba-980b-29dd04a768f5",
      "name": "Send Follow-Up Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        1740,
        300
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "2IuycrTIgWJZEjBE",
          "name": "Gmail account AVM Tutorial"
        }
      },
      "parameters": {
        "sendTo": "={{ $json.Contact }}",
        "subject": "={{ $json.subject }}",
        "emailType": "html",
        "message": "={{ $json.bodyHtml }}",
        "options": {
          "appendAttribution": false
        }
      }
    },
    {
      "id": "28ea4fff-f826-4f48-bd88-17c9d5cc07f0",
      "name": "Mark Row Sent",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
