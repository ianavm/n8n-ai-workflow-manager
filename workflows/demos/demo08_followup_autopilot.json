    {
      "id": "bbb7404d-9c0b-45bf-97c0-4321d053d046",
      "name": "Aggregate Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const all = $input.all().map(i => i.json);\nconst runId = $('Demo Config').first().json.runId;\nconst slackText = all.length === 0\n  ? `_No follow-ups due today (run ${runId})._`\n  : `*Follow-up autopilot* sent ${all.length} personalised emails:\\n` +\n    all.map(r => `- ${r.Contact} (${r.Type || 'follow-up'})`).join('\\n');\nreturn [{\n  json: {\n    runId,\n    processed: all.length,\n    contacts: all.map(r => r.Contact),\n    slackText,\n  }\n}];"
      }
    },
    {
      "id": "8f665e29-c5de-4ad7-ae03-817a9d3b3fa2",
      "name": "Slack Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2440,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Demo Config').first().json.slackWebhook || 'https://hooks.slack.com/services/DISABLED' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: $json.slackText }) }}",
        "options": {
          "timeout": 10000
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "1bc5f082-85ce-407d-b519-2a4a5faf2453",
      "name": "Audit Log",
      "type": "n8n-nodes-base.googleSheets",
