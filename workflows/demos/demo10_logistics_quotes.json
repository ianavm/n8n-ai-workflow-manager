{
  "name": "DEMO-10 Logistics Quote Request Handler",
  "nodes": [
    {
      "id": "99b72836-7f59-496c-a3ef-88607119078f",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        300
      ],
      "webhookId": "demo10-logistics-quote",
      "parameters": {
        "httpMethod": "POST",
        "path": "demo10-logistics-quote",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "46ae38ee-944b-4b7f-8eb0-ca410a6d40cc",
      "name": "Demo Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        420,
        300
      ],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "bfe0b35d-9875-491b-a1f2-6124c0954a0c",
              "name": "demoMode",
              "type": "string",
              "value": "={{ String($json.demoMode ?? '1') }}"
            },
            {
              "id": "fb12eef3-f867-4517-a589-487d9542c104",
              "name": "runId",
              "type": "string",
              "value": "={{ 'RUN-' + $now.toFormat('yyyyLLdd-HHmmss') }}"
            },
            {
              "id": "983976c8-4072-4fcf-ace0-4f23b181a4fb",
              "name": "sheetId",
              "type": "string",
              "value": "={{ $env.DEMO_SHEET_VOL2_ID || 'REPLACE_WITH_SHEET_ID' }}"
            },
            {
              "id": "ee926144-8c9d-452b-81ed-d6de9f52ef05",
              "name": "slackWebhook",
              "type": "string",
              "value": "={{ $env.SLACK_DEMO_WEBHOOK_URL || '' }}"
            },
            {
              "id": "3c355d17-cb54-46d4-a998-ca623ae827b7",
              "name": "fixtureData",
              "type": "string",
              "value": "{\"company\": \"Karoo Craft Beverages\", \"contactName\": \"Pieter de Villiers\", \"contactEmail\": \"pieter@karoocraft.co.za\", \"contactPhone\": \"+27 82 555 0132\", \"origin\": \"Port Elizabeth, EC\", \"destination\": \"Midrand, GP\", \"weightKg\": 4200, \"palletCount\": 6, \"cargoType\": \"Ambient beverages (glass bottles)\", \"pickupDate\": \"2026-04-25\", \"notes\": \"Prefer arrival before 08:00 on 25 April. Forklift on site both ends.\"}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "b99d476e-ab7d-4c60-b21e-61cb4ae8c4b0",
      "name": "DEMO_MODE Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "demo"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "0",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "live"
            }
          ]
        },
        "options": {
          "fallbackOutput": 0
        }
      }
    },
    {
      "id": "019fc0e6-720d-438e-9768-f2b98b3971bf",
      "name": "Load Fixture Quote",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst q = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...q, runId: cfg.runId, source: 'fixture' } }];\n"
      }
    },
    {
      "id": "d24aafd5-c72d-43ed-98b7-584f0a130fba",
      "name": "Normalise Quote Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nreturn [{\n  json: {\n    company: body.company || '',\n    contactName: body.contactName || body.name || '',\n    contactEmail: body.contactEmail || body.email || '',\n    contactPhone: body.contactPhone || body.phone || '',\n    origin: body.origin || '',\n    destination: body.destination || '',\n    weightKg: Number(body.weightKg || body.weight_kg || 0),\n    palletCount: Number(body.palletCount || body.pallet_count || 1),\n    cargoType: body.cargoType || body.cargo_type || 'general',\n    pickupDate: body.pickupDate || body.pickup_date || '',\n    notes: body.notes || '',\n    runId: cfg.runId,\n    source: 'webhook',\n  }\n}];"
      }
    },
    {
      "id": "5f9c1902-7674-4a0d-9ed5-e901f8401638",
      "name": "Merge Quote Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    },
    {
      "id": "53532aca-ff80-464d-978e-fa764302a2ff",
      "name": "Build Quote Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const q = $input.first().json;\nconst prompt = `You are a freight-quoting assistant for AnyVision Logistics\n(demo company, South African 3PL). Produce a realistic-looking quote for the\ninbound request. Output STRICT JSON ONLY (no markdown fences):\n\n  {\n    \"estimateZAR\": <integer, total incl. VAT>,\n    \"transitDays\": <integer>,\n    \"pricingRationale\": \"1-sentence, shows the calc: distance, weight, pallet fuel levy\",\n    \"quoteHtml\": \"<HTML email body, ~150 words, warm but professional, includes estimate, ETA, next step>\",\n    \"subjectLine\": \"Quote #... -  {origin} -> {destination}\",\n    \"quoteId\": \"Q-2026-XXXX\"\n  }\n\nPricing heuristics (use these as a starting point, then write the rationale):\n  - Base: R18/km per pallet for ambient\n  - Chilled / hazmat / glass -> +20%\n  - Fuel levy: R0.60/km/pallet\n  - Overnight / before-08:00 surcharge: R1 200\n  - VAT 15% on top\n  - Distance reference lanes:\n      PE -> Midrand ~= 1 100 km\n      Cape Town -> Joburg ~= 1 400 km\n      Durban -> Joburg ~= 600 km\n\nRequest:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...q, prompt } }];\n"
      }
    },
    {
      "id": "a7737705-2fe7-4b77-935f-9d34d892dc54",
      "name": "AI Draft Quote",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 1000, temperature: 0.4, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "4d0dee55-43d3-46b9-ad06-63b8226e1ac4",
      "name": "Parse Quote",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const q = $('Build Quote Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\n\n// Safe fallback if AI fails — rough calc so the demo still produces numbers.\nconst baseKm = 1100;\nconst perPallet = 18 * baseKm + 0.60 * baseKm;\nconst subtotal = perPallet * (q.palletCount || 1);\nconst fallbackEstimate = Math.round(subtotal * 1.15);\n\nreturn [{\n  json: {\n    ...q,\n    quoteId: parsed.quoteId || `Q-2026-${Math.floor(Math.random() * 9000 + 1000)}`,\n    estimateZAR: Number(parsed.estimateZAR) || fallbackEstimate,\n    transitDays: Number(parsed.transitDays) || 2,\n    pricingRationale: parsed.pricingRationale || `Estimated from ~${baseKm}km at standard pallet rate`,\n    quoteHtml: parsed.quoteHtml || `<p>Hi ${q.contactName},</p><p>Thanks for the request. Preliminary estimate for ${q.origin} -> ${q.destination}: <b>R${fallbackEstimate.toLocaleString()}</b> (excl. any special handling). I will confirm firm pricing within 2 hours once we lock the lane.</p><p>Ian</p>`,\n    subjectLine: parsed.subjectLine || `Quote ${parsed.quoteId || 'Q-2026'} - ${q.origin} -> ${q.destination}`,\n  }\n}];"
      }
    },
    {
      "id": "b2d0cf55-1847-4bd2-80ac-fb56a02add0c",
      "name": "Send Quote Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        1960,
        200
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "2IuycrTIgWJZEjBE",
          "name": "Gmail account AVM Tutorial"
        }
      },
      "parameters": {
        "sendTo": "={{ $json.contactEmail }}",
        "subject": "={{ $json.subjectLine }}",
        "emailType": "html",
        "message": "={{ $json.quoteHtml }}",
        "options": {
          "appendAttribution": false
        }
      }
    },
    {
      "id": "376e3411-044e-4071-9618-ceeaf2bb50dc",
      "name": "Log Quote",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        2200,
        200
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "OkpDXxwI8WcUJp4P",
          "name": "Google Sheets AVM Tutorial"
        }
      },
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Demo Config').first().json.sheetId }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Quotes_Log"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Quote_ID": "={{ $json.quoteId }}",
            "Company": "={{ $json.company }}",
            "Origin": "={{ $json.origin }}",
            "Destination": "={{ $json.destination }}",
            "Weight_Kg": "={{ $json.weightKg }}",
            "Pallets": "={{ $json.palletCount }}",
            "Estimate_ZAR": "={{ $json.estimateZAR }}",
            "Sent_At": "={{ new Date().toISOString() }}",
            "Status": "'sent'",
            "Contact_Email": "={{ $json.contactEmail }}"
          },
          "schema": []
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "f59a6074-a9b9-461b-b7fe-b883fbcbda89",
      "name": "Create 72h Follow-Up",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        2200,
        420
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "OkpDXxwI8WcUJp4P",
          "name": "Google Sheets AVM Tutorial"
        }
      },
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Demo Config').first().json.sheetId }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Follow_Ups"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Follow_Up_ID": "={{ 'FU-' + $json.quoteId }}",
            "Related_Record": "={{ $json.quoteId }}",
            "Contact": "={{ $json.contactEmail }}",
            "Scheduled_For": "={{ new Date(Date.now() + 1000*60*60*72).toISOString().slice(0, 10) }}",
            "Type": "'quote-followup'",
            "Status": "'due'",
            "Last_Action": "'quote-sent'",
            "Notes": "={{ 'Check in on ' + $json.company + ' quote R' + $json.estimateZAR }}"
          },
          "schema": []
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "7a1907f0-3568-40eb-a092-92ad8af72fa5",
      "name": "Audit Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        2680,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "OkpDXxwI8WcUJp4P",
          "name": "Google Sheets AVM Tutorial"
        }
      },
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Demo Config').first().json.sheetId }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Audit_Log"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Workflow": "'DEMO-10'",
            "Run_ID": "={{ $('Demo Config').first().json.runId }}",
            "Timestamp": "={{ new Date().toISOString() }}",
            "Action": "={{ 'run_complete' }}",
            "Status": "={{ 'ok' }}",
            "Error_Message": "={{ '' }}"
          },
          "schema": []
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "c9e43ab6-6030-42fa-b7ce-d0475658e0ff",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
