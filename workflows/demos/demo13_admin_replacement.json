            },
            {
              "id": "2de47aef-027a-4fbe-aa6e-c358cd386fcf",
              "name": "fixtureData",
              "type": "string",
              "value": "{\"name\": \"Sibusiso Ndlovu\", \"email\": \"sbu@nextgen-installs.co.za\", \"company\": \"NextGen Installs\", \"phone\": \"+27 82 555 0177\", \"source\": \"google-ad\", \"message\": \"We're a 25-person solar installer in KZN. Tired of chasing service quotes and booking follow-ups manually. Looking for a system that automates lead replies + admin. Aiming to pick a partner in the next 2 weeks. Budget around R15k/mo.\"}"
            },
            {
              "id": "666513ed-8e70-4c7b-aecb-c940722441c0",
              "name": "brand",
              "type": "string",
              "value": "AnyVision Media - Johannesburg AI automation agency for SA SMEs. Founder: Ian Immelman. Typical package R5k-R15k/mo."
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "e4f77075-bf1d-4c81-be3b-ea5359c61d2d",
      "name": "DEMO_MODE Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "demo"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "0",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "live"
            }
          ]
        },
        "options": {
          "fallbackOutput": 0
        }
      }
    },
    {
      "id": "97c202c3-df94-4683-9abc-3c2e7bea43aa",
      "name": "Load Fixture Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...l, runId: cfg.runId, source: l.source || 'fixture' } }];"
      }
    },
    {
      "id": "e5727c0f-5b63-4ad4-b2da-4a98d865d67d",
      "name": "Normalise Live Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nreturn [{\n  json: {\n    name: body.name || 'there',\n    email: body.email || '',\n    company: body.company || '',\n    phone: body.phone || '',\n    source: body.source || 'webhook',\n    message: body.message || '',\n    runId: cfg.runId,\n  }\n}];"
      }
    },
    {
      "id": "0fb85ecd-f8bc-4c82-9415-6709ffbc1775",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    },
    {
      "id": "bdfb49e9-d0a4-4966-9abe-71c6ab32ae20",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = $input.first().json;\nconst prompt = `You are the sales operator for ${cfg.brand}.\n\nFor the lead below, do three things. Output STRICT JSON (no fences):\n{\n  \"intent\": \"hot|question|generic|spam\",\n  \"urgency\": \"low|medium|high\",\n  \"industry\": \"short label\",\n  \"leadScore\": 1-10,\n  \"subjectLine\": \"...\",\n  \"replyHtml\": \"<p>3-sentence personalised reply, sign as Ian, offer a 20-min slot</p>\",\n  \"slackSummary\": \"one punchy slack line with name, company, ask, score\"\n}\n\nLead:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...l, prompt } }];\n"
      }
    },
    {
      "id": "98a53da7-bce2-41fe-b25b-4b94a70b6aaa",
      "name": "AI Classify + Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 900, temperature: 0.4, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "1b87aa98-861b-480e-9fc6-698dcacc3781",
      "name": "Parse Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const src = $('Build Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\nreturn [{\n  json: {\n    ...src,\n    clientId: `CLT-${Date.now()}-${Math.floor(Math.random() * 1000)}`,\n    intent: (parsed.intent || 'generic').toLowerCase(),\n    urgency: (parsed.urgency || 'low').toLowerCase(),\n    industry: parsed.industry || '',\n    leadScore: Number(parsed.leadScore) || 5,\n    subjectLine: parsed.subjectLine || `Re: ${src.company || src.name}`,\n    replyHtml: parsed.replyHtml || `<p>Thanks — will follow up within one business day.</p><p>Ian</p>`,\n    slackSummary: parsed.slackSummary || `New lead: ${src.name} (${src.company || '-'})`,\n  }\n}];"
      }
    },
