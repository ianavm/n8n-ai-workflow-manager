    {
      "id": "2545140f-e8b2-45f9-9cd8-874faa4b28ee",
      "name": "DEMO_MODE Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "demo"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "0",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "live"
            }
          ]
        },
        "options": {
          "fallbackOutput": 0
        }
      }
    },
    {
      "id": "a9488818-2c07-473f-84c7-a9d1906f92bc",
      "name": "Load Fixture Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...l, runId: cfg.runId, source: l.source || 'fixture' } }];"
      }
    },
    {
      "id": "4db562f9-cdf6-43ad-a868-1a9311284438",
      "name": "Normalise Live Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nreturn [{\n  json: {\n    name: body.name || 'there',\n    email: body.email || '',\n    company: body.company || '',\n    phone: body.phone || '',\n    source: body.source || 'webhook',\n    message: body.message || '',\n    runId: cfg.runId,\n  }\n}];"
      }
    },
    {
      "id": "40358465-bba6-43af-80b7-e50596262622",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    },
    {
      "id": "dd13981e-b548-4161-aeac-2a4bab27e5e8",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = $input.first().json;\nconst prompt = `You are the sales operator for ${cfg.brand}.\n\nFor the lead below, do three things. Output STRICT JSON (no fences):\n{\n  \"intent\": \"hot|question|generic|spam\",\n  \"urgency\": \"low|medium|high\",\n  \"industry\": \"short label\",\n  \"leadScore\": 1-10,\n  \"subjectLine\": \"...\",\n  \"replyHtml\": \"<p>3-sentence personalised reply, sign as Ian, offer a 20-min slot</p>\",\n  \"slackSummary\": \"one punchy slack line with name, company, ask, score\"\n}\n\nLead:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...l, prompt } }];\n"
      }
    },
    {
      "id": "372602b8-46db-4a36-8472-57e7f0df019e",
      "name": "AI Classify + Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 900, temperature: 0.4, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "b95d50dc-8f98-47fe-8878-87a80b346ad4",
      "name": "Parse Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const src = $('Build Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\nreturn [{\n  json: {\n    ...src,\n    clientId: `CLT-${Date.now()}-${Math.floor(Math.random() * 1000)}`,\n    intent: (parsed.intent || 'generic').toLowerCase(),\n    urgency: (parsed.urgency || 'low').toLowerCase(),\n    industry: parsed.industry || '',\n    leadScore: Number(parsed.leadScore) || 5,\n    subjectLine: parsed.subjectLine || `Re: ${src.company || src.name}`,\n    replyHtml: parsed.replyHtml || `<p>Thanks — will follow up within one business day.</p><p>Ian</p>`,\n    slackSummary: parsed.slackSummary || `New lead: ${src.name} (${src.company || '-'})`,\n  }\n}];"
      }
    },
