    {
      "parameters": {
        "jsCode": "// Parse order extraction response\nconst aiResponse = $input.first().json;\nconst upstream = $('Route by Type').first().json;\n\nlet order;\ntry {\n  const content = aiResponse.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  order = JSON.parse(cleaned);\n} catch (e) {\n  order = { product: 'Unknown', quantity: 1, urgency: 'normal', special_instructions: '', estimated_value_zar: 0 };\n}\n\nreturn [{\n  json: {\n    ...upstream,\n    ...order,\n    order_status: 'New',\n    created_at: new Date().toISOString()\n  }\n}];"
      },
