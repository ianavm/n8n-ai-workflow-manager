                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "complaint"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Complaints"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
