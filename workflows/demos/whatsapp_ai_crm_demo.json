      "id": "d1a00001-0002-4000-8000-000000000002",
      "name": "Extract Message Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        460,
        380
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a message classifier for a business. Classify the incoming WhatsApp message into exactly ONE category. Respond with ONLY a JSON object, no other text.\\n\\nCategories:\\n- order: Customer wants to place an order, buy something, or request a product/service\\n- lead: New contact expressing interest, asking about pricing, or requesting a quote\\n- inquiry: General question about business hours, policies, availability, or existing order status\\n- complaint: Customer expressing dissatisfaction, reporting a problem, or requesting a refund\\n\\nRespond with: {\\\"category\\\": \\\"<category>\\\", \\\"confidence\\\": <0.0-1.0>, \\\"summary\\\": \\\"<one-line summary>\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Message from {{ $json.sender_name }} ({{ $json.phone }}):\\n{{ $json.message }}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "d1a00001-0003-4000-8000-000000000003",
      "name": "Classify with AI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        380
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_OPENROUTER_CRED_ID",
          "name": "OpenRouter API"
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI classification response\nconst aiResponse = $input.first().json;\nconst upstream = $('Extract Message Fields').first().json;\n\nlet parsed;\ntry {\n  const content = aiResponse.choices[0].message.content;\n  // Handle both raw JSON and markdown-wrapped JSON\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = { category: 'inquiry', confidence: 0.5, summary: 'Could not parse AI response' };\n}\n\nreturn [{\n  json: {\n    ...upstream,\n    category: parsed.category || 'inquiry',\n    confidence: parsed.confidence || 0.5,\n    summary: parsed.summary || '',\n    classified_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "d1a00001-0004-4000-8000-000000000004",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        380
      ]
    },
    {
      "parameters": {
