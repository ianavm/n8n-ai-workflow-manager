        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 400,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a lead qualification assistant. Score this lead from 1-10 based on their WhatsApp message. Consider: intent clarity, budget signals, decision-making authority, timeline urgency, and fit with a digital marketing agency.\\n\\nRespond with ONLY a JSON object:\\n{\\\"score\\\": <1-10>, \\\"reasoning\\\": \\\"<brief reasoning>\\\", \\\"interest_area\\\": \\\"<what service they want>\\\", \\\"next_action\\\": \\\"<recommended follow-up>\\\", \\\"priority\\\": \\\"hot|warm|cold\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Lead message from {{ $json.sender_name }} ({{ $json.phone }}):\\n{{ $json.message }}\"\n    }\n  ]\n}",
