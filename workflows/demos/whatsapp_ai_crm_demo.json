    {
      "parameters": {
        "jsCode": "// Parse lead qualification response\nconst aiResponse = $input.first().json;\nconst upstream = $('Route by Type').first().json;\n\nlet lead;\ntry {\n  const content = aiResponse.choices[0].message.content;\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  lead = JSON.parse(cleaned);\n} catch (e) {\n  lead = { score: 5, reasoning: 'Could not parse', interest_area: 'General', next_action: 'Follow up', priority: 'warm' };\n}\n\nreturn [{\n  json: {\n    ...upstream,\n    lead_score: lead.score || 5,\n    reasoning: lead.reasoning || '',\n    interest_area: lead.interest_area || 'General',\n    next_action: lead.next_action || 'Follow up',\n    priority: lead.priority || 'warm',\n    qualified_at: new Date().toISOString()\n  }\n}];"
