        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Extract order details from this WhatsApp message. Respond with ONLY a JSON object:\\n{\\\"product\\\": \\\"<what they want>\\\", \\\"quantity\\\": <number or 1>, \\\"urgency\\\": \\\"normal|urgent\\\", \\\"special_instructions\\\": \\\"<any notes>\\\", \\\"estimated_value_zar\\\": <estimated rand value or 0>}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Order message from {{ $json.sender_name }}:\\n{{ $json.message }}\"\n    }\n  ]\n}",
        "options": {
