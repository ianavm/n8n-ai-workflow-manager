      "name": "Live Path Placeholder",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1780,
        480
      ],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
