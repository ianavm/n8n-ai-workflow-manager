    {
      "id": "48da5e3b-20f5-4c67-a5ed-09c7a94b7235",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        370
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all().map(i => i.json);\n\n// Winner = highest score24h, tiebreak on engagementRate.\nconst sorted = [...items].sort((a, b) => {\n  const s = (b.score24h || 0) - (a.score24h || 0);\n  return s !== 0 ? s : (b.engagementRate || 0) - (a.engagementRate || 0);\n});\n\nconst winner = sorted[0] || null;\nreturn [{\n  json: {\n    experimentId: items[0]?.experimentId,\n    idea: items[0]?.idea,\n    totalVariations: items.length,\n    winner,\n    allVariations: sorted,\n    timestamp: new Date().toISOString(),\n  }\n}];"
      }
    },
    {
      "id": "011cc3f1-7c11-4110-94b1-c33da6d3bff9",
      "name": "AI Explain Winner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2460,
        370
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-haiku-4-5', max_tokens: 400, temperature: 0.4, messages: [{role: 'user', content: 'Given this winning hook variation, write a 2-sentence rationale explaining WHY it is likely to outperform the alternatives. Be concrete about the psychology. Output plain text, no markdown.\\n\\nWinner: ' + JSON.stringify($json.winner) + '\\n\\nAll variations (for context): ' + JSON.stringify($json.allVariations.slice(0,10))}] }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "fa471e5b-aadb-4909-bae5-5b5e306cac26",
      "name": "Finalize Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2680,
        370
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const agg = $('Aggregate Results').first().json;\nconst aiResp = $input.first().json || {};\n\nlet rationale = '';\ntry {\n  rationale = aiResp.choices && aiResp.choices[0] && aiResp.choices[0].message\n    ? aiResp.choices[0].message.content.trim()\n    : '';\n} catch (e) { rationale = ''; }\nif (!rationale) rationale = 'Winner selected by highest synthetic engagement score.';\n\nreturn [{\n  json: {\n    experimentId: agg.experimentId,\n    idea: agg.idea,\n    winner: agg.winner,\n    winnerRationale: rationale,\n    topThree: (agg.allVariations || []).slice(0, 3),\n    totalVariations: agg.totalVariations,\n    timestamp: agg.timestamp,\n    status: 'complete',\n  }\n}];"
      }
    },
