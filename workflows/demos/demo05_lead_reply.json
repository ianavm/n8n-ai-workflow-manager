              "id": "03c3c989-c29f-4cfe-b0ab-9d40e875ae2f",
              "name": "brand",
              "type": "string",
              "value": "AnyVision Media — Johannesburg AI automation agency for SA SMEs. Typical package R5k-R15k/mo. Founder: Ian Immelman."
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "fa6a1db1-b2ac-43f3-a4cf-f557c9e5d04f",
      "name": "DEMO_MODE Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "demo"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "0",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "live"
            }
          ]
        },
        "options": {
          "fallbackOutput": 0
        }
      }
    },
    {
      "id": "f53e1d48-0465-43b3-8e56-9739ef44fac4",
      "name": "Load Fixture Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst lead = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...lead, runId: cfg.runId, source: lead.source || 'fixture' } }];\n"
      }
    },
    {
      "id": "74aad251-4d23-41ef-a590-ea6e2aa3b8cb",
      "name": "Normalise Live Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nreturn [{\n  json: {\n    name: body.name || 'there',\n    email: body.email || '',\n    company: body.company || '',\n    phone: body.phone || '',\n    source: body.source || 'webhook',\n    message: body.message || '',\n    runId: cfg.runId,\n  }\n}];"
      }
    },
    {
      "id": "ebe2735f-c0b0-4be1-847f-7f89e1df13cf",
      "name": "Merge Lead Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    },
    {
      "id": "958ff7db-8477-4e37-b7b4-70d07b396632",
      "name": "Build Classification Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst lead = $input.first().json;\nconst prompt = `You are the lead-qualifier for ${cfg.brand}.\n\nClassify the inbound lead on two axes:\n  1. intent: one of [hot, question, spam, generic]\n     - hot       = explicit buying signal, demo request, budget or timeline\n     - question  = curious, asking general info, objection, comparison\n     - spam      = bot/random/crypto/unrelated\n     - generic   = fan message, compliment, no ask\n  2. urgency: low | medium | high\n\nFor intent = hot OR question, draft a short personalised reply (3 short\nsentences, HTML allowed, no preamble). Sign off as Ian.\nFor spam or generic, suggestedReply = null.\n\nReturn STRICT JSON (no prose, no markdown fences):\n{{\n  \"intent\": \"...\",\n  \"urgency\": \"...\",\n  \"reasoning\": \"one sentence\",\n  \"suggestedReply\": \"...\" | null,\n  \"subjectLine\": \"...\"\n}}\n\nBrand: ${cfg.brand}\nLead:\n  Name: ${lead.name}\n  Email: ${lead.email}\n  Company: ${lead.company}\n  Source: ${lead.source}\n  Message: ${lead.message}\n`;\nreturn [{ json: { ...lead, prompt } }];\n"
      }
    },
    {
      "id": "6310346c-1daa-443d-a44f-0ce9e55fefd3",
      "name": "AI Classify & Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 700, temperature: 0.4, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "075347ab-4e77-456e-ae16-0563f8f712c5",
      "name": "Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const lead = $('Build Classification Prompt').first().json;\nconst resp = $input.first().json || {};\nlet raw = '';\ntry { raw = resp.choices?.[0]?.message?.content || ''; } catch (e) { raw = ''; }\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) { parsed = {}; }\nconst intent = (parsed.intent || '').toLowerCase() || 'generic';\nreturn [{\n  json: {\n    ...lead,\n    intent,\n    urgency: (parsed.urgency || 'low').toLowerCase(),\n    reasoning: parsed.reasoning || 'ai-fallback',\n    suggestedReply: parsed.suggestedReply || null,\n    subjectLine: parsed.subjectLine || `Re: ${lead.company || 'your enquiry'}`,\n    shouldReply: ['hot', 'question'].includes(intent),\n  }\n}];"
      }
    },
    {
      "id": "7a5f30ac-230d-45bc-bc7d-7da1e8d07b52",
      "name": "Intent Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        1960,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.shouldReply }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ]
              },
              "outputKey": "reply"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.shouldReply }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "false"
                    }
                  }
                ]
              },
              "outputKey": "noReply"
            }
          ]
        },
        "options": {
          "fallbackOutput": 1
        }
      }
    },
