      "position": [
        1080,
        260
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst fx = JSON.parse(cfg.fixtureCreators || '[]');\nreturn fx.map(c => ({ json: { ...c, campaignId: cfg.campaignId, source: 'fixture' } }));"
