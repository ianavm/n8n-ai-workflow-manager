    {
      "id": "85ba7e45-2228-4ccf-b88a-2674769765e3",
      "name": "Apify TikTok Scrape",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1080,
        500
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/clockworks~tiktok-scraper/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "={{ $env.APIFY_API_TOKEN || 'MISSING' }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ hashtags: ($('Demo Config').first().json.niche || '').split(',').map(s => s.trim()).filter(Boolean), resultsPerPage: 20 }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "8a2325e5-e5e8-4c9e-a64c-2df288224ad1",
      "name": "Normalise Apify Creators",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        500
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst items = $input.all();\nconst out = [];\nconst seen = new Set();\nfor (const item of items) {\n  const rows = Array.isArray(item.json) ? item.json : [item.json];\n  for (const r of rows) {\n    const author = r.authorMeta || r.author || {};\n    const handle = author.name ? '@' + author.name : null;\n    if (!handle || seen.has(handle)) continue;\n    seen.add(handle);\n    out.push({\n      json: {\n        handle,\n        platform: 'tiktok',\n        followers: author.fans || 0,\n        niche: cfg.niche,\n        avgViews: r.playCount || 0,\n        engagementRate: r.playCount ? ((r.diggCount || 0) + (r.commentCount || 0)) / r.playCount * 100 : 0,\n        samplePost: r.text || '',\n        email: author.email || '',\n        rateCard: 0,\n        campaignId: cfg.campaignId,\n        source: 'apify',\n      }\n    });\n  }\n}\nreturn out.length ? out : [{ json: { _empty: true, campaignId: cfg.campaignId } }];"
      }
    },
    {
      "id": "2087e906-3eb0-428c-af4b-76154cf42400",
      "name": "Merge Creators",
