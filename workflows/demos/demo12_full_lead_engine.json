      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "ec5cac12-f5e3-455d-8ab9-7dda23bf8b9f",
              "leftValue": "={{ $json.emailOk !== false && /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test($json.email || '') }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "76595f53-64ad-4061-adfb-53acc1c21557",
      "name": "Read CRM_Clients",
      "type": "n8n-nodes-base.googleSheets",
