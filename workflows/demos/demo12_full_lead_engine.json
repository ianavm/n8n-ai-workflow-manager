              "leftValue": "={{ $json.emailOk !== false && /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test($json.email || '') }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "2f09119b-2913-4d3b-8b31-089ed43e482c",
      "name": "Read CRM_Clients",
