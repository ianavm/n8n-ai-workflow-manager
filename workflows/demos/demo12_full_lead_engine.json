    {
      "id": "59075738-09f4-47a4-9b42-f57169c3471f",
      "name": "Load Fixture Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...l, runId: cfg.runId, source: l.source || 'fixture' } }];"
      }
    },
    {
      "id": "8a1b3cf2-4784-4f06-8ab8-d0d80642703a",
      "name": "Validate + Normalise Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nconst email = String(body.email || '').trim().toLowerCase();\nconst emailOk = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\nreturn [{\n  json: {\n    name: body.name || 'there',\n    email,\n    company: body.company || '',\n    phone: body.phone || '',\n    source: body.source || 'webhook',\n    message: body.message || '',\n    runId: cfg.runId,\n    emailOk,\n  }\n}];"
      }
    },
    {
      "id": "542f401b-6ed9-4f24-832c-926f4dc2031f",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
