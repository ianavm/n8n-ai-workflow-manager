    {
      "id": "0fd592aa-81b6-42a6-999e-cc4a5b8249e3",
      "name": "Dedup + Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const existing = $input.all().map(i => i.json);\nconst lead = $('Validate Email').first().json;\nconst match = existing.find(r => (r.Email || '').toLowerCase() === lead.email);\nconst existingClient = Boolean(match);\nconst prompt = `You are a senior SDR for AnyVision Media. For the lead\nbelow, do three things and return STRICT JSON (no fences):\n\n  {\n    \"industry\": \"single-line industry classification\",\n    \"companySizeGuess\": \"SMB|mid-market|enterprise (best guess)\",\n    \"leadScore\": 1-10,\n    \"intent\": \"hot|question|generic\",\n    \"subjectLine\": \"...\",\n    \"replyHtml\": \"<p>...</p> (3-4 sentences, personalised, offer a specific 20-min slot, sign as Ian)\"\n  }\n\nInputs include an ``existingClient`` flag. If existingClient=true, the reply\nshould reference prior context gently; if false, introduce yourself briefly.\n\nLead:\n${JSON.stringify($json, null, 2)}`;\nreturn [{\n  json: {\n    ...lead,\n    existingClient,\n    existingNotes: match ? match.Notes : '',\n    clientId: match?.Client_ID || `CLT-${Date.now()}-${Math.floor(Math.random() * 1000)}`,\n    prompt,\n  }\n}];\n"
      }
    },
    {
      "id": "06cb0a8c-c3db-4227-98ef-5adbc396ef45",
      "name": "AI Enrich + Draft Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1960,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 900, temperature: 0.4, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "b8833e2b-94c0-4ada-9887-a1bc2b978db1",
      "name": "Parse Enrichment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const src = $('Dedup + Build Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = {};\ntry { parsed = cleaned ? JSON.parse(cleaned) : {}; } catch (e) {}\n\nconst score = Number(parsed.leadScore) || 5;\n\nreturn [{\n  json: {\n    ...src,\n    industry: parsed.industry || 'unknown',\n    companySizeGuess: parsed.companySizeGuess || 'SMB',\n    leadScore: score,\n    intent: parsed.intent || 'question',\n    hot: score >= 7,\n    subjectLine: parsed.subjectLine || `Re: ${src.company || src.name}`,\n    replyHtml: parsed.replyHtml || `<p>Thanks for reaching out — I will follow up within one business day.</p><p>Ian</p>`,\n  }\n}];"
      }
    },
