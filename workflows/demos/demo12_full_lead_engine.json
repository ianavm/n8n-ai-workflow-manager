    {
      "id": "ea632bff-50f3-4772-81c5-c063b7af1f6f",
      "name": "DEMO_MODE Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "demo"
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.demoMode }}",
                    "rightValue": "0",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "live"
            }
          ]
        },
        "options": {
          "fallbackOutput": 0
        }
      }
    },
    {
      "id": "830cac0e-faf9-4883-843c-81432ac60784",
      "name": "Load Fixture Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst l = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...l, runId: cfg.runId, source: l.source || 'fixture' } }];"
      }
    },
    {
      "id": "19220d07-a1e1-4642-b612-7bfa20ac65a3",
      "name": "Validate + Normalise Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst body = $json.body || $json;\nconst email = String(body.email || '').trim().toLowerCase();\nconst emailOk = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\nreturn [{\n  json: {\n    name: body.name || 'there',\n    email,\n    company: body.company || '',\n    phone: body.phone || '',\n    source: body.source || 'webhook',\n    message: body.message || '',\n    runId: cfg.runId,\n    emailOk,\n  }\n}];"
      }
    },
    {
      "id": "d8bea869-3034-4a7b-9f35-105d3b394233",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
