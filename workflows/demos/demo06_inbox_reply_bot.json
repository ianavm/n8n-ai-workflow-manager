    {
      "id": "34776e04-dae9-43ff-8865-7e15092fff53",
      "name": "Load Fixture Thread",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst t = JSON.parse(cfg.fixtureData);\nreturn [{ json: { ...t, runId: cfg.runId, source: 'fixture' } }];\n"
      }
    },
    {
      "id": "82b740e6-82f3-4ba0-aad7-9f823aa87c64",
      "name": "Extract Live Thread",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        420
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Demo Config').first().json;\nconst raw = $json;\nconst from = raw.from || raw.payload?.headers?.find(h => h.name === 'From')?.value || 'unknown';\nconst subject = raw.subject || raw.payload?.headers?.find(h => h.name === 'Subject')?.value || '(no subject)';\nconst body = raw.snippet || raw.textPlain || raw.html || raw.body || '';\nreturn [{\n  json: {\n    threadId: raw.threadId || raw.id,\n    messageId: raw.id,\n    from: { name: String(from).split('<')[0].trim(), email: String(from).match(/<([^>]+)>/)?.[1] || from },\n    subject,\n    latestMessage: { body, date: new Date().toISOString() },\n    priorMessages: [],\n    runId: cfg.runId,\n    source: 'gmail',\n  }\n}];"
      }
    },
    {
      "id": "fca4a1fa-9d5f-4e50-b599-ee0721ee7bfb",
      "name": "Merge Thread Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    },
    {
      "id": "2f8f7ebe-980f-4fd9-812f-6aef25ef09a0",
      "name": "Build Draft Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const t = $input.first().json;\nconst prompt = `You are Ian Immelman, founder of AnyVision Media (AI automation\nagency, Johannesburg). You are drafting a reply to the LATEST message in the\nthread below. Keep your voice: direct, warm, specific, no filler, no emoji.\n\nGuidance:\n- Answer their exact questions. If you don't know a number, commit to sending\n  it in the next reply.\n- Always suggest a next step (15-min call, link to a one-pager, or a specific\n  timeline).\n- 3-5 sentences max. HTML allowed.\n- Output STRICT JSON only, no markdown fences:\n  { \"draftBody\": \"...\", \"draftSubject\": \"Re: ...\" }\n\nThread:\n${JSON.stringify($json, null, 2)}`;\nreturn [{ json: { ...t, prompt } }];\n"
      }
    },
    {
      "id": "05978dfe-89d2-49d0-a553-d8ff8cc5155c",
      "name": "AI Draft Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4-20250514', max_tokens: 650, temperature: 0.5, messages: [{role: 'user', content: $json.prompt}] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "3e16bf3a-60d7-4f6d-9e1c-d9840d936b2e",
      "name": "Parse Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const t = $('Build Draft Prompt').first().json;\nconst resp = $input.first().json || {};\nconst raw = resp.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/^```(?:json)?\\s*|\\s*```$/g, '').trim();\nlet parsed = { draftBody: null, draftSubject: null };\ntry { parsed = cleaned ? JSON.parse(cleaned) : parsed; } catch (e) {}\nconst fallbackBody = (t.latestMessage?.body || '').slice(0, 160);\nreturn [{\n  json: {\n    ...t,\n    draftBody: parsed.draftBody || `Thanks for the note — I will come back to you within the next business day.\\n\\n(Auto-draft fallback based on: ${fallbackBody})`,\n    draftSubject: parsed.draftSubject || `Re: ${t.subject || 'your message'}`,\n  }\n}];"
      }
    },
