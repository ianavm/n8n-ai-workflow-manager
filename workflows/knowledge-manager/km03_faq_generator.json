    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 2000,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"Based on these resolved support tickets, generate FAQ entries. Avoid duplicating existing FAQs. Format output as JSON array: [{question: string, answer: string, category: string, source_articles: [string], confidence: 0-1}]. Only generate FAQs for recurring patterns or commonly asked questions. Max 5 new FAQs.\"},\n    {\"role\": \"user\", \"content\": \"Resolved support KB articles ({{ $('Read Resolved Tickets').all().length }}):\\n{{ $('Read Resolved Tickets').all().map(i => 'Title:' + (i.json.title||i.json.article_id||'N/A') + ' Category:' + (i.json.category||'N/A') + ' Content:' + (i.json.content||'N/A').substring(0, 200)).join('\\n') || 'None.' }}\\n\\nExisting FAQ titles:\\n{{ $('Read Existing FAQs').all().map(i => '- ' + (i.json.file_name||i.json.summary||'N/A')).join('\\n') || 'None.' }}\"}\n  ]}",
        "options": {}
      },
      "id": "315fd2f5-b234-45b2-b21a-ca47789e85bd",
      "name": "AI Generate FAQs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst raw = (resp.choices && resp.choices[0]) ? resp.choices[0].message.content : '[]';\nlet faqs = [];\ntry { faqs = JSON.parse(raw.replace(/```json\\n?/g,'').replace(/```\\n?/g,'').trim()); } catch(e) { faqs = []; }\nif (!Array.isArray(faqs)) faqs = [];\n\nconst existing = $('Read Existing FAQs').all().map(i => (i.json.file_name || i.json.summary || '').toLowerCase());\nconst unique = faqs.filter(f => f.question && !existing.some(e => e.includes(f.question.toLowerCase().substring(0, 30))));\n\nif (unique.length === 0) {\n  return { json: { skip: true, message: 'No new unique FAQs generated', faq_count: 0 } };\n}\n\nreturn unique.map(f => ({json: {\n  doc_id: 'FAQ-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).substring(2, 6).toUpperCase(),\n  file_name: 'FAQ: ' + f.question,\n  doc_type: 'FAQ',\n  summary: 'Q: ' + f.question + '\\nA: ' + f.answer,\n  tags: f.category || 'general',\n  key_topics: (f.source_articles || []).join(', '),\n  confidence: f.confidence || 0.8,\n  skip: false,\n}}));"
      },
      "id": "d03bcb3a-8493-4be1-a0b2-8bf4050ba3c9",
      "name": "Parse and Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
