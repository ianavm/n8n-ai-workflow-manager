      "parameters": {
        "jsCode": "\n// Terminal node - log parse error for debugging\nconst input = $input.first().json;\nreturn {\n  json: {\n    logged: true,\n    error: 'Message parse failed',\n    reason: input.reason || 'Unknown',\n    timestamp: new Date().toISOString()\n  }\n};\n",
