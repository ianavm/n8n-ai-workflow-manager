        "jsonBody": "{\"Quotes\": [{\"Contact\": {\"ContactID\": \"={{ $json.xeroContactId }}\"}, \"LineItems\": [{\"ItemCode\": \"={{ $json.xeroItemCode }}\", \"Description\": \"={{ $json.description }}\", \"Quantity\": \"={{ $('Process Quantity').first().json.selectedQuantity }}\", \"UnitAmount\": \"={{ $json.unitPrice }}\", \"TaxType\": \"OUTPUT\"}], \"Status\": \"DRAFT\", \"Title\": \"=WhatsApp Order - {{ $('Parse Message').first().json.profileName }}\", \"Summary\": \"=Order via WhatsApp: {{ $('Process Quantity').first().json.selectedCategory || $('Find Active Session').first().json.Selected_Category }} - {{ $('Process Size Selection').first().json.selectedSize || $('Find Active Session').first().json.Selected_Size }} x {{ $('Process Quantity').first().json.selectedQuantity }}\"}]}",
