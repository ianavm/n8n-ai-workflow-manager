    {
      "id": "b83b0347-b650-4b27-b921-4d8df176714d",
      "name": "Parse Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        400
      ],
      "parameters": {
        "jsCode": "\nconst input = $input.first().json;\nconst text = (input.messageBody || '').trim().toUpperCase();\n\nlet decision = 'vague';\nlet feedback = '';\n\nif (text === 'APPROVE' || text === 'YES' || text === 'APPROVED' || text.startsWith('APPROVE')) {\n  decision = 'approve';\n} else if (text.startsWith('REJECT') || text.startsWith('NO ') || text === 'NO') {\n  decision = 'reject';\n  feedback = text.replace(/^(REJECT|NO)\\s*/i, '').trim();\n  if (!feedback) decision = 'vague';\n}\n\nreturn { json: { ...input, decision, feedback } };\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "4a47aeb7-925c-4f6b-b1c9-b1ab42f94e40",
      "name": "Decision Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        1660,
        400
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.decision }}",
                    "rightValue": "approve",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.decision }}",
                    "rightValue": "reject",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            }
          ]
        },
        "options": {
          "fallbackOutput": 2
        }
      }
    },
