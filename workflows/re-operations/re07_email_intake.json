    {
      "id": "f391b9bb-6b2c-45a9-aabe-61b95bb74484",
      "name": "Check Email Dedup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        300
      ],
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r['Thread ID']);\nconst target = $('Extract Email Data').first().json.gmail_message_id;\nconst matches = rows.filter(r => String(r['Conversation ID'] || '') === String(target));\nreturn [{json: { match_count: matches.length, is_new: matches.length === 0 }}];\n"
      }
    },
