    {
      "id": "951b7092-f891-4184-afab-db911bd1f06c",
      "name": "Query Calendar FreeBusy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/freeBusy",
        "options": {
          "timeout": 30000
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"timeMin\":\"{{ $now.toISO() }}\",\"timeMax\":\"{{ $now.plus({days: 10}).toISO() }}\",\"items\":[{\"id\":\"primary\"}]}"
      },
