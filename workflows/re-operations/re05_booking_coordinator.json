    {
      "id": "cc531ae0-dc7a-41ba-9f5f-befa82689f1e",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        300
      ],
      "parameters": {
        "jsCode": "\n// Build prompt for AI slot suggestion\nconst data = $input.first().json;\n\nreturn { json: {\n  ...data,\n  prompt_text: `Client: ${data.client_name}\nProperty: ${data.property_id}\nAgent: ${data.agent_name}\nViewing type: ${data.viewing_type}\nPreferred date: ${data.preferred_date}\nDuration: ${data.duration_min} minutes\nAvailable slots (showing up to 30):\n${JSON.stringify(data.available_slots.slice(0, 30), null, 2)}`,\n}};\n"
      }
    },
    {
      "id": "9023d0b7-c350-4423-8dfa-74fb033a4128",
      "name": "AI Suggest Slots",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1980,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 800, \"temperature\": 0.3, \"messages\": [{\"role\": \"system\", \"content\": \"You are a scheduling assistant for a South African real estate agency.\\n\\nGiven a list of available time slots, the client's preferences, and the property/agent details, suggest the BEST 3 time slots for a property viewing or meeting.\\n\\nConsider these factors when ranking slots:\\n1. Proximity to the client's preferred date/time\\n2. Morning slots (09:00-12:00 SAST) are preferred for first viewings\\n3. Afternoon slots (14:00-16:00 SAST) are preferred for second viewings and negotiations\\n4. Avoid slots that are back-to-back with other appointments (buffer time)\\n5. Weekend slots should only be suggested if weekday options are limited\\n6. Consider daylight hours for property viewings (before 17:00 in winter, 18:00 in summer)\\n\\nIMPORTANT RULES:\\n- ALL slots must be at least 2 FULL BUSINESS DAYS in the future from now\\n- Slots must be within business hours: 08:00-17:00 SAST (06:00-15:00 UTC)\\n- Each viewing slot should be 30 or 60 minutes\\n- Leave at least 30 minutes buffer between appointments for travel time\\n- Never double-book an agent\\n\\nOUTPUT FORMAT (JSON only, no markdown fences):\\n{\\n  \\\"recommended_slots\\\": [\\n    {\\n      \\\"start\\\": \\\"2026-01-15T09:00:00+02:00\\\",\\n      \\\"end\\\": \\\"2026-01-15T09:30:00+02:00\\\",\\n      \\\"reason\\\": \\\"Morning slot, closest to preferred date, good for first viewing\\\"\\n    }\\n  ],\\n  \\\"selected_slot\\\": {\\n    \\\"start\\\": \\\"2026-01-15T09:00:00+02:00\\\",\\n    \\\"end\\\": \\\"2026-01-15T09:30:00+02:00\\\"\\n  },\\n  \\\"notes\\\": \\\"Any additional scheduling notes\\\"\\n}\"}, {\"role\": \"user\", \"content\": \"={{$json.prompt_text}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "ac059273-c487-463c-b9a1-cc664cd75103",
      "name": "Parse AI Suggestion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        300
      ],
      "parameters": {
        "jsCode": "\n// Parse AI slot suggestion response\nconst aiResp = $input.first().json;\nconst content = (aiResp.choices && aiResp.choices[0])\n  ? aiResp.choices[0].message.content\n  : '{}';\n\nconst slotData = $('Build AI Prompt').first().json;\n\nlet aiResult = {};\ntry {\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  aiResult = JSON.parse(cleaned);\n} catch (e) {\n  // Fallback to first available slot\n  aiResult = {\n    recommended_slots: [],\n    selected_slot: slotData.available_slots[0] || {},\n    notes: 'AI parse failed, using first available slot',\n  };\n}\n\nconst selectedSlot = aiResult.selected_slot || slotData.available_slots[0] || {};\n\nreturn { json: {\n  booking_id: slotData.booking_id,\n  client_name: slotData.client_name,\n  property_id: slotData.property_id,\n  agent_name: slotData.agent_name,\n  viewing_type: slotData.viewing_type,\n  duration_min: slotData.duration_min,\n  event_start: selectedSlot.start || '',\n  event_end: selectedSlot.end || '',\n  recommended_slots: aiResult.recommended_slots || [],\n  ai_notes: aiResult.notes || '',\n  booked_at: new Date().toISOString(),\n}};\n"
      }
    },
