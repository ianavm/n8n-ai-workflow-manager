      }
    },
    {
      "id": "256952ed-a976-46bf-997e-37fb850b68ab",
      "name": "AI Generate Follow-up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9ZgHenDBrFuyboov",
          "name": "OpenRouter 2WC"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://www.anyvisionmedia.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 200, \"temperature\": 0.6, \"messages\": [{\"role\": \"system\", \"content\": \"You are a friendly real estate assistant in South Africa. Generate a brief, warm WhatsApp follow-up message. Keep it under 200 characters. Do not use markdown. Be conversational and natural.\"}, {\"role\": \"user\", \"content\": \"={{$json.prompt_text}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "d06cdd63-874d-4726-95c8-aed069e66e9e",
      "name": "Parse Follow-up",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        300
      ],
      "parameters": {
        "jsCode": "\n// Parse AI-generated follow-up and prepare for sending\nconst aiResp = $input.first().json;\nconst content = (aiResp.choices && aiResp.choices[0])\n  ? aiResp.choices[0].message.content\n  : 'Hi! Just checking in to see if you are still looking for property. Let us know if we can help!';\n\n// Strip any markdown\nlet cleanText = content\n  .replace(/\\*\\*([^*]+)\\*\\*/g, '$1')\n  .replace(/\\*([^*]+)\\*/g, '$1')\n  .replace(/`([^`]+)`/g, '$1')\n  .trim();\n\nif (cleanText.length > 500) {\n  cleanText = cleanText.substring(0, 495) + '...';\n}\n\nconst leadData = $('Generate Follow-up Data').first().json;\n\nreturn {\n  json: {\n    follow_up_text: cleanText,\n    lead_id: leadData.lead_id || leadData.id || '',\n    client_name: leadData.client_name || 'Unknown',\n    phone_normalized: leadData.phone_normalized || leadData.phone || '',\n    phone_number_id: leadData.phone_number_id || '',\n    follow_up_number: leadData.follow_up_number,\n    is_final_followup: leadData.is_final_followup,\n  }\n};\n"
      }
    },
    {
      "id": "3c7eb68b-6e8e-4f94-b53b-db6113b7aff1",
      "name": "Send Follow-up WA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1980,
