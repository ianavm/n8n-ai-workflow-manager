      ],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $json.phone_number_id }}/messages",
        "options": {
          "timeout": 30000
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"messaging_product\":\"whatsapp\",\"to\":\"{{ $json.phone_normalized }}\",\"type\":\"text\",\"text\":{\"body\":\"{{ $json.follow_up_text }}\"}}"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "dCAz6MBXpOXvMJrq",
          "name": "WhatsApp account AVM Multi Agent"
        }
      }
    },
