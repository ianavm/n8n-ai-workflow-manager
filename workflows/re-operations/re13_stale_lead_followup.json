{
  "name": "RE-13 Stale Lead Follow-up",
  "nodes": [
    {
      "id": "f51d5f68-6e8c-4b25-8277-b89182a5a8f2",
      "name": "Note RE-13",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        100
      ],
      "parameters": {
        "content": "RE-13: Stale Lead Follow-up\n\nRuns daily at 09:00 SAST (07:00 UTC).\nFinds leads with no contact > 48h,\ngenerates AI follow-up, sends WhatsApp.\nMax 3 follow-ups, then marks Cold.",
        "width": 300,
        "height": 200,
        "color": 5
      }
    },
    {
      "id": "8614812a-a3a6-4f74-ad02-25dd06d98817",
      "name": "Daily 09:00 SAST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "1da54d2f-a259-41dc-96fa-ceabab608960",
      "name": "Find Stale Leads",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        440,
        300
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable account"
        }
      },
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "appCVxBCRi5ppbUpV",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "tblnsKB429zyzEpfJ",
          "mode": "id"
        },
        "filterByFormula": "=AND(IS_BEFORE({last_contact}, DATEADD(NOW(), -48, 'hours')), NOT(OR({status} = 'Converted', {status} = 'Closed', {status} = 'Cold')), {follow_up_count} < 3)",
        "options": {}
      },
      "alwaysOutputData": true
    },
    {
      "id": "a3c981b9-c025-4c2b-add8-d2c85fe711c8",
      "name": "Has Stale Leads?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        660,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $input.all().length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        }
      }
    },
    {
      "id": "50e7fd7d-04d6-4a1c-a029-dd7f39657c8a",
      "name": "Generate Follow-up Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\n// Generate follow-up message for each stale lead\nconst leads = $input.all();\nconst results = [];\n\nfor (const item of leads) {\n  const lead = item.json;\n  const followUpCount = parseInt(lead.follow_up_count || 0);\n  const name = lead.client_name || 'there';\n  const area = lead.area || '';\n  const budget = lead.budget || '';\n\n  let promptContext = `Generate a brief, warm WhatsApp follow-up message (under 200 chars) for:\\n`;\n  promptContext += `Name: ${name}\\nFollow-up #${followUpCount + 1}\\n`;\n  if (area) promptContext += `Interested area: ${area}\\n`;\n  if (budget) promptContext += `Budget: ${budget}\\n`;\n\n  if (followUpCount === 0) {\n    promptContext += 'First follow-up: check if they are still looking, mention we have new listings.';\n  } else if (followUpCount === 1) {\n    promptContext += 'Second follow-up: ask if they have questions, offer to schedule a viewing.';\n  } else {\n    promptContext += 'Final follow-up: let them know we are here when ready, wish them well.';\n  }\n\n  results.push({\n    json: {\n      ...lead,\n      follow_up_number: followUpCount + 1,\n      is_final_followup: followUpCount >= 2,\n      prompt_text: promptContext,\n      phone_number_id: lead.phone_number_id || '',\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];\n"
      }
    },
    {
      "id": "23dceac6-de2c-4795-bdd2-fb4700c1e4dc",
      "name": "Not Skip?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        300
      ],
      "parameters": {
        "conditions": {
