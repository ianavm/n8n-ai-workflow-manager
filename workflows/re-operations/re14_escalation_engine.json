    {
      "id": "fc2270dc-a0fd-40bc-bd89-896593665f15",
      "name": "Unresponded Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        200
      ],
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r['Lead ID']);\nconst matches = rows.filter(r =>\n  new Date(r['Last Contact']) < new Date(Date.now() - 2*3600000) &&\n  (r['Status'] === 'New' || r['Status'] === 'Active')\n);\nreturn matches.length ? matches.map(m => ({json: m})) : [{json: {}}];\n"
      }
    },
