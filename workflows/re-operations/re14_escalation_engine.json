    {
      "id": "a432ff0b-604f-4aee-9bee-2f8dfa25818a",
      "name": "Stale Deals",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        200
      ],
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r['Deal ID']);\nconst matches = rows.filter(r =>\n  new Date(r['Updated At']) < new Date(Date.now() - 7*24*3600000) &&\n  (r['Status'] === 'Active' || r['Status'] === 'In Progress')\n);\nreturn matches.length ? matches.map(m => ({json: m})) : [{json: {}}];\n"
      }
    },
