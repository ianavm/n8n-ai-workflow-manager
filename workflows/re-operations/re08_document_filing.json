    {
      "id": "4319dc7c-0d2d-46bc-94cd-113e14109982",
      "name": "Find Drive Folder",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        500
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://www.googleapis.com/drive/v3/files?q={{ encodeURIComponent(\"mimeType='application/vnd.google-apps.folder' and name='\" + $('Build Filename').first().json.folder_name + \"' and '\" + $env.RE_GDRIVE_ROOT_FOLDER_ID + \"' in parents and trashed=false\") }}&fields=files(id,name)",
        "options": {
          "timeout": 30000
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleOAuth2Api"
      },
      "credentials": {
        "googleOAuth2Api": {
          "id": "h1nJlw5vhziBMlh8",
          "name": "Google Drive OAuth2"
        }
      }
    },
    {
      "id": "1e55941b-88fe-4544-b508-749da1ef1f46",
      "name": "Process Folder Search",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        500
      ],
      "parameters": {
        "jsCode": "\n// Check if folder exists, if not prepare create request\nconst searchResult = $input.first().json;\nconst fileData = $('Build Filename').first().json;\nconst files = searchResult.files || [];\n\nif (files.length > 0) {\n  // Folder exists\n  return { json: {\n    ...fileData,\n    drive_folder_id: files[0].id,\n    folder_existed: true,\n  }};\n}\n\n// Folder does not exist - we need to create it\nreturn { json: {\n  ...fileData,\n  drive_folder_id: '',\n  folder_existed: false,\n  create_folder_body: {\n    name: fileData.folder_name,\n    mimeType: 'application/vnd.google-apps.folder',\n    parents: [$env.RE_GDRIVE_ROOT_FOLDER_ID || ''],\n  },\n}};\n"
      }
    },
    {
      "id": "f1468e28-5242-4835-ab26-7b9af1e1d039",
      "name": "Folder Exists?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1760,
        500
