    {
      "id": "1ae9933e-2224-4df9-8e11-8a2fae39dee0",
      "name": "Check Duplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\nconst target = $('Build Filename').first().json.content_hash;\nconst rows = $input.all().map(i => i.json).filter(r => r['Doc ID']);\nconst matches = rows.filter(r => r['Content Hash'] === target);\nreturn matches.length ? matches.map(m => ({json: m})) : [{json: {}}];\n"
      }
    },
    {
      "id": "7a6cd63d-8b22-49ed-ba70-c4051b0ae502",
      "name": "Check Duplicate Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\n// Handle duplicate detection result\nconst searchResults = $input.all();\nconst fileData = $('Build Filename').first().json;\n\nconst hasDuplicate = searchResults.length > 0\n  && searchResults[0].json\n  && searchResults[0].json.content_hash\n  && searchResults[0].json.content_hash === fileData.content_hash;\n\nreturn {\n  json: {\n    ...fileData,\n    is_duplicate: hasDuplicate,\n    existing_doc_id: hasDuplicate ? (searchResults[0].json.document_id || '') : '',\n  }\n};\n"
      }
    },
    {
      "id": "1b2682f6-460e-4c57-83dd-400b61056861",
      "name": "Is Duplicate?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
