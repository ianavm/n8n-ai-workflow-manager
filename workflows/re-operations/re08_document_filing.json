            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $json.is_duplicate }}",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        }
      }
    },
    {
      "id": "b8ae92db-8da0-4244-92f2-404875e65ba8",
      "name": "Prepare Skip Log",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        200
      ],
      "parameters": {
        "jsCode": "\n// Log duplicate skip\nconst data = $input.first().json;\n\nreturn {\n  json: {\n    activity_type: 'Duplicate Document Skipped',\n    entity_type: 'Document',\n    entity_id: data.existing_doc_id || 'unknown',\n    description: `Duplicate detected: ${data.original_filename} (hash: ${data.content_hash})`,\n    performed_by: 'System',\n    timestamp: new Date().toISOString(),\n    is_duplicate: true,\n    skipped: true,\n  }\n};\n"
      }
    },
