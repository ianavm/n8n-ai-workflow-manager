      ],
      "parameters": {
        "content": "RE-08: Document Filing\n\nFiles classified documents to Google Drive,\ncreates Google Sheets record, deduplicates by hash,\nnotifies admin via RE-10.",
        "width": 300,
        "height": 160,
        "color": 3
      }
    },
    {
      "id": "1bf8994e-0278-4cdc-beaa-9ab42a94bbd6",
      "name": "Trigger",
