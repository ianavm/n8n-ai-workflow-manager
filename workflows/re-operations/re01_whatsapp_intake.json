      "name": "Find Agent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        300
      ],
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r['Agent Name']);\nconst target = $('Not Group?').first().json.phone_number_id;\nconst matches = rows.filter(r => String(r['WhatsApp Phone Number ID'] || '') === String(target));\nreturn matches.length ? matches.map(m => ({json: m})) : [{json: {}}];\n"
      }
