    {
      "id": "23b42081-5f56-4a05-bda1-640c6925f855",
      "name": "WhatsApp Trigger",
      "type": "n8n-nodes-base.whatsAppTrigger",
      "typeVersion": 1,
      "position": [
        220,
        300
      ],
      "webhookId": "bb0adf29-6d8b-4929-af39-c7e693f60557",
      "credentials": {
        "whatsAppTriggerApi": {
          "id": "rUyqIX1gaBs3ae6Q",
          "name": "WhatsApp OAuth AVM Multi Agent"
        }
