      "name": "WhatsApp Trigger",
      "type": "n8n-nodes-base.whatsAppTrigger",
      "typeVersion": 1,
      "position": [
        220,
        300
      ],
      "webhookId": "a8ddb6f4-5f45-4615-a353-93ef01180f67",
      "credentials": {
        "whatsAppTriggerApi": {
          "id": "rUyqIX1gaBs3ae6Q",
