            }
          ]
        }
      }
    },
    {
      "id": "7d27f94f-17bd-4fe6-a3b9-2141152cf750",
      "name": "Check Recent Failures",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://ianimmelman89.app.n8n.cloud/api/v1/executions?status=error&limit=10",
        "options": {
          "timeout": 30000
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "={{ $env.N8N_API_KEY }}"
            }
          ]
        }
      }
    },
    {
      "id": "595eb2e1-94ca-4d84-abd2-9b2b1dcb82ea",
      "name": "Analyze Failures",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\n// Analyze recent execution failures\nconst healthData = $('Check n8n Health').first().json;\nconst execData = $('Check Recent Failures').first().json;\n\nconst executions = execData.data || [];\nconst failedExecs = executions.filter(e =>\n  e.status === 'error' || e.status === 'failed' || e.finished === false\n);\n\nconst now = new Date();\nconst hasErrors = failedExecs.length > 0;\n\nlet errorSummary = '';\nif (hasErrors) {\n  errorSummary = failedExecs.slice(0, 5).map(e => {\n    const wfName = e.workflowData ? e.workflowData.name : (e.workflowId || 'Unknown');\n    const errMsg = e.data && e.data.resultData && e.data.resultData.error\n      ? e.data.resultData.error.message || 'Unknown error'\n      : 'Execution failed';\n    return `- ${wfName}: ${errMsg.substring(0, 200)}`;\n  }).join('\\n');\n}\n\nreturn {\n  json: {\n    has_errors: hasErrors,\n    failed_count: failedExecs.length,\n    total_checked: executions.length,\n    error_summary: errorSummary,\n    health_status: healthData.status || 'unknown',\n    checked_at: now.toISOString(),\n    alert_type: 'System Health',\n    severity: failedExecs.length >= 3 ? 'critical' : failedExecs.length > 0 ? 'high' : 'low',\n    message: hasErrors\n      ? `${failedExecs.length} workflow execution(s) failed in the last 15 min:\\n${errorSummary}`\n      : 'All workflows executing normally.',\n  }\n};\n"
      }
    },
    {
      "id": "e4684112-7213-452d-9bbc-e9f442741bc4",
      "name": "Has Errors?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
