        "specifyBody": "json",
        "jsonBody": "{\"model\": \"anthropic/claude-sonnet-4-20250514\", \"max_tokens\": 800, \"temperature\": 0.3, \"messages\": [{\"role\": \"system\", \"content\": \"You are a daily briefing assistant for a South African real estate agency. Format the provided summary data into a clean, concise Telegram message using HTML tags. Use <b>bold</b> for headers. Add relevant emoji sparingly. Keep it under 2000 characters.\"}, {\"role\": \"user\", \"content\": \"={{$json.prompt_text}}\"}]}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "ce11c321-61ab-4de6-94ec-33d1a24acff5",
      "name": "Parse AI Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2640,
        300
      ],
      "parameters": {
        "jsCode": "\nconst aiResp = $input.first().json;\nconst content = (aiResp.choices && aiResp.choices[0])\n  ? aiResp.choices[0].message.content\n  : $('Build Summary').first().json.prompt_text;\n\nreturn { json: { summary_text: content } };\n"
      }
    },
