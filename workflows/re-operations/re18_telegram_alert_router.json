{
  "name": "RE-18 Telegram Alert Router",
  "nodes": [
    {
      "id": "f40146dc-870e-471d-bb22-a7e0921555a4",
      "name": "Note RE-18",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
