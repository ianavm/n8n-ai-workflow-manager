{
  "name": "CURE-01 Nightly Dedup Scan",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 23 * * *"
            }
          ]
        }
      },
      "id": "0145940a-347b-49e1-849f-2f8e128675e3",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Define tables to scan for duplicates\nconst targets = [\n  {\n    base_id: 'app2ALQUP7CKEkHOz',\n    table_id: 'REPLACE_AFTER_SETUP',\n    table_name: 'CRM_Unified',\n    dedup_field: 'email'\n  },\n  {\n    base_id: 'app2ALQUP7CKEkHOz',\n    table_id: 'REPLACE_AFTER_SETUP',\n    table_name: 'Leads',\n    dedup_field: 'email'\n  },\n  {\n    base_id: 'apptjjBx34z9340tK',\n    table_id: 'REPLACE_AFTER_SETUP',\n    table_name: 'Contacts',\n    dedup_field: 'email'\n  }\n];\nreturn targets.map(t => ({json: t}));"
      },
      "id": "023f99a7-a73c-4f72-8b7a-8603eccf4569",
      "name": "Set Target Tables",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "={{ $json.base_id }}",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "={{ $json.table_id }}",
          "mode": "id"
        },
        "returnAll": true,
        "options": {}
      },
      "id": "b55d5e8b-4a6d-4b26-871b-baebd928a20e",
      "name": "Fetch Table Records",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        660,
        300
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable PAT"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const records = $input.all();\nconst targetInfo = $('Set Target Tables').item.json;\nconst dedupField = targetInfo.dedup_field;\nconst tableName = targetInfo.table_name;\n\n// Normalize and group by dedup field\nconst groups = {};\nlet totalRecords = 0;\nlet emptyFieldCount = 0;\n\nfor (const item of records) {\n  totalRecords++;\n  const raw = item.json[dedupField] || item.json.fields?.[dedupField] || '';\n  if (!raw) { emptyFieldCount++; continue; }\n  const normalized = String(raw).toLowerCase().trim();\n  if (!groups[normalized]) groups[normalized] = [];\n  groups[normalized].push({\n    record_id: item.json.id || item.json.record_id || 'unknown',\n    raw_value: raw,\n  });\n}\n\nconst duplicates = Object.entries(groups)\n  .filter(([_, recs]) => recs.length > 1)\n  .map(([key, recs]) => ({\n    value: key,\n    count: recs.length,\n    record_ids: recs.map(r => r.record_id),\n  }));\n\nconst totalDuplicateRecords = duplicates.reduce((sum, d) => sum + d.count - 1, 0);\n\nreturn { json: {\n  table_name: tableName,\n  base_id: targetInfo.base_id,\n  table_id: targetInfo.table_id,\n  dedup_field: dedupField,\n  total_records: totalRecords,\n  empty_field_count: emptyFieldCount,\n  duplicate_groups: duplicates.length,\n  duplicate_records: totalDuplicateRecords,\n  duplicate_rate_pct: totalRecords > 0 ? Math.round((totalDuplicateRecords / totalRecords) * 10000) / 100 : 0,\n  top_duplicates: duplicates.slice(0, 10),\n  scanned_at: new Date().toISOString(),\n}};"
      },
      "id": "55ec7874-2ba9-4fd9-9892-23deb498284b",
      "name": "Detect Duplicates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "__rl": true,
          "value": "appTCh0EeXQp0XqzW",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "REPLACE_AFTER_SETUP",
          "mode": "id"
        },
        "columns": {
          "value": {
            "scan_id": "=DEDUP-{{ $json.table_name }}-{{ $now.toFormat('yyyyMMdd') }}",
            "scan_type": "Dedup Scan",
            "table_name": "={{ $json.table_name }}",
            "total_records": "={{ $json.total_records }}",
            "issues_found": "={{ $json.duplicate_records }}",
            "issue_rate_pct": "={{ $json.duplicate_rate_pct }}",
            "details": "={{ JSON.stringify({duplicate_groups: $json.duplicate_groups, top_duplicates: $json.top_duplicates, empty_fields: $json.empty_field_count}) }}",
            "scanned_at": "={{ $json.scanned_at }}",
            "status": "={{ $json.duplicate_records > 20 ? 'Alert' : 'OK' }}"
          },
          "mappingMode": "defineBelow"
        },
        "options": {}
      },
      "id": "b24d243c-b321-4db5-a3c1-90e6e2102c4e",
      "name": "Write Dedup Results",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        1100,
        300
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable PAT"
        }
      }
    },
    {
