    },
    {
      "id": "65b1873b-3423-4f2c-87ee-8e71b89d8e88",
      "name": "Parse Call",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        320
      ],
      "parameters": {
        "jsCode": "\n// Parse Twilio Voice StatusCallback payload (or a manual test POST).\n// Webhook v2 wraps POST body under $json.body.\nconst root = $input.first().json || {};\nconst body = (root && typeof root.body === 'object' && root.body) ? root.body : root;\n\nconst rawStatus = String(body.CallStatus || body.DialCallStatus || body.call_status || '').toLowerCase().trim();\nconst missedStatuses = ['no-answer', 'busy', 'failed', 'canceled', 'cancelled'];\nconst isMissed = missedStatuses.includes(rawStatus);\n\nconst fromPhone = String(body.From || body.from || '').trim();\nconst toPhone = String(body.To || body.to || '').trim();\nconst callSid = String(body.CallSid || body.call_sid || '').trim();\n\n// Johannesburg hours — Date.toLocaleString with a timezone returns the wall-clock\n// in that zone, so parsing its hour gives us SAST regardless of server TZ.\nconst now = new Date();\nconst sastParts = now.toLocaleString('en-GB', {\n  timeZone: 'Africa/Johannesburg',\n  hour: '2-digit',\n  hour12: false,\n});\nconst sastHour = parseInt(sastParts, 10);\nconst businessHoursStart = 8;\nconst businessHoursEnd = 18;\nconst inBusinessHours = sastHour >= businessHoursStart && sastHour < businessHoursEnd;\nconst callWindow = inBusinessHours ? 'business-hours' : 'after-hours';\n\nconst callId = 'MCB-' + now.getTime().toString(36).toUpperCase();\n\nreturn [{\n  json: {\n    'Call ID': callId,\n    'From Phone': fromPhone,\n    'To Phone': toPhone,\n    'Call Status': rawStatus || 'unknown',\n    'Call Window': callWindow,\n    'Call SID': callSid,\n    'Received At': now.toISOString(),\n    _isMissed: isMissed,\n    _inBusinessHours: inBusinessHours,\n  }\n}];\n"
      }
    },
    {
      "id": "9b4c5fa2-e4e7-4f26-bfca-e1c660d9c99b",
      "name": "Is Missed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        680,
        320
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "caseSensitive": true,
            "typeValidation": "loose",
            "leftValue": ""
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "6778f22e-5f9d-4171-9af6-41f5147b0c6f",
              "leftValue": "={{ $json._isMissed ? 'yes' : '' }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "5ec5af77-cfbd-4b70-9af8-8e93704e9aac",
      "name": "Repeat Caller?",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "alwaysOutputData": true,
      "onError": "continueRegularOutput",
      "position": [
        900,
        240
      ],
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "mode": "id",
          "value": "appdRv8eJY6uweQ5F"
        },
        "table": {
          "__rl": true,
          "mode": "id",
          "value": "tbl9Kp2eWSca6opov"
        },
        "filterByFormula": "={{ \"{From Phone} = '\" + $('Parse Call').first().json['From Phone'] + \"'\" }}",
        "options": {
          "fields": [
            "From Phone"
          ]
        }
      },
      "credentials": {
        "airtableTokenApi": {
          "id": "ZyBrcAO6fps7YB3u",
          "name": "Airtable account"
        }
      }
    },
    {
      "id": "41143388-c7b7-4c2c-bb62-0651d2baa739",
      "name": "Compose SMS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        240
      ],
      "parameters": {
        "jsCode": "\n// Compose the reply WhatsApp message. If there is already a row in\n// MCB_Missed_Calls for this phone number, treat it as a repeat caller and\n// send a softer follow-up.\nconst parsed = $('Parse Call').first().json;\nconst search = $input.first().json || {};\nconst isRepeat = !!(search && search.id);\n\nconst inHours = parsed._inBusinessHours;\nlet body;\nif (isRepeat) {\n  body = \"Hey again — thanks for calling back. What's the best way to help you? \"\n       + \"Happy to sort it over WhatsApp or book a quick call.\";\n} else if (inHours) {\n  body = \"Hey! Sorry I missed your call — I'm on a job right now. \"\n       + \"What can I help you with? I'll WhatsApp you back in 10 min.\";\n} else {\n  body = \"Hey! Sorry I missed your call — we're closed right now. \"\n       + \"What can I help you with? I'll reply first thing tomorrow.\";\n}\n\nreturn [{\n  json: Object.assign({}, parsed, {\n    'Is Repeat Caller': isRepeat,\n    'SMS Body': body,\n    'Status': 'SMS Sent',\n  })\n}];\n"
      }
    },
    {
      "id": "1b56aa09-99f6-42e5-8e8b-b8469f2342a1",
