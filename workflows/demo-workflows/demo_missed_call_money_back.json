        "operation": "send",
        "from": "+14155238886",
        "to": "={{ $json['From Phone'] }}",
        "toWhatsapp": true,
        "message": "={{ $json['SMS Body'] }}",
        "options": {}
      },
      "credentials": {
        "twilioApi": {
          "id": "YzAgDJdx5ZaKbbar",
