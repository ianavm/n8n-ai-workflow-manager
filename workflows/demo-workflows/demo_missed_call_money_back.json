{
  "name": "DEMO: Missed Call Money Back",
  "nodes": [
    {
      "id": "cce4b501-a218-41cd-9b50-99618207e66f",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
