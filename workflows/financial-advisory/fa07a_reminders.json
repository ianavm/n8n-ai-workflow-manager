      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        300,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://qfvsqjsrlnxjplqefhon.supabase.co/rest/v1/fa_meetings?select=*,client:fa_clients(*),adviser:fa_advisers(*)&reminder_24h_sent=eq.false&status=in.(scheduled,confirmed)&scheduled_at=gte.{{ $now.plus({hours: 23}).toISO() }}&scheduled_at=lte.{{ $now.plus({hours: 25}).toISO() }}",
