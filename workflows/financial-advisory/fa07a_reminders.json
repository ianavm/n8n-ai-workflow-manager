      "typeVersion": 1.2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/30 7-19 * * 1-5"
            }
          ]
        }
      }
    },
    {
      "id": "ca8aafff-5e8c-4131-8f81-2fbbe54a975d",
