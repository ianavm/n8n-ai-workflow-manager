    {
      "id": "8dc50171-3b47-40de-ade7-c96d3b0fa273",
      "name": "Send 24h Email",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        1200,
        -200
      ],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "bodyContentType": "html",
        "bodyContent": "={{ (function() {\n  const m = $json;\n  const dt = new Date(m.scheduled_at);\n  const dateStr = dt.toLocaleDateString('en-ZA', {weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Africa/Johannesburg'});\n  const timeStr = dt.toLocaleTimeString('en-ZA', {hour: '2-digit', minute: '2-digit', timeZone: 'Africa/Johannesburg'});\n  return `<h2>Meeting Reminder - Tomorrow</h2>\n  <p>Hi ${m.client.first_name},</p>\n  <p>This is a friendly reminder that you have a <strong>${m.meeting_type}</strong> meeting scheduled:</p>\n  <div style=\"background:#f0f0ff;border:1px solid #d0d0ff;border-radius:12px;padding:20px;margin:16px 0;\">\n    <p><strong>Date:</strong> ${dateStr}</p>\n    <p><strong>Time:</strong> ${timeStr} (SAST)</p>\n    <p><strong>Adviser:</strong> ${m.adviser.full_name}</p>\n    <p><strong>Duration:</strong> ${m.duration_minutes || 60} minutes</p>\n  </div>\n  ${m.teams_meeting_url ? '<p style=\"text-align:center;\"><a href=\"' + m.teams_meeting_url + '\" style=\"display:inline-block;background:#6264A7;color:#fff;padding:14px 32px;border-radius:8px;text-decoration:none;font-weight:600;\">Join Teams Meeting</a></p>' : ''}\n  <p>If you need to reschedule, please reply to this email.</p>`;\n})() }}",
        "toRecipients": "={{ $json.client.email }}",
        "subject": "=Reminder: Your meeting tomorrow with {{ $json.adviser.full_name }}",
        "additionalFields": {}
      },
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK_FA",
          "name": "Microsoft Outlook OAuth2 FA"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "9d1666fc-8b9f-4c96-94e1-572dc0260714",
      "name": "WhatsApp 24h Reminder",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v21.0//messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.FA_WHATSAPP_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": {{ $json.client.mobile }},\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"fa_reminder_24h\",\n    \"language\": {\"code\": \"en\"},\n    \"components\": [{\"type\": \"body\", \"parameters\": ={{ JSON.stringify([\n  {type: 'text', text: $json.client.first_name},\n  {type: 'text', text: $json.adviser.full_name},\n  {type: 'text', text: new Date($json.scheduled_at).toLocaleDateString('en-ZA', {weekday: 'long', month: 'long', day: 'numeric', timeZone: 'Africa/Johannesburg'})},\n  {type: 'text', text: new Date($json.scheduled_at).toLocaleTimeString('en-ZA', {hour: '2-digit', minute: '2-digit', timeZone: 'Africa/Johannesburg'})}\n]) }}}]\n  }\n}",
        "options": {}
