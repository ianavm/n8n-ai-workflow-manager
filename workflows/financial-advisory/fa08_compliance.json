        "contentType": "html",
        "message": "={{ '<h3 style=\"color:#dc2626;\">CRITICAL Compliance Alert</h3><p>The daily compliance report has identified CRITICAL issues requiring immediate attention. Please review the compliance report sent to your email.</p><p>Report date: ' + $now.toFormat('dd MMM yyyy HH:mm') + '</p>' }}"
      },
      "credentials": {
        "microsoftTeamsOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK_FA",
          "name": "Microsoft Outlook OAuth2 FA"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
