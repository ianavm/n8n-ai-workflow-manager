            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    firm_id: 'ea0fbe19-4612-414a-b00f-f1ce185a1ea3',\n    action: 'compliance_report_generated',\n    entity_type: 'compliance_report',\n    details: {\n      has_critical: $('Format Report').first().json.has_critical,\n      report_date: new Date().toISOString()\n    },\n    performed_by: 'system',\n    created_at: new Date().toISOString()\n  })\n}}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    }
  ],
