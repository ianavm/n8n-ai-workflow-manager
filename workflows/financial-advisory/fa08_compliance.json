        "bodyContent": "={{ $json.html }}",
        "toRecipients": "={{ $env.FA_COMPLIANCE_EMAIL || 'compliance@anyvisionmedia.com' }}",
        "subject": "=Daily Compliance Report - {{ $now.toFormat('dd MMM yyyy') }}",
        "additionalFields": {}
      },
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK_FA",
          "name": "Microsoft Outlook OAuth2 FA"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "20d7e730-70e9-4ae0-9ee7-0a5c07f423c5",
      "name": "Any Critical",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1800,
        400
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $('Format Report').first().json.has_critical }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
