        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    client_id: $('Fetch Meeting').first().json[0].client_id,\n    firm_id: 'ea0fbe19-4612-414a-b00f-f1ce185a1ea3',\n    adviser_id: $('Fetch Meeting').first().json[0].adviser_id,\n    meeting_id: $('Fetch Meeting').first().json[0].id,\n    channel: 'email',\n    direction: 'outbound',\n    subject: 'Post-Meeting Summary',\n    status: 'sent',\n    sent_at: new Date().toISOString()\n  })\n}}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "8a42479b-ee00-476f-bdf4-b79221f606ec",
