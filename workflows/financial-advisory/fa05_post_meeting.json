{
  "name": "FA - Post-Meeting Processing (FA-05)",
  "nodes": [
    {
      "id": "59991c39-d4cd-472b-b698-03747ba7ebb6",
      "name": "Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ],
      "parameters": {}
    },
    {
      "id": "ffd75764-de46-4fd2-bf41-e48af177b307",
      "name": "Fetch Meeting",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        300,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://qfvsqjsrlnxjplqefhon.supabase.co/rest/v1/fa_meetings?select=*,insights:fa_meeting_insights(*),client:fa_clients(*),adviser:fa_advisers(*)&id=eq.{{ $json.meeting_id }}&select=*,insights:fa_meeting_insights(*),client:fa_clients(*),adviser:fa_advisers(*)",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "90adb08e-c959-42e7-90d6-4626c8c137cc",
      "name": "Generate Client Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        600,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 3000,\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": 'You are a financial advisory assistant. Generate a professional, client-friendly meeting summary email. Exclude compliance_flags and internal notes. Include: discussion points recap, agreed next steps, action items with owners. Use warm but professional tone. Output as HTML suitable for email.'},\n    {\"role\": \"user\", \"content\": \"Generate client meeting summary for: \" + JSON.stringify({  meeting: $('Fetch Meeting').first().json[0],  insights: $('Fetch Meeting').first().json[0]?.insights?.[0] || {}})}\n  ]\n}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "3a2acd90-1340-42d1-8ea1-8a1479f2d9ae",
      "name": "Email Client Summary",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        900,
        0
      ],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "bodyContentType": "html",
        "bodyContent": "={{ $('Generate Client Summary').first().json.choices?.[0]?.message?.content || '<p>Meeting summary is being prepared.</p>' }}",
        "toRecipients": "={{ $('Fetch Meeting').first().json[0].client.email }}",
        "subject": "=Meeting Summary: {{ $('Fetch Meeting').first().json[0].title || $('Fetch Meeting').first().json[0].meeting_type + ' Meeting' }}",
        "additionalFields": {}
      },
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK_FA",
          "name": "Microsoft Outlook OAuth2 FA"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "7f131bc6-1bfc-4b17-80ad-7db2cb06db64",
      "name": "Build Task Records",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "jsCode": "\n// Extract action items from meeting insights and build task records\nconst meeting = $('Fetch Meeting').first().json[0];\nconst insights = meeting?.insights?.[0] || {};\nconst actionItems = insights.action_items || [];\n\nconst tasks = actionItems.map((item, idx) => ({\n  client_id: meeting.client_id,\n  adviser_id: meeting.adviser_id,\n  firm_id: 'ea0fbe19-4612-414a-b00f-f1ce185a1ea3',\n  meeting_id: meeting.id,\n  title: item.task || 'Action item ' + (idx + 1),\n  description: item.task,\n  assignee: item.assignee || 'adviser',\n  due_date: item.suggested_due_date || new Date(Date.now() + 7*24*60*60*1000).toISOString().split('T')[0],\n  status: 'pending',\n  priority: 'medium'\n}));\n\nreturn [{json: {tasks}}];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "61de68bd-cfa6-40b2-9aa2-e745010290eb",
      "name": "Store Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1500,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://qfvsqjsrlnxjplqefhon.supabase.co/rest/v1/fa_tasks",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.tasks) }}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "b4f2e990-4bea-4052-b5f2-d88019e0efed",
      "name": "Log Communication",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1500,
        200
