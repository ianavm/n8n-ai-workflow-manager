          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ JSON.stringify($('Fetch Meeting').first().json[0]?.insights?.[0]?.next_steps || '').toLowerCase() }}",
              "rightValue": "follow",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "d4393ba8-d1f4-466f-95ba-4324819537e6",
      "name": "Schedule Follow-Up",
