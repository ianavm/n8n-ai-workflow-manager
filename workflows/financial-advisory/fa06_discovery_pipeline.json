    {
      "id": "4c81166c-8123-4a5f-b026-2b58f1970b01",
      "name": "Notify Adviser",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        2400,
        0
      ],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "bodyContentType": "html",
        "bodyContent": "={{ (function() {\n  const client = $('Fetch Full Client').first().json[0];\n  const pricing = $('Build Pricing Records').first().json.pricing || [];\n  const gap = $('Build Pricing Records').first().json.gap_analysis || 'See full report';\n  return `<h2>Analysis Complete</h2>\n  <p>The discovery analysis for <strong>${client.first_name} ${client.last_name}</strong> is ready for your review.</p>\n  <h3>Gap Analysis</h3>\n  <p>${gap}</p>\n  <h3>Recommendations (${pricing.length})</h3>\n  <ul>${pricing.map(p => `<li><strong>${p.product_type}</strong> - ${p.provider} (est. R${p.estimated_premium}/mo) - ${p.rationale}</li>`).join('')}</ul>\n  <p>Please review the Record of Advice draft before the presentation meeting.</p>\n  <p style=\"text-align:center;margin-top:20px;\"><a href=\"#\" style=\"display:inline-block;background:#FF6D5A;color:#fff;padding:14px 32px;border-radius:8px;text-decoration:none;font-weight:600;\">Review in Portal</a></p>`;\n})() }}",
        "toRecipients": "={{ $('Fetch Full Client').first().json[0]?.insights?.[0]?.adviser?.email || $('Workflow Trigger').first().json.adviser_id }}",
        "subject": "=Analysis Complete: {{ $('Fetch Full Client').first().json[0].first_name }} {{ $('Fetch Full Client').first().json[0].last_name }}",
        "additionalFields": {}
      },
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "PLACEHOLDER_OUTLOOK_FA",
          "name": "Microsoft Outlook OAuth2 FA"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
