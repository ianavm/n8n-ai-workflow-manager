    {
      "id": "0d89e5fa-68cd-4de1-80a1-95ba5ad04059",
      "name": "Research Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        600,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 5000,\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"Analyze this South African client's financial situation. Identify gaps in coverage, recommend specific products from the provider list, prioritize needs based on urgency and budget, consider risk tolerance. Output as JSON: {recommendations: [{product_type, provider, rationale, priority, estimated_premium}], gap_analysis: string, risk_assessment: string}\"},\n    {\"role\": \"user\", \"content\": \"Full client data for analysis: \" + JSON.stringify($('Fetch Full Client').first().json[0])}\n  ]\n}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "3ecef847-6ba5-48b3-9d1b-856dbad83ade",
      "name": "Generate Record of Advice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-20250514\",\n  \"max_tokens\": 6000,\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": 'Draft a FAIS-compliant Record of Advice for this South African client. Include: client needs analysis, recommendations with rationale, risk disclosures, fee disclosure, alternative products considered. Format as professional HTML document.'},\n    {\"role\": \"user\", \"content\": \"Client data: \" + JSON.stringify($('Fetch Full Client').first().json[0]) + \"\\n\\nResearch analysis: \" + JSON.stringify($('Research Analysis').first().json.choices?.[0]?.message?.content || '')}\n  ]\n}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "8f79ee67-ee92-4c45-a195-b02fa6d8fdba",
      "name": "Store Advice Doc",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://qfvsqjsrlnxjplqefhon.supabase.co/rest/v1/fa_documents",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    client_id: $('Workflow Trigger').first().json.client_id,\n    adviser_id: $('Workflow Trigger').first().json.adviser_id,\n    firm_id: 'ea0fbe19-4612-414a-b00f-f1ce185a1ea3',\n    meeting_id: $('Workflow Trigger').first().json.meeting_id,\n    document_type: 'record_of_advice',\n    title: 'Record of Advice - ' + ($('Fetch Full Client').first().json[0].first_name || '') + ' ' + ($('Fetch Full Client').first().json[0].last_name || ''),\n    content: $('Generate Record of Advice').first().json.choices?.[0]?.message?.content || '',\n    status: 'draft',\n    version: 1\n  })\n}}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "106c0f68-feda-421d-9509-67a72def59ee",
      "name": "Build Pricing Records",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        0
      ],
      "parameters": {
        "jsCode": "\n// Parse research analysis to extract recommendations with pricing\nconst raw = $('Research Analysis').first().json.choices?.[0]?.message?.content || '{}';\nlet analysis;\ntry {\n  const jsonMatch = raw.match(/```json\\n?([\\s\\S]*?)```/) || raw.match(/\\{[\\s\\S]*\\}/);\n  analysis = JSON.parse(jsonMatch ? (jsonMatch[1] || jsonMatch[0]) : raw);\n} catch (e) {\n  analysis = {recommendations: []};\n}\n\nconst recommendations = analysis.recommendations || [];\nconst clientId = $('Workflow Trigger').first().json.client_id;\nconst adviserId = $('Workflow Trigger').first().json.adviser_id;\n\nconst pricingRecords = recommendations.map((rec, idx) => ({\n  client_id: clientId,\n  adviser_id: adviserId,\n  firm_id: 'ea0fbe19-4612-414a-b00f-f1ce185a1ea3',\n  product_type: rec.product_type || 'unknown',\n  provider: rec.provider || 'TBD',\n  estimated_premium: rec.estimated_premium || 0,\n  rationale: rec.rationale || '',\n  priority: rec.priority || 'medium',\n  status: 'draft',\n  sort_order: idx + 1\n}));\n\nreturn [{json: {pricing: pricingRecords, gap_analysis: analysis.gap_analysis || '', risk_assessment: analysis.risk_assessment || ''}}];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "c7ed7153-4f4a-4745-84e5-3405d4a93f63",
