  },
  "email": {
    "recipient": "ian@anyvisionmedia.com",
    "subject": "n8n Workflow Report - {date}",
    "alert_recipient": "ian@anyvisionmedia.com"
  },
  "templates": {
    "directory": "templates",
    "auto_backup": true
  },
  "caching": {
    "enabled": true,
    "cache_duration_hours": 1
  }
