{
  "n8n": {
    "base_url": "https://your-n8n-instance.com",
    "api_version": "v1",
    "timeout_seconds": 30,
    "max_retries": 3
  },
  "instances": {
    "production": {
      "base_url": "https://n8n.anyvisionmedia.com",
      "label": "AnyVision Production"
    },
    "staging": {
      "base_url": "http://localhost:5678",
      "label": "Local Development"
    }
  },
  "workflow_categories": [
    "client_onboarding",
    "whatsapp_agents",
    "social_media",
    "lead_generation",
    "internal_tools",
    "ai_agents"
  ],
  "ai_models": {
    "preferred_provider": "openrouter",
    "models": {
      "qualification": "anthropic/claude-sonnet-4-20250514",
      "conversation": "openai/gpt-4o",
      "code_generation": "anthropic/claude-sonnet-4-20250514"
    }
  },
  "monitoring": {
    "check_interval_minutes": 15,
    "error_alert_threshold": 3,
    "execution_history_days": 30,
    "performance_baseline_days": 7
  },
  "reporting": {
    "title": "n8n Workflow Performance Report",
    "brand_color": "#FF6D5A",
